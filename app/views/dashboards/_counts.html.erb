<%# Flowbite admin-style KPI cards. Updated live via Turbo Stream from Defect commits. %>
<div id="dashboard_counts" class="grid grid-cols-2 lg:grid-cols-4 gap-4">

  <% cards = [
       { label: "Open defects", value: counts[:open],       icon: :folder,
         accent: "bg-talent-navy/5 text-talent-navy",
         sub: "All active across the org" },
       { label: "Overdue",      value: counts[:overdue],    icon: :alert,
         accent: "bg-rose-50 text-rose-700",
         sub: "SLA target passed" },
       { label: "≤48h to SLA",  value: counts[:amber],      icon: :clock,
         accent: "bg-amber-50 text-amber-700",
         sub: "Approaching breach" },
       { label: "Signed off",   value: counts[:signed_off], icon: :check,
         accent: "bg-emerald-50 text-emerald-700",
         sub: "Completed & approved" }
     ] %>

  <% cards.each do |c| %>
    <div class="bg-white border border-gray-200 rounded-lg p-5">
      <div class="flex items-center justify-between">
        <span class="text-xs font-medium text-gray-500 uppercase tracking-wide"><%= c[:label] %></span>
        <span class="inline-flex h-8 w-8 items-center justify-center rounded-lg <%= c[:accent] %>">
          <% case c[:icon] %>
          <% when :folder %>
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/></svg>
          <% when :alert %>
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
          <% when :clock %>
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          <% when :check %>
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          <% end %>
        </span>
      </div>
      <div class="mt-3 text-2xl font-semibold text-talent-navy"><%= c[:value] %></div>
      <div class="mt-1 text-xs text-gray-500"><%= c[:sub] %></div>
    </div>
  <% end %>
</div>
