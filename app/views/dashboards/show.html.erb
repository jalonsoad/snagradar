<% content_for :title, "Dashboard — SnagRadar" %>

<%# Live Turbo Stream subscription so KPI counts refresh on every defect change %>
<%= turbo_stream_from [:org, Current.organization.id, :dashboard] %>

<div class="space-y-6">

  <%# ─── Page header ──────────────────────────────────────────── %>
  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
    <div>
      <h1 class="text-2xl sm:text-3xl font-semibold tracking-tight text-talent-navy">
        Welcome back, <%= Current.user.display_name.split.first %>
      </h1>
      <p class="mt-1 text-sm text-gray-500">Here's what's on the radar today across <%= Current.organization.name %>.</p>
    </div>
    <div class="flex items-center gap-2">
      <%= link_to reports_path, class: "inline-flex items-center gap-2 rounded-lg border border-gray-200 bg-white px-4 py-2 text-sm font-medium text-talent-navy hover:bg-gray-50 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-talent-orange transition" do %>
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 17 9 11 13 15 21 7"/><polyline points="14 7 21 7 21 14"/></svg>
        Reports
      <% end %>
      <%= link_to new_defect_path, class: "inline-flex items-center gap-2 rounded-lg bg-talent-orange px-4 py-2 text-sm font-medium text-white hover:bg-talent-orange-600 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-talent-orange focus-visible:ring-offset-2 transition" do %>
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
        Log defect
      <% end %>
    </div>
  </div>

  <%# ─── KPI grid ─────────────────────────────────────────────── %>
  <%= render "counts", counts: @counts %>

  <%# ─── Operational charts (Geckoboard-style) ───────────────── %>
  <%= render "charts", chart: @chart %>

  <%# ─── Two-column main area ────────────────────────────────── %>
  <div class="grid grid-cols-1 xl:grid-cols-3 gap-6">

    <%# LEFT (2/3) — recent defects table + by-trade chart %>
    <div class="xl:col-span-2 space-y-6">

      <%# Recent defects (Flowbite table style) %>
      <div class="bg-white border border-gray-200 rounded-lg overflow-hidden">
        <div class="flex items-center justify-between px-5 py-4 border-b border-gray-200">
          <div>
            <h3 class="text-lg font-semibold text-talent-navy">Recent defects</h3>
            <p class="text-xs text-gray-500"><%= @recent_defects.size %> shown · latest activity first</p>
          </div>
          <%= link_to "View all", defects_path, class: "text-sm font-medium text-talent-orange hover:text-talent-orange-700 transition" %>
        </div>

        <% if @recent_defects.any? %>
          <div class="overflow-x-auto">
            <table class="w-full text-sm text-left text-gray-700">
              <thead class="text-xs text-gray-500 uppercase bg-gray-50 border-b border-gray-200">
                <tr>
                  <th scope="col" class="px-5 py-3">Defect</th>
                  <th scope="col" class="px-5 py-3">Trade</th>
                  <th scope="col" class="px-5 py-3">Contractor</th>
                  <th scope="col" class="px-5 py-3">Status</th>
                  <th scope="col" class="px-5 py-3 text-right">SLA</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-gray-100">
                <% @recent_defects.each do |d| %>
                  <tr class="hover:bg-gray-50 transition cursor-pointer" onclick="window.location='<%= defect_path(d) %>'">
                    <td class="px-5 py-3">
                      <div class="flex items-center gap-2 text-xs text-gray-500">
                        <span class="font-mono"><%= d.reference || "##{d.id}" %></span>
                        <span>·</span><span><%= d.site&.name %></span>
                        <% if d.plot %><span>·</span><span><%= d.plot.label %></span><% end %>
                      </div>
                      <div class="font-medium text-talent-navy mt-0.5"><%= d.title %></div>
                    </td>
                    <td class="px-5 py-3"><%= d.trade&.name %></td>
                    <td class="px-5 py-3 text-gray-500"><%= d.contractor_company&.name || "—" %></td>
                    <td class="px-5 py-3"><%= render "defects/status_badge", status: d.status %></td>
                    <td class="px-5 py-3 text-right"><%= render "defects/sla_badge", defect: d %></td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        <% else %>
          <div class="p-10 text-center">
            <svg class="mx-auto h-10 w-10 text-gray-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="9"/><circle cx="12" cy="12" r="5"/></svg>
            <h4 class="mt-3 font-semibold text-talent-navy">No defects yet</h4>
            <p class="mt-1 text-sm text-gray-500">Log your first defect to see it on the radar.</p>
            <%= link_to "Log a defect", new_defect_path, class: "inline-flex items-center gap-2 mt-4 rounded-lg bg-talent-orange px-4 py-2 text-sm font-medium text-white hover:bg-talent-orange-600 transition" %>
          </div>
        <% end %>
      </div>

    </div>

    <%# RIGHT (1/3) — Awaiting acceptance + upcoming appointments %>
    <div class="space-y-6">

      <% awaiting_count = Current.organization.defects.where(status: :assigned).count %>
      <div class="bg-white border border-gray-200 rounded-lg p-5">
        <div class="flex items-center justify-between">
          <h3 class="text-sm font-medium text-gray-500 uppercase tracking-wide">Awaiting acceptance</h3>
          <span class="inline-flex items-center justify-center w-6 h-6 text-xs font-medium text-talent-orange-700 bg-talent-orange-50 rounded-full"><%= awaiting_count %></span>
        </div>
        <p class="mt-3 text-2xl font-semibold text-talent-navy"><%= awaiting_count %></p>
        <p class="mt-1 text-xs text-gray-500">Trades who haven't replied within 24h.</p>
        <% if awaiting_count > 0 %>
          <%= link_to defects_path(filter: "open"), class: "mt-4 inline-flex items-center gap-1 text-sm font-medium text-talent-orange hover:text-talent-orange-700 transition" do %>
            Review them
            <svg class="h-3 w-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
          <% end %>
        <% end %>
      </div>

      <div class="bg-white border border-gray-200 rounded-lg">
        <div class="px-5 py-4 border-b border-gray-200 flex items-center justify-between">
          <h3 class="text-lg font-semibold text-talent-navy">Upcoming</h3>
          <%= link_to "Calendar", appointments_path, class: "text-sm font-medium text-talent-orange hover:text-talent-orange-700 transition" %>
        </div>
        <% if @upcoming_appointments.any? %>
          <ul class="divide-y divide-gray-100">
            <% @upcoming_appointments.each do |appt| %>
              <li class="px-5 py-3 flex items-center gap-3">
                <div class="flex-shrink-0 w-12 text-center">
                  <div class="text-[10px] font-semibold uppercase tracking-widest text-gray-400"><%= appt.scheduled_at.strftime("%a") %></div>
                  <div class="text-xl font-bold text-talent-navy"><%= appt.scheduled_at.day %></div>
                  <div class="text-[10px] text-gray-400 font-mono"><%= appt.scheduled_at.strftime("%H:%M") %></div>
                </div>
                <div class="flex-1 min-w-0">
                  <%= link_to appt.defect.title, defect_path(appt.defect), class: "text-sm font-medium text-talent-navy hover:text-talent-orange transition block truncate" %>
                  <div class="text-xs text-gray-500"><%= appt.defect.trade&.name %> · <%= appt.defect.site&.name %></div>
                </div>
              </li>
            <% end %>
          </ul>
        <% else %>
          <div class="p-8 text-center text-sm text-gray-500">No appointments coming up.</div>
        <% end %>
      </div>
    </div>
  </div>
</div>
