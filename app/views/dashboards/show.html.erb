<% content_for :title, "Dashboard — SnagRadar" %>

<div class="space-y-6">
  <%# Greeting + quick action %>
  <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4">
    <div>
      <h1 class="font-display text-3xl sm:text-4xl font-extrabold tracking-tight text-talent-navy">
        Welcome back, <%= Current.user.display_name.split.first %>
      </h1>
      <p class="mt-1 text-talent-slate">Here's what's on the radar today.</p>
    </div>
    <button class="btn-primary cursor-pointer">
      <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
      New defect
    </button>
  </div>

  <%# KPI grid %>
  <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
    <% [
         { label: "Open",        value: @counts[:open],       bg: "bg-talent-navy text-white",                   sub: "All active defects" },
         { label: "Overdue",     value: @counts[:overdue],    bg: "bg-rose-50 text-rose-700",                    sub: "SLA target passed" },
         { label: "≤48h to SLA", value: @counts[:amber],      bg: "bg-amber-50 text-amber-700",                  sub: "Approaching breach" },
         { label: "Signed off",  value: @counts[:signed_off], bg: "bg-emerald-50 text-emerald-700",              sub: "Last 30 days" }
       ].each do |k| %>
      <div class="rounded-2xl p-5 <%= k[:bg] %> shadow-soft">
        <div class="text-xs font-semibold uppercase tracking-wide opacity-80"><%= k[:label] %></div>
        <div class="font-display text-4xl font-extrabold mt-2"><%= k[:value] %></div>
        <div class="text-xs opacity-75 mt-1"><%= k[:sub] %></div>
      </div>
    <% end %>
  </div>

  <%# Two-column: recent defects + appointments %>
  <div class="grid lg:grid-cols-12 gap-4">
    <div class="lg:col-span-8 rounded-2xl bg-white border border-talent-navy/5 shadow-soft">
      <div class="px-5 py-4 border-b border-talent-navy/5 flex items-center justify-between">
        <div class="font-display text-lg font-extrabold">Recent defects</div>
        <%= link_to "View all", "#", class: "text-sm font-semibold text-talent-orange hover:text-talent-orange-700 transition" %>
      </div>
      <% if @recent_defects.any? %>
        <ul class="divide-y divide-talent-navy/5">
          <% @recent_defects.each do |d| %>
            <li class="px-5 py-3.5 flex items-center gap-3 hover:bg-talent-mist/50 transition">
              <div class="h-10 w-10 rounded-xl bg-talent-mist grid place-items-center text-talent-navy flex-shrink-0">
                <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><circle cx="12" cy="12" r="5"/><circle cx="12" cy="12" r="1.5" fill="currentColor"/></svg>
              </div>
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-2 text-xs text-talent-muted">
                  <span class="font-mono font-semibold"><%= d.reference || "##{d.id}" %></span>
                  <span>·</span><span><%= d.site&.name %></span>
                  <% if d.plot %><span>·</span><span><%= d.plot.label %></span><% end %>
                  <span>·</span><span><%= d.trade&.name %></span>
                </div>
                <div class="text-sm font-semibold text-talent-navy truncate"><%= d.title %></div>
              </div>
              <% case d.sla_state
                 when :red %>
                <span class="sla-red"><span class="dot bg-red-500"></span> <%= d.days_until_sla.to_i.abs %>d overdue</span>
              <% when :amber %>
                <span class="sla-amber"><span class="dot bg-amber-500"></span> Due in <%= d.days_until_sla %>d</span>
              <% when :green %>
                <span class="sla-green"><span class="dot bg-emerald-500"></span> On track</span>
              <% else %>
                <span class="text-xs text-talent-muted">No SLA</span>
              <% end %>
            </li>
          <% end %>
        </ul>
      <% else %>
        <div class="p-10 text-center">
          <div class="mx-auto h-14 w-14 rounded-2xl bg-talent-orange/10 text-talent-orange grid place-items-center">
            <svg class="h-7 w-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="9"/><circle cx="12" cy="12" r="5"/><circle cx="12" cy="12" r="1.5" fill="currentColor"/></svg>
          </div>
          <h3 class="mt-4 font-display text-lg font-extrabold text-talent-navy">No defects yet</h3>
          <p class="mt-1 text-sm text-talent-muted">Log your first defect to see it on the radar.</p>
          <button class="btn-primary mt-5 cursor-pointer">Log a defect</button>
        </div>
      <% end %>
    </div>

    <div class="lg:col-span-4 space-y-4">
      <div class="card-accent-orange p-5 relative overflow-hidden">
        <div class="absolute inset-0 bp-grid opacity-30 pointer-events-none"></div>
        <div class="relative">
          <div class="text-xs font-semibold uppercase tracking-wider text-white/80">Awaiting acceptance</div>
          <div class="font-display text-4xl font-extrabold mt-2"><%= 0 %></div>
          <p class="mt-1 text-sm text-white/85">Trades who haven't replied within 24h get auto-flagged here.</p>
        </div>
      </div>

      <div class="rounded-2xl bg-white border border-talent-navy/5 shadow-soft">
        <div class="px-5 py-4 border-b border-talent-navy/5 flex items-center justify-between">
          <div class="font-display text-lg font-extrabold">Upcoming</div>
          <%= link_to "Calendar", "#", class: "text-xs font-semibold text-talent-orange hover:text-talent-orange-700 transition" %>
        </div>
        <% if @upcoming_appointments.any? %>
          <ul class="divide-y divide-talent-navy/5">
            <% @upcoming_appointments.each do |a| %>
              <li class="px-5 py-3 text-sm">
                <div class="font-medium text-talent-navy"><%= a.defect&.title %></div>
                <div class="text-xs text-talent-muted mt-0.5"><%= a.scheduled_at.strftime("%a %d %b · %H:%M") %></div>
              </li>
            <% end %>
          </ul>
        <% else %>
          <div class="p-6 text-center text-sm text-talent-muted">No appointments yet.</div>
        <% end %>
      </div>
    </div>
  </div>
</div>
