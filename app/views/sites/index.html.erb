<% content_for :title, "Sites — SnagRadar" %>

<div class="space-y-6">
  <div class="flex items-end justify-between gap-4">
    <div>
      <h1 class="font-display text-3xl font-extrabold tracking-tight text-talent-navy">Sites</h1>
      <p class="mt-1 text-talent-slate"><%= @sites.size %> in your organisation</p>
    </div>
    <%= link_to new_site_path, class: "btn-primary cursor-pointer" do %>
      <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
      Add site
    <% end %>
  </div>

  <div class="rounded-2xl bg-white border border-talent-navy/5 shadow-soft overflow-hidden">
    <% if @sites.any? %>
      <table class="w-full text-sm">
        <thead class="bg-talent-mist/50 border-b border-talent-navy/5">
          <tr class="text-left text-xs font-semibold uppercase tracking-wider text-talent-muted">
            <th class="px-5 py-3">Name</th>
            <th class="px-5 py-3">Reference</th>
            <th class="px-5 py-3">Address</th>
            <th class="px-5 py-3">Plots</th>
            <th class="px-5 py-3 text-right">Status</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-talent-navy/5">
          <% @sites.each do |s| %>
            <tr class="hover:bg-talent-mist/40 transition cursor-pointer" onclick="window.location='<%= site_path(s) %>'">
              <td class="px-5 py-3.5 font-semibold text-talent-navy"><%= s.name %></td>
              <td class="px-5 py-3.5 text-talent-slate font-mono text-xs"><%= s.reference || "—" %></td>
              <td class="px-5 py-3.5 text-talent-slate"><%= s.address || "—" %></td>
              <td class="px-5 py-3.5 text-talent-slate"><%= s.plots.size %></td>
              <td class="px-5 py-3.5 text-right">
                <span class="inline-flex items-center gap-1.5 rounded-full bg-talent-mist text-talent-navy px-2.5 py-1 text-xs font-semibold capitalize"><%= s.status %></span>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <div class="p-10 text-center">
        <h3 class="font-display text-xl font-extrabold text-talent-navy">No sites yet</h3>
        <p class="mt-2 text-talent-muted">Add your first site (development) — plots go inside.</p>
        <%= link_to "Add a site", new_site_path, class: "btn-primary mt-5 inline-flex cursor-pointer" %>
      </div>
    <% end %>
  </div>
</div>
