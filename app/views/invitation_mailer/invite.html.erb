<!DOCTYPE html>
<html>
<body style="font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; max-width: 560px; margin: 0 auto; padding: 24px; color: #022043;">
  <div style="text-align: center; margin-bottom: 32px;">
    <strong style="font-size: 20px;"><span style="color: #022043;">Snag</span><span style="color: #FC5A07;">Radar</span></strong>
  </div>

  <h1 style="font-size: 24px; margin-bottom: 16px;">You're invited to <%= @org.name %></h1>

  <p style="line-height: 1.6; color: #38506D;">
    <strong><%= @invited_by.display_name %></strong> has invited you to join their SnagRadar workspace as
    <strong><%= @invitation.role.titleize %></strong>.
  </p>

  <p style="text-align: center; margin: 32px 0;">
    <a href="<%= @url %>" style="display: inline-block; background: #FC5A07; color: #fff; padding: 14px 32px; border-radius: 9999px; text-decoration: none; font-weight: 600;">
      Accept invitation →
    </a>
  </p>

  <p style="font-size: 12px; color: #6B7C93; line-height: 1.6;">
    This invitation expires in 14 days. If you weren't expecting this, you can ignore the message —
    the link will quietly stop working.
  </p>
</body>
</html>
