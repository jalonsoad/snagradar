      { key: "done",        title: "Done",        accent: "bg-emerald-500",
        cards: [
          { ref: "SNG-189", title: "Email intake mailbox (Action Mailbox)", description: "Inbound defects+adur-14@acme parses subject, body, photos, runs the classifier and creates the Defect.",
            cover: "orange",
            tags: [{ label: "Mailbox",   tone: "blue"   }, { label: "Done",      tone: "emerald" }],
            assignees: %w[SJ TM], comments: 6, attachments: 5, due: "Apr 14" },
          { ref: "SNG-185", title: "Solid Queue recurring SLA check", description: "Nightly job flags amber + red defects and notifies the right team channel.",
            tags: [{ label: "Backend",   tone: "indigo" }],
            assignees: %w[AK RP], comments: 1, attachments: 0, due: "Apr 12" },
          { ref: "SNG-180", title: "Onboarding wizard", description: "3-step setup: org, first site, first contractor invite.",
            tags: [{ label: "Onboarding", tone: "pink" }],
            assignees: %w[SJ], comments: 0, attachments: 0, due: "Apr 10" }
