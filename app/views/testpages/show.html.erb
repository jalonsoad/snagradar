        ] },
      { key: "in_progress", title: "In progress", accent: "bg-amber-500",
        cards: [
          { ref: "SNG-205", title: "Build the SLA breach dashboard", description: "Red/amber/green KPIs + drill-through table. Should respect the org's working-day calendar.",
            cover: "navy",
