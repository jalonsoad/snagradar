  <%# ── 25. List group ──────────────────────────────────────── %>
  <section class="bg-white border border-gray-200 rounded-lg p-6">
    <header class="mb-5">
      <h2 class="text-lg font-semibold text-talent-navy">25 · List group</h2>
      <p class="text-sm text-gray-500">Settings-style list with rich rows — title, helper text, value indicator on the right.</p>
    </header>

    <div class="grid lg:grid-cols-2 gap-6">
      <%# Settings list %>
      <ul class="divide-y divide-gray-100 rounded-lg border border-gray-200 overflow-hidden bg-white">
        <% [
          { title: "Email notifications",   sub: "Daily digest, 9:00 GMT",                state: "On" },
          { title: "SMS escalations",       sub: "For red-flagged SLA breaches only",      state: "On" },
          { title: "Slack integration",     sub: "Posts to #snags channel",                state: "Off" },
          { title: "Auto-assign contractor", sub: "Based on trade + postcode rules",       state: "Beta" },
          { title: "Two-factor authentication", sub: "TOTP via authenticator app",         state: "Required" }
        ].each do |row| %>
          <li class="flex items-center justify-between gap-3 px-4 py-3 hover:bg-gray-50 transition">
            <div class="min-w-0">
              <div class="text-sm font-medium text-talent-navy"><%= row[:title] %></div>
              <div class="text-xs text-gray-500"><%= row[:sub] %></div>
            </div>
            <span class="text-xs font-medium px-2 py-0.5 rounded-full
                         <%= 'bg-emerald-100 text-emerald-700' if row[:state] == 'On' %>
                         <%= 'bg-gray-100    text-gray-600'    if row[:state] == 'Off' %>
                         <%= 'bg-amber-100   text-amber-700'   if row[:state] == 'Beta' %>
                         <%= 'bg-rose-100    text-rose-700'    if row[:state] == 'Required' %>">
              <%= row[:state] %>
            </span>
          </li>
        <% end %>
      </ul>

      <%# Simple anchor list — icons stored in a hash to keep ERB readable. %>
      <%
        list_icons = {
          grid:   '<svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7" rx="1.5"/><rect x="14" y="3" width="7" height="7" rx="1.5"/><rect x="3" y="14" width="7" height="7" rx="1.5"/><rect x="14" y="14" width="7" height="7" rx="1.5"/></svg>'.html_safe,
          folder: '<svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/></svg>'.html_safe,
          users:  '<svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>'.html_safe,
          chart:  '<svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>'.html_safe,
          cog:    '<svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9 1.65 1.65 0 0 0 4.27 7.18l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>'.html_safe
        }
      %>
      <ul class="rounded-lg border border-gray-200 overflow-hidden divide-y divide-gray-100 bg-white">
        <% [
          { icon: :grid,    label: "Dashboard" },
          { icon: :folder,  label: "Defects",  badge: 12 },
          { icon: :users,   label: "Contractors" },
          { icon: :chart,   label: "Reports" },
          { icon: :cog,     label: "Settings" }
        ].each do |row| %>
          <li>
            <a href="#" class="flex items-center gap-3 px-4 py-3 hover:bg-gray-50 transition">
              <span class="h-8 w-8 grid place-items-center rounded-md bg-gray-100 text-talent-navy"><%= list_icons[row[:icon]] %></span>
              <span class="flex-1 text-sm font-medium text-talent-navy"><%= row[:label] %></span>
              <% if row[:badge] %>
                <span class="inline-flex items-center justify-center min-w-[20px] h-5 px-1.5 rounded-full bg-talent-orange-50 text-talent-orange-700 text-[11px] font-semibold"><%= row[:badge] %></span>
              <% end %>
              <svg class="h-3 w-3 text-gray-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="9 18 15 12 9 6"/></svg>
            </a>
          </li>
        <% end %>
      </ul>
    </div>
  </section>

  <%# ── 26. Empty states ────────────────────────────────────── %>
  <section class="bg-white border border-gray-200 rounded-lg p-6">
    <header class="mb-5">
      <h2 class="text-lg font-semibold text-talent-navy">26 · Empty states</h2>
      <p class="text-sm text-gray-500">Four patterns: nothing-here, search-no-results, error, and success / all-done.</p>
    </header>

    <div class="grid sm:grid-cols-2 gap-4">
      <%# Nothing here yet %>
      <div class="rounded-lg border border-dashed border-gray-200 p-8 text-center">
        <div class="mx-auto h-12 w-12 rounded-full bg-talent-orange-50 text-talent-orange grid place-items-center">
          <%= icon "satellite", class: "h-6 w-6" %>
        </div>
        <h4 class="mt-3 text-sm font-semibold text-talent-navy">No defects yet</h4>
        <p class="mt-1 text-xs text-gray-500">Log your first defect and it appears on the radar instantly.</p>
        <button class="mt-3 inline-flex items-center gap-1.5 rounded-lg bg-talent-orange px-3 py-1.5 text-xs font-medium text-white hover:bg-talent-orange-600 cursor-pointer transition">
          <%= icon "plus", class: "h-3 w-3" %>
          Log defect
        </button>
      </div>

      <%# Search no results %>
      <div class="rounded-lg border border-dashed border-gray-200 p-8 text-center">
        <div class="mx-auto h-12 w-12 rounded-full bg-gray-100 text-gray-500 grid place-items-center">
          <%= icon "search", class: "h-6 w-6" %>
        </div>
        <h4 class="mt-3 text-sm font-semibold text-talent-navy">No matches for "boiler"</h4>
        <p class="mt-1 text-xs text-gray-500">Try a different keyword, or clear filters to widen the search.</p>
        <button class="mt-3 inline-flex items-center gap-1.5 rounded-lg border border-gray-200 bg-white px-3 py-1.5 text-xs font-medium text-talent-navy hover:bg-gray-50 cursor-pointer transition">Clear filters</button>
      </div>

      <%# Error %>
      <div class="rounded-lg border border-rose-200 bg-rose-50/50 p-8 text-center">
        <div class="mx-auto h-12 w-12 rounded-full bg-rose-100 text-rose-700 grid place-items-center">
          <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        </div>
        <h4 class="mt-3 text-sm font-semibold text-talent-navy">Couldn't load reports</h4>
        <p class="mt-1 text-xs text-gray-500">Something went wrong on our side. Please try again in a moment.</p>
        <button class="mt-3 inline-flex items-center gap-1.5 rounded-lg bg-rose-600 px-3 py-1.5 text-xs font-medium text-white hover:bg-rose-700 cursor-pointer transition">Retry</button>
      </div>

      <%# All done %>
      <div class="rounded-lg border border-emerald-200 bg-emerald-50/50 p-8 text-center">
        <div class="mx-auto h-12 w-12 rounded-full bg-emerald-100 text-emerald-700 grid place-items-center">
          <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="20 6 9 17 4 12"/></svg>
        </div>
        <h4 class="mt-3 text-sm font-semibold text-talent-navy">All defects signed off</h4>
        <p class="mt-1 text-xs text-gray-500">Nice work — no outstanding items across any site. Tea break.</p>
        <button class="mt-3 inline-flex items-center gap-1.5 rounded-lg border border-emerald-200 bg-white px-3 py-1.5 text-xs font-medium text-emerald-700 hover:bg-emerald-50 cursor-pointer transition">View archive</button>
      </div>
    </div>
  </section>

  <%# ── 14. Coverage map — what we still might want ───────── %>
  <section class="bg-white border border-gray-200 rounded-lg p-6">
    <header class="mb-4">
      <h2 class="text-lg font-semibold text-talent-navy">14 · Coverage map</h2>
      <p class="text-sm text-gray-500">Quick stocktake of the Flowbite component catalogue. Anything not listed below is already on this page or used elsewhere in the app.</p>
    </header>

    <% covered = [
      "Dropdown", "Modal (standard, confirm, form)", "Drawer (right + mobile sidebar)", "Accordion", "Tabs", "Tooltip", "Popover",
      "Forms (all input types + dropzone)", "Password with eye toggle",
      "Charts (area, column, bar, donut, radial, line, sparkline)",
      "Toasts (success/info/warning/danger/rich)",
      "Datepicker (inline + input)", "Calendar (month grid + nav)",
      "Kanban board (Flowbite layout + SortableJS drag)",
      "Table (defects index)", "Timeline (defect show)", "Pagination shell",
      "Status & SLA badges", "Sidebar nav", "Topbar with user menu",
      "Realtime via Turbo Streams + Solid Cable",
      "Stepper / Wizard", "Skeleton loaders", "Progress bars (single + stacked)",
      "Spinners + button loading state", "Speed dial (FAB)", "Rating stars (display + interactive)",
      "Carousel (auto-rotate + indicators + controls)", "Banner (dismissible)",
      "Breadcrumb (chevron / slash / pill)", "List group (settings + nav)",
      "Empty states (4 patterns)"
    ] %>
    <% nice_to_add = [
      "Wire kanban drag → Turbo Stream PATCH (currently logs to console)",
      "Mega-menu / multi-column dropdown",
      "Dark mode toggle (theme is already token-driven)",
      "Rich text editor (Action Text + Trix)"
    ] %>

    <div class="grid sm:grid-cols-2 gap-6">
      <div>
        <h3 class="text-xs font-semibold uppercase tracking-wide text-emerald-700 mb-3 flex items-center gap-2">
          <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="20 6 9 17 4 12"/></svg>
          Covered (<%= covered.size %>)
        </h3>
        <ul class="space-y-1.5 text-sm text-talent-navy">
          <% covered.each do |c| %>
            <li class="flex items-start gap-2">
              <span class="mt-1.5 h-1 w-1 rounded-full bg-emerald-500 flex-shrink-0"></span>
              <span><%= c %></span>
            </li>
          <% end %>
        </ul>
      </div>
      <div>
        <h3 class="text-xs font-semibold uppercase tracking-wide text-talent-orange-700 mb-3 flex items-center gap-2">
          <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
          Worth doing next (<%= nice_to_add.size %>)
        </h3>
        <ul class="space-y-1.5 text-sm text-talent-navy">
          <% nice_to_add.each do |c| %>
            <li class="flex items-start gap-2">
              <span class="mt-1.5 h-1 w-1 rounded-full bg-talent-orange flex-shrink-0"></span>
              <span><%= c %></span>
            </li>
          <% end %>
        </ul>
      </div>
    </div>
  </section>

  <%# ── 15. Realtime via Turbo Streams + Solid Cable ───────── %>
  <section class="bg-white border border-gray-200 rounded-lg p-6">
    <header class="mb-5 flex items-start justify-between flex-wrap gap-3">
      <div>
        <h2 class="text-lg font-semibold text-talent-navy">15 · Realtime updates (Turbo Streams)</h2>
        <p class="text-sm text-gray-500">
          Open this page in a second tab. Post a message — it appears in <em>both</em> tabs instantly.
          Delete one — gone from both. No reload, no polling. Pure Hotwire over Solid Cable.
        </p>
      </div>
      <% if @testpage_messages.any? %>
        <%= button_to destroy_all_testpage_messages_path, method: :delete,
              class: "inline-flex items-center gap-2 rounded-lg border border-gray-200 bg-white px-3 py-1.5 text-sm font-medium text-talent-navy hover:bg-gray-50 cursor-pointer transition",
              form: { data: { turbo_confirm: "Clear every demo message?" } } do %>
          <%= icon "delete", class: "h-3.5 w-3.5 text-gray-500" %>
          Clear feed
        <% end %>
      <% end %>
    </header>

    <%# Subscribe to the broadcast channel. After this tag is rendered, any
        broadcast_prepend/remove_to "testpage_messages" reaches this tab live. %>
    <%= turbo_stream_from TestpageMessage::STREAM %>

    <div class="grid lg:grid-cols-5 gap-6">

      <%# Compose form (2/5) — extracted to partial so controller can
          turbo_stream.replace it after submit (clears textarea, no scroll). %>
      <div class="lg:col-span-2">
        <h3 class="text-xs font-medium text-gray-500 uppercase tracking-wide mb-3">Post a message</h3>
        <%= render "testpage_messages/form" %>

        <%# Helper: how it works %>
        <div class="mt-4 rounded-lg bg-gray-50 border border-gray-200 p-3 text-xs text-gray-600 leading-relaxed">
          <p class="font-semibold text-talent-navy mb-1">How it works</p>
          <ol class="list-decimal list-inside space-y-0.5">
            <li>Form POSTs to <code class="px-1 bg-white border border-gray-200 rounded font-mono">/testpage_messages</code>.</li>
            <li>Model <code class="px-1 bg-white border border-gray-200 rounded font-mono">after_create_commit</code> calls <code class="px-1 bg-white border border-gray-200 rounded font-mono">broadcast_prepend_to "testpage_messages"</code>.</li>
            <li>Every tab subscribed via <code class="px-1 bg-white border border-gray-200 rounded font-mono">turbo_stream_from</code> prepends the partial — no reload.</li>
            <li>Delete uses <code class="px-1 bg-white border border-gray-200 rounded font-mono">broadcast_remove_to</code> on the same channel.</li>
          </ol>
        </div>
      </div>

      <%# Live feed (3/5) %>
      <div class="lg:col-span-3">
        <div class="flex items-center justify-between mb-3">
          <h3 class="text-xs font-medium text-gray-500 uppercase tracking-wide">Live feed</h3>
          <span class="inline-flex items-center gap-1.5 text-xs text-emerald-700">
            <span class="relative inline-flex h-2 w-2">
              <span class="absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75 animate-ping"></span>
              <span class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"></span>
            </span>
            Subscribed
          </span>
        </div>

        <%# Container must keep the dom_id that broadcast_prepend_to targets. %>
        <div id="testpage_message_list" class="space-y-2 min-h-[200px]">
          <% if @testpage_messages.any? %>
            <%= render @testpage_messages %>
          <% else %>
            <div class="flex flex-col items-center justify-center text-center py-10 rounded-lg border border-dashed border-gray-200 bg-gray-50">
              <svg class="h-8 w-8 text-gray-300 mb-2" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>
              <p class="text-sm text-talent-navy font-medium">No messages yet</p>
              <p class="text-xs text-gray-500 mt-0.5">Post one on the left to see it appear here — and in every other open tab.</p>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </section>

  <%# ── Diagnostic note ────────────────────────────────────── %>
  <section class="bg-talent-navy text-white rounded-lg p-6">
    <h2 class="text-lg font-semibold">Diagnostic checklist</h2>
    <ul class="mt-3 space-y-1.5 text-sm text-white/80 list-disc list-inside">
      <li>Open the browser console — there should be no Flowbite import errors.</li>
      <li>Type <code class="px-1.5 py-0.5 bg-white/10 rounded font-mono">window.initFlowbite()</code> in the console to force re-init.</li>
      <li>Every interactive section above should react on click/hover.</li>
    </ul>
  </section>
</div>
