  %>

  <section class="bg-white border border-gray-200 rounded-lg p-6">
    <%# Top header %>
    <header class="mb-5">
      <h2 class="text-lg font-semibold text-talent-navy">13 · Kanban board</h2>
      <p class="text-sm text-gray-500 mt-1">Mirrors Flowbite's official Kanban demo — toolbar, three status columns, rich cards (cover image, colored tag chips, avatar stack, due + attachments + comments), drag-and-drop between columns.</p>
    </header>

    <%# Toolbar — matches the Flowbite kanban demo top bar %>
    <div class="flex flex-col xl:flex-row xl:items-center xl:justify-between gap-3 mb-5 pb-5 border-b border-gray-200">
      <div class="flex items-center gap-2">
        <button data-modal-target="tp-form-modal" data-modal-toggle="tp-form-modal" type="button"
                class="inline-flex items-center gap-2 rounded-lg bg-talent-orange px-4 py-2 text-sm font-medium text-white hover:bg-talent-orange-600 cursor-pointer transition">
          <%= icon "plus", class: "h-4 w-4" %>
          Add new task
        </button>
        <button data-dropdown-toggle="kanban-actions-menu" data-dropdown-placement="bottom-start" type="button"
