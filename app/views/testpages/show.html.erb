          Actions
          <svg class="h-3 w-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="6 9 12 15 18 9"/></svg>
        </button>
        <div id="kanban-actions-menu" class="z-50 hidden w-48 bg-white rounded-lg border border-gray-200 shadow-lg overflow-hidden">
          <ul class="py-1 text-sm text-talent-navy">
            <li><a class="block px-4 py-2 hover:bg-gray-50" href="#">Reset board</a></li>
            <li><a class="block px-4 py-2 hover:bg-gray-50" href="#">Export to CSV</a></li>
            <li class="border-t border-gray-100"><a class="block px-4 py-2 text-rose-600 hover:bg-rose-50" href="#">Archive all done</a></li>
          </ul>
        </div>
      </div>

      <div class="flex items-center gap-2">
        <%# Search %>
        <div class="relative flex-1 xl:w-72">
          <span class="absolute inset-y-0 left-0 pl-3 flex items-center text-gray-400 pointer-events-none">
            <%= icon "search", class: "h-4 w-4" %>
          </span>
          <input type="search" placeholder="Search tasks…"
                 class="block w-full rounded-lg border border-gray-200 bg-white pl-10 pr-3 py-2 text-sm focus:outline-none focus:border-talent-orange focus:ring-2 focus:ring-talent-orange/20">
        </div>
        <%# Filter dropdown %>
        <button data-dropdown-toggle="kanban-filter-menu" data-dropdown-placement="bottom-end" type="button"
                class="inline-flex items-center gap-2 rounded-lg border border-gray-200 bg-white px-3 py-2 text-sm font-medium text-talent-navy hover:bg-gray-50 cursor-pointer transition">
          <%= icon "filter", class: "h-4 w-4" %>
          Filter
        </button>
        <div id="kanban-filter-menu" class="z-50 hidden w-56 bg-white rounded-lg border border-gray-200 shadow-lg p-3">
          <h6 class="text-xs font-semibold uppercase tracking-wide text-gray-500 mb-2">Priority</h6>
          <div class="space-y-1.5">
            <% %w[High Medium Low Lowest].each_with_index do |level, i| %>
              <label class="flex items-center gap-2 text-sm text-talent-navy cursor-pointer">
                <input type="checkbox" <%= "checked" if i.zero? %> class="h-4 w-4 rounded border-gray-300 text-talent-orange focus:ring-talent-orange">
                <%= level %>
              </label>
            <% end %>
          </div>
          <h6 class="text-xs font-semibold uppercase tracking-wide text-gray-500 mt-3 mb-2">Type</h6>
          <div class="space-y-1.5">
            <% %w[Issue Feature Sprint Milestone].each_with_index do |t, i| %>
              <label class="flex items-center gap-2 text-sm text-talent-navy cursor-pointer">
                <input type="checkbox" <%= "checked" if i == 2 %> class="h-4 w-4 rounded border-gray-300 text-talent-orange focus:ring-talent-orange">
                <%= t %>
              </label>
            <% end %>
          </div>
        </div>

        <%# View toggle (Board / List) %>
        <div class="inline-flex rounded-lg border border-gray-200 bg-white overflow-hidden">
          <button class="inline-flex items-center gap-1.5 px-3 py-2 text-sm font-medium text-talent-navy bg-gray-50 border-r border-gray-200 cursor-pointer">
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="9"/><rect x="14" y="3" width="7" height="5"/><rect x="14" y="12" width="7" height="9"/><rect x="3" y="16" width="7" height="5"/></svg>
            Board
          </button>
          <button class="inline-flex items-center gap-1.5 px-3 py-2 text-sm font-medium text-gray-500 hover:bg-gray-50 cursor-pointer">
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/></svg>
            List
          </button>
        </div>

        <%# Assignee stack %>
        <div class="hidden xl:flex items-center -space-x-2 pl-2 ml-1 border-l border-gray-200">
          <% %w[SJ TM AK EM].each_with_index do |i, idx| %>
            <% bg = %w[bg-talent-orange bg-talent-blue bg-talent-navy bg-emerald-500][idx] %>
            <span class="inline-flex items-center justify-center h-7 w-7 rounded-full <%= bg %> ring-2 ring-white text-[10px] font-semibold text-white"><%= i %></span>
          <% end %>
          <button class="inline-flex items-center justify-center h-7 w-7 rounded-full bg-white ring-2 ring-white border border-dashed border-gray-300 text-gray-500 hover:bg-gray-50 cursor-pointer" aria-label="Invite teammate">
            <%= icon "plus", class: "h-3 w-3" %>
          </button>
        </div>
      </div>
    </div>

    <%# Columns %>
    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-4" data-controller="kanban">
      <% kanban_columns.each do |col| %>
        <div class="bg-gray-50 rounded-lg border border-gray-200 flex flex-col">
          <%# Column header %>
          <div class="px-4 py-3 border-b border-gray-200 flex items-center justify-between">
            <div class="flex items-center gap-2">
              <span class="h-2.5 w-2.5 rounded-full <%= col[:accent] %>"></span>
              <h3 class="text-sm font-semibold text-talent-navy"><%= col[:title] %></h3>
              <span class="inline-flex items-center justify-center rounded-full bg-white border border-gray-200 text-gray-600 px-2 min-w-[22px] h-5 text-[11px] font-semibold"><%= col[:cards].size %></span>
            </div>
            <div class="flex items-center gap-1">
              <button class="h-7 w-7 grid place-items-center rounded-md text-gray-400 hover:bg-gray-200 hover:text-talent-navy cursor-pointer transition" aria-label="Add card">
                <%= icon "plus", class: "h-3.5 w-3.5" %>
              </button>
              <button class="h-7 w-7 grid place-items-center rounded-md text-gray-400 hover:bg-gray-200 hover:text-talent-navy cursor-pointer transition" aria-label="Column actions">
                <%= icon "more", class: "h-3.5 w-3.5" %>
              </button>
            </div>
          </div>

          <%# Cards container — Sortable target %>
          <div class="p-3 space-y-3 flex-1 min-h-[260px]"
               data-kanban-target="column" data-column-key="<%= col[:key] %>">
            <% col[:cards].each do |card| %>
              <article data-card-id="<%= card[:ref] %>"
                       class="bg-white border border-gray-200 rounded-lg overflow-hidden hover:border-talent-orange/40 hover:shadow-sm transition cursor-grab active:cursor-grabbing">

                <%# Optional cover image / banner %>
                <% if card[:cover] %>
                  <div class="h-24 relative overflow-hidden">
                    <% case card[:cover]
                       when "navy" %>
                      <div class="absolute inset-0" style="background: linear-gradient(135deg, #022043 0%, #06335E 100%);"></div>
                      <svg class="absolute inset-0 w-full h-full opacity-20 text-white" viewBox="0 0 200 80" preserveAspectRatio="none"><path d="M0 60 C40 30 80 70 120 40 S180 50 200 30 L200 80 L0 80 Z" fill="currentColor"/></svg>
                    <% when "orange" %>
                      <div class="absolute inset-0" style="background: linear-gradient(135deg, #FC5A07 0%, #FF7A33 100%);"></div>
                      <svg class="absolute inset-0 w-full h-full opacity-25 text-white" viewBox="0 0 200 80" preserveAspectRatio="none"><circle cx="40" cy="40" r="30" fill="currentColor"/><circle cx="150" cy="60" r="40" fill="currentColor"/></svg>
                    <% end %>
                    <span class="absolute top-2 left-2 inline-flex items-center text-[10px] font-mono text-white/90 bg-black/20 backdrop-blur-sm px-1.5 py-0.5 rounded">
                      <%= card[:ref] %>
                    </span>
                  </div>
                <% end %>

                <div class="p-4">
                  <%# Header row: ref (if no cover) + actions %>
                  <% unless card[:cover] %>
                    <div class="flex items-center justify-between gap-2 mb-2">
                      <span class="inline-flex items-center text-[10px] font-mono text-gray-500"><%= card[:ref] %></span>
                      <button class="h-6 w-6 grid place-items-center rounded text-gray-400 hover:bg-gray-100 hover:text-talent-navy cursor-pointer" aria-label="Card actions">
                        <%= icon "more", class: "h-3 w-3" %>
                      </button>
                    </div>
                  <% end %>

                  <%# Title + description %>
                  <h4 class="text-base font-semibold text-talent-navy leading-snug mb-1.5"><%= card[:title] %></h4>
                  <p class="text-sm text-gray-500 leading-relaxed mb-3 line-clamp-2"><%= card[:description] %></p>

                  <%# Tag chips %>
                  <div class="flex flex-wrap gap-1.5 mb-4">
                    <% card[:tags].each do |tag| %>
                      <% tone = tag[:tone] %>
                      <span class="inline-flex items-center gap-1 text-[11px] font-medium px-2 py-0.5 rounded-md
                                   bg-<%= tone %>-100 text-<%= tone %>-700">
                        <span class="h-1.5 w-1.5 rounded-full bg-<%= tone %>-500"></span>
                        <%= tag[:label] %>
                      </span>
                    <% end %>
                  </div>

                  <%# Footer: avatar stack on left, meta on right %>
                  <div class="flex items-center justify-between text-xs text-gray-500">
                    <div class="flex -space-x-1.5">
                      <% card[:assignees].first(4).each do |key| %>
                        <% a = avatars[key] %>
                        <span class="inline-flex items-center justify-center h-6 w-6 rounded-full <%= a[:bg] %> ring-2 ring-white text-[10px] font-semibold text-white" title="<%= a[:initials] %>"><%= a[:initials] %></span>
                      <% end %>
                      <% if card[:assignees].size > 4 %>
                        <span class="inline-flex items-center justify-center h-6 w-6 rounded-full bg-gray-100 ring-2 ring-white text-[10px] font-semibold text-gray-600">+<%= card[:assignees].size - 4 %></span>
                      <% end %>
                    </div>
                    <div class="flex items-center gap-3">
                      <% if card[:due].present? %>
                        <span class="inline-flex items-center gap-1 font-medium <%= card[:due] == 'today' ? 'text-rose-600' : 'text-gray-500' %>" title="Due">
                          <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                          <%= card[:due] %>
                        </span>
                      <% end %>
                      <% if card[:comments] > 0 %>
                        <span class="inline-flex items-center gap-1" title="Comments">
                          <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                          <%= card[:comments] %>
                        </span>
                      <% end %>
                      <% if card[:attachments] > 0 %>
                        <span class="inline-flex items-center gap-1" title="Attachments">
                          <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21.44 11.05l-9.19 9.19a6 6 0 0 1-8.49-8.49l9.19-9.19a4 4 0 0 1 5.66 5.66l-9.2 9.19a2 2 0 0 1-2.83-2.83l8.49-8.48"/></svg>
                          <%= card[:attachments] %>
                        </span>
                      <% end %>
                    </div>
                  </div>
                </div>
              </article>
            <% end %>

            <%# Add new card — full-width ghost button at the end of each column %>
            <button class="w-full text-sm font-medium text-gray-500 hover:text-talent-navy hover:bg-white border border-dashed border-gray-300 hover:border-talent-orange/40 rounded-lg py-2.5 transition cursor-pointer flex items-center justify-center gap-1.5">
              <%= icon "plus", class: "h-4 w-4" %>
              Add task
            </button>
          </div>
        </div>
      <% end %>
    </div>
  </section>

  <%# ── 16. Stepper / Wizard ────────────────────────────────── %>
  <section class="bg-white border border-gray-200 rounded-lg p-6">
    <header class="mb-5">
      <h2 class="text-lg font-semibold text-talent-navy">16 · Stepper</h2>
      <p class="text-sm text-gray-500">Horizontal numbered steps. Past steps show a check, current step is highlighted, future steps are muted.</p>
    </header>

    <ol class="flex items-center w-full text-sm font-medium text-center text-gray-500 sm:text-base">
      <% [
        { n: 1, label: "Site",        sub: "Pick location",   state: :done },
        { n: 2, label: "Trade",       sub: "Match contractor", state: :done },
        { n: 3, label: "Defect",      sub: "Describe + photos", state: :current },
        { n: 4, label: "Review",      sub: "SLA + assign",     state: :upcoming },
        { n: 5, label: "Confirm",     sub: "Notify resident",  state: :upcoming }
      ].each_with_index do |s, i| %>
        <li class="flex items-center <%= 'md:w-full' if i < 4 %> <%= 'sm:after:content-[""] after:w-full after:h-1 after:border-b after:border-gray-200 after:border-1 after:hidden sm:after:inline-block after:mx-4 xl:after:mx-6' if i < 4 %>
                   <%= 'text-talent-orange' if s[:state] == :current %>
                   <%= 'text-emerald-700'   if s[:state] == :done %>">
          <span class="flex items-center after:content-['/'] sm:after:hidden after:mx-2 after:text-gray-200">
            <span class="me-2 flex items-center justify-center w-6 h-6 rounded-full
                         <%= 'bg-emerald-100 text-emerald-700' if s[:state] == :done %>
                         <%= 'bg-talent-orange text-white'      if s[:state] == :current %>
                         <%= 'bg-gray-100 text-gray-500'        if s[:state] == :upcoming %>">
              <% if s[:state] == :done %>
                <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              <% else %>
                <span class="text-xs font-semibold"><%= s[:n] %></span>
              <% end %>
            </span>
            <span class="hidden sm:flex flex-col items-start leading-tight">
              <span><%= s[:label] %></span>
              <span class="text-[10px] font-normal text-gray-400 uppercase tracking-wide"><%= s[:sub] %></span>
            </span>
          </span>
        </li>
      <% end %>
    </ol>

    <div class="mt-6 flex items-center justify-between border-t border-gray-200 pt-4">
      <button class="inline-flex items-center gap-2 rounded-lg border border-gray-200 bg-white px-4 py-2 text-sm font-medium text-talent-navy hover:bg-gray-50 cursor-pointer transition">
        <svg class="h-3 w-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="15 18 9 12 15 6"/></svg>
        Back
      </button>
      <span class="text-xs text-gray-500">Step 3 of 5</span>
      <button class="inline-flex items-center gap-2 rounded-lg bg-talent-orange px-4 py-2 text-sm font-medium text-white hover:bg-talent-orange-600 cursor-pointer transition">
        Continue
        <svg class="h-3 w-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="9 18 15 12 9 6"/></svg>
      </button>
    </div>
  </section>

  <%# ── 17. Skeleton loaders ────────────────────────────────── %>
  <section class="bg-white border border-gray-200 rounded-lg p-6">
    <header class="mb-5">
      <h2 class="text-lg font-semibold text-talent-navy">17 · Skeleton loaders</h2>
      <p class="text-sm text-gray-500">Placeholder shimmer while data loads. Three patterns: card, list, table row.</p>
    </header>

    <div class="grid lg:grid-cols-3 gap-6">
      <%# Card skeleton %>
      <div class="rounded-lg border border-gray-200 p-5 animate-pulse">
        <div class="flex items-center gap-3">
          <div class="h-10 w-10 rounded-full bg-gray-200"></div>
          <div class="flex-1 space-y-1.5">
            <div class="h-3 w-3/4 bg-gray-200 rounded"></div>
            <div class="h-2 w-1/2 bg-gray-100 rounded"></div>
          </div>
        </div>
        <div class="mt-5 space-y-2">
          <div class="h-2.5 bg-gray-200 rounded"></div>
          <div class="h-2.5 bg-gray-200 rounded"></div>
          <div class="h-2.5 w-5/6 bg-gray-200 rounded"></div>
        </div>
        <div class="mt-5 flex gap-2">
          <div class="h-8 w-20 bg-gray-200 rounded-lg"></div>
          <div class="h-8 w-16 bg-gray-100 rounded-lg"></div>
        </div>
      </div>

      <%# List skeleton %>
      <div class="rounded-lg border border-gray-200 divide-y divide-gray-100 animate-pulse">
        <% 4.times do %>
          <div class="flex items-center gap-3 p-4">
            <div class="h-8 w-8 rounded-full bg-gray-200"></div>
            <div class="flex-1 space-y-1.5">
              <div class="h-2.5 w-3/4 bg-gray-200 rounded"></div>
              <div class="h-2 w-1/3 bg-gray-100 rounded"></div>
            </div>
            <div class="h-6 w-12 bg-gray-100 rounded-full"></div>
          </div>
        <% end %>
      </div>

      <%# Table-row skeleton %>
      <div class="rounded-lg border border-gray-200 overflow-hidden animate-pulse">
        <div class="grid grid-cols-12 gap-3 bg-gray-50 border-b border-gray-200 px-4 py-3">
          <div class="col-span-4 h-2 bg-gray-200 rounded"></div>
          <div class="col-span-3 h-2 bg-gray-200 rounded"></div>
          <div class="col-span-3 h-2 bg-gray-200 rounded"></div>
          <div class="col-span-2 h-2 bg-gray-200 rounded"></div>
        </div>
        <% 5.times do %>
          <div class="grid grid-cols-12 gap-3 px-4 py-3 border-b border-gray-100 last:border-0">
            <div class="col-span-4 h-3 bg-gray-200 rounded"></div>
            <div class="col-span-3 h-3 bg-gray-100 rounded"></div>
            <div class="col-span-3 h-3 bg-gray-100 rounded"></div>
            <div class="col-span-2 h-3 bg-gray-200 rounded"></div>
          </div>
        <% end %>
      </div>
    </div>
  </section>

  <%# ── 18. Progress bars ───────────────────────────────────── %>
  <section class="bg-white border border-gray-200 rounded-lg p-6">
    <header class="mb-5">
      <h2 class="text-lg font-semibold text-talent-navy">18 · Progress</h2>
      <p class="text-sm text-gray-500">Linear bars at different sizes and tones, plus a stepped multi-segment example.</p>
    </header>

    <div class="space-y-5 max-w-2xl">
      <% [
        { label: "Plot sign-off",      pct: 85, tone: "talent-orange" },
        { label: "Plumbing trade",     pct: 62, tone: "talent-blue"   },
        { label: "Electrical trade",   pct: 34, tone: "amber"          },
        { label: "Outstanding snags",  pct: 12, tone: "rose"           }
      ].each do |bar| %>
        <div>
          <div class="flex items-center justify-between mb-1 text-sm">
            <span class="font-medium text-talent-navy"><%= bar[:label] %></span>
            <span class="text-gray-500"><%= bar[:pct] %>%</span>
          </div>
          <div class="w-full h-2.5 bg-gray-100 rounded-full overflow-hidden">
            <div class="h-2.5 rounded-full bg-<%= bar[:tone] %>" style="width: <%= bar[:pct] %>%"></div>
          </div>
        </div>
      <% end %>

      <%# Stacked / segmented progress %>
      <div>
        <div class="flex items-center justify-between mb-1 text-sm">
          <span class="font-medium text-talent-navy">Defect mix (this week)</span>
          <span class="text-gray-500">100%</span>
        </div>
        <div class="flex w-full h-3 bg-gray-100 rounded-full overflow-hidden">
          <div class="bg-emerald-500" style="width: 42%" title="Resolved"></div>
          <div class="bg-amber-500"   style="width: 28%" title="In progress"></div>
          <div class="bg-talent-blue" style="width: 18%" title="Logged"></div>
          <div class="bg-rose-500"    style="width: 12%" title="Overdue"></div>
        </div>
        <div class="mt-2 flex flex-wrap gap-x-4 gap-y-1 text-xs text-gray-500">
          <span class="inline-flex items-center gap-1.5"><span class="h-2 w-2 rounded-sm bg-emerald-500"></span>Resolved 42%</span>
          <span class="inline-flex items-center gap-1.5"><span class="h-2 w-2 rounded-sm bg-amber-500"></span>In progress 28%</span>
          <span class="inline-flex items-center gap-1.5"><span class="h-2 w-2 rounded-sm bg-talent-blue"></span>Logged 18%</span>
          <span class="inline-flex items-center gap-1.5"><span class="h-2 w-2 rounded-sm bg-rose-500"></span>Overdue 12%</span>
        </div>
      </div>
    </div>
  </section>

  <%# ── 19. Spinners + button loading state ─────────────────── %>
  <section class="bg-white border border-gray-200 rounded-lg p-6">
    <header class="mb-5">
      <h2 class="text-lg font-semibold text-talent-navy">19 · Spinners</h2>
      <p class="text-sm text-gray-500">Standalone spinners at multiple sizes / tones, plus a button in its loading state.</p>
    </header>

    <div class="flex items-center gap-6 flex-wrap">
      <% [
        { size: "h-4 w-4", color: "text-gray-300", fill: "fill-talent-orange" },
        { size: "h-6 w-6", color: "text-gray-300", fill: "fill-talent-orange" },
        { size: "h-8 w-8", color: "text-gray-300", fill: "fill-talent-navy"   },
        { size: "h-10 w-10", color: "text-gray-300", fill: "fill-emerald-500" },
        { size: "h-12 w-12", color: "text-gray-300", fill: "fill-rose-500"    }
      ].each do |spin| %>
        <svg class="animate-spin <%= spin[:size] %> <%= spin[:color] %> <%= spin[:fill] %>" viewBox="0 0 100 101" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path d="M100 50.5908C100 78.2051 77.6142 100.591 50 100.591C22.3858 100.591 0 78.2051 0 50.5908C0 22.9766 22.3858 0.59082 50 0.59082C77.6142 0.59082 100 22.9766 100 50.5908ZM9.08144 50.5908C9.08144 73.1895 27.4013 91.5094 50 91.5094C72.5987 91.5094 90.9186 73.1895 90.9186 50.5908C90.9186 27.9921 72.5987 9.67226 50 9.67226C27.4013 9.67226 9.08144 27.9921 9.08144 50.5908Z" fill="currentColor"/>
          <path d="M93.9676 39.0409C96.393 38.4038 97.8624 35.9116 97.0079 33.5539C95.2932 28.8227 92.871 24.3692 89.8167 20.348C85.8452 15.1192 80.8826 10.7238 75.2124 7.41289C69.5422 4.10194 63.2754 1.94025 56.7698 1.05124C51.7666 0.367541 46.6976 0.446843 41.7345 1.27873C39.2613 1.69328 37.813 4.19778 38.4501 6.62326C39.0873 9.04874 41.5694 10.4717 44.0505 10.1071C47.8511 9.54855 51.7191 9.52689 55.5402 10.0491C60.8642 10.7766 65.9928 12.5457 70.6331 15.2552C75.2735 17.9648 79.3347 21.5619 82.5849 25.841C84.9175 28.9121 86.7997 32.2913 88.1811 35.8758C89.083 38.2158 91.5421 39.6781 93.9676 39.0409Z" fill="currentFill"/>
        </svg>
      <% end %>
    </div>

    <div class="mt-6 flex items-center gap-3 flex-wrap">
      <%# Button with loading state %>
      <button type="button" disabled
              class="inline-flex items-center gap-2 rounded-lg bg-talent-orange px-4 py-2 text-sm font-medium text-white opacity-80 cursor-not-allowed">
        <svg class="animate-spin h-4 w-4 text-white/40 fill-white" viewBox="0 0 100 101" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path d="M100 50.5908C100 78.2051 77.6142 100.591 50 100.591C22.3858 100.591 0 78.2051 0 50.5908C0 22.9766 22.3858 0.59082 50 0.59082C77.6142 0.59082 100 22.9766 100 50.5908ZM9.08144 50.5908C9.08144 73.1895 27.4013 91.5094 50 91.5094C72.5987 91.5094 90.9186 73.1895 90.9186 50.5908C90.9186 27.9921 72.5987 9.67226 50 9.67226C27.4013 9.67226 9.08144 27.9921 9.08144 50.5908Z" fill="currentColor"/>
