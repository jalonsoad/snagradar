      <div class="flex items-center gap-2">
        <a href="#" class="text-xs font-medium text-talent-orange-700 hover:text-talent-orange whitespace-nowrap">Learn more →</a>
        <button type="button" data-dismiss-target="#tp-banner" aria-label="Dismiss banner"
                class="h-7 w-7 grid place-items-center rounded text-gray-500 hover:text-talent-navy hover:bg-white cursor-pointer transition">
          <svg class="w-3 h-3" viewBox="0 0 14 14" fill="none"><path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 1 6 6m0 0 6 6M7 7l6-6M7 7l-6 6"/></svg>
        </button>
      </div>
    </div>
  </section>

  <%# ── 24. Breadcrumb variants ─────────────────────────────── %>
  <section class="bg-white border border-gray-200 rounded-lg p-6">
    <header class="mb-5">
      <h2 class="text-lg font-semibold text-talent-navy">24 · Breadcrumb</h2>
      <p class="text-sm text-gray-500">Three breadcrumb styles: chevron separator, slash separator, and a pill-style trail.</p>
    </header>

    <div class="space-y-5">
      <%# Chevron %>
      <nav class="flex" aria-label="Breadcrumb">
        <ol class="inline-flex items-center gap-2 text-sm text-gray-500">
          <li><a href="/dashboard" class="hover:text-talent-orange transition">Dashboard</a></li>
