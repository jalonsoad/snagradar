          <li><a href="/dashboard" class="hover:text-talent-orange transition">Dashboard</a></li>
          <li class="px-2 text-gray-300">/</li>
          <li><a href="/sites"     class="hover:text-talent-orange transition">Sites</a></li>
          <li class="px-2 text-gray-300">/</li>
          <li><a href="#"          class="hover:text-talent-orange transition">Adur Apartments</a></li>
          <li class="px-2 text-gray-300">/</li>
          <li><span class="font-medium text-talent-navy" aria-current="page">Plot 14</span></li>
        </ol>
