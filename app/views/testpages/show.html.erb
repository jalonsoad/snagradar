      <nav class="flex" aria-label="Breadcrumb">
        <ol class="inline-flex items-center gap-1.5">
          <% [
            { label: "Reports", href: "/reports", active: false },
            { label: "SLA",     href: "#",        active: false },
            { label: "Q1 2026", href: "#",        active: true }
          ].each_with_index do |b, i| %>
            <li>
              <% if b[:active] %>
                <span class="inline-flex items-center rounded-md bg-talent-orange-50 text-talent-orange-700 text-xs font-medium px-2 py-1" aria-current="page"><%= b[:label] %></span>
              <% else %>
                <a href="<%= b[:href] %>" class="inline-flex items-center rounded-md bg-gray-100 text-talent-navy text-xs font-medium px-2 py-1 hover:bg-gray-200 transition"><%= b[:label] %></a>
