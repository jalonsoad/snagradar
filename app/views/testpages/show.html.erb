  <%# ── 20. Speed dial (floating action button) ─────────────── %>
  <section class="bg-white border border-gray-200 rounded-lg p-6">
    <header class="mb-5">
      <h2 class="text-lg font-semibold text-talent-navy">20 · Speed dial</h2>
      <p class="text-sm text-gray-500">A floating action button that fans out sub-actions on hover/click. Rendered inside this card relatively (production usage: fixed bottom-end).</p>
    </header>

    <div class="relative h-44 rounded-lg border border-dashed border-gray-200 bg-gray-50 grid place-items-center">
      <span class="text-xs text-gray-400 uppercase tracking-widest">Hover the orange button →</span>

      <div data-dial-init class="absolute end-6 bottom-6 group">
        <div id="tp-speed-dial-menu" class="flex flex-col items-center hidden mb-3 space-y-2">
          <% [
            { label: "Log defect",    icon_path: "M12 5v14M5 12h14" },
            { label: "Add site",      icon_path: "M3 21h18M5 21V8l7-5 7 5v13M9 21v-6h6v6" },
            { label: "Invite member", icon_path: "M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2M9 11a4 4 0 1 0 0-8 4 4 0 0 0 0 8zM20 8v6M23 11h-6" },
            { label: "Comment",       icon_path: "M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" }
          ].each_with_index do |a, i| %>
            <button type="button" data-tooltip-target="tp-dial-tip-<%= i %>" data-tooltip-placement="left"
                    class="flex items-center justify-center w-11 h-11 text-talent-navy bg-white border border-gray-200 rounded-full shadow-md hover:bg-gray-50 cursor-pointer transition">
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="<%= a[:icon_path] %>"/></svg>
              <span class="sr-only"><%= a[:label] %></span>
            </button>
            <div id="tp-dial-tip-<%= i %>" role="tooltip"
                 class="absolute z-10 invisible inline-block px-2 py-1 text-xs font-medium text-white bg-talent-navy rounded-md opacity-0 transition-opacity">
              <%= a[:label] %>
            </div>
          <% end %>
        </div>
        <button type="button" data-dial-toggle="tp-speed-dial-menu" aria-controls="tp-speed-dial-menu" aria-expanded="false"
                class="flex items-center justify-center w-14 h-14 text-white bg-talent-orange rounded-full hover:bg-talent-orange-600 shadow-lg cursor-pointer transition">
          <svg class="w-5 h-5 transition-transform group-hover:rotate-45" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
          <span class="sr-only">Open actions</span>
        </button>
      </div>
    </div>
  </section>

  <%# ── 21. Rating stars ────────────────────────────────────── %>
  <section class="bg-white border border-gray-200 rounded-lg p-6">
    <header class="mb-5">
      <h2 class="text-lg font-semibold text-talent-navy">21 · Rating</h2>
      <p class="text-sm text-gray-500">Static average display, distribution breakdown, and interactive selector.</p>
    </header>

    <% star_svg = '<svg class="%s" viewBox="0 0 22 20" fill="currentColor" xmlns="http://www.w3.org/2000/svg"><path d="M20.924 7.625a1.523 1.523 0 0 0-1.238-1.044l-5.051-.734-2.259-4.577a1.534 1.534 0 0 0-2.752 0L7.365 5.847l-5.051.734A1.535 1.535 0 0 0 1.463 9.2l3.656 3.563-.863 5.031a1.532 1.532 0 0 0 2.226 1.616L11 17.033l4.518 2.375a1.534 1.534 0 0 0 2.226-1.617l-.863-5.03 3.656-3.564a1.524 1.524 0 0 0 .387-1.572Z"/></svg>'.html_safe %>

    <div class="grid lg:grid-cols-2 gap-6">
      <%# Average + breakdown %>
      <div class="rounded-lg border border-gray-200 p-5">
        <div class="flex items-baseline gap-3">
          <span class="text-4xl font-semibold text-talent-navy">4.7</span>
          <span class="text-sm text-gray-500">out of 5</span>
        </div>
        <div class="flex items-center gap-1 mt-2">
          <% 5.times do |i| %>
            <%= raw star_svg % "w-5 h-5 #{i < 4 ? 'text-amber-400' : 'text-amber-400 opacity-70'}" %>
          <% end %>
        </div>
        <p class="mt-1 text-xs text-gray-500">1,248 ratings</p>
        <div class="mt-5 space-y-2">
          <% [[5, 78], [4, 14], [3, 5], [2, 2], [1, 1]].each do |stars, pct| %>
            <div class="flex items-center gap-2 text-xs text-gray-500">
              <span class="w-3 font-medium text-talent-navy"><%= stars %></span>
              <%= raw star_svg % "w-3 h-3 text-amber-400" %>
              <div class="flex-1 h-2 rounded-full bg-gray-100 overflow-hidden">
                <div class="h-2 rounded-full bg-amber-400" style="width: <%= pct %>%"></div>
              </div>
              <span class="w-8 text-right"><%= pct %>%</span>
            </div>
          <% end %>
        </div>
      </div>

      <%# Interactive rating (CSS-only via has-[:checked]:~) %>
      <div class="rounded-lg border border-gray-200 p-5">
        <h3 class="text-sm font-semibold text-talent-navy mb-2">Rate your contractor</h3>
        <p class="text-xs text-gray-500 mb-4">Pick a star — bigger taps for mobile.</p>
        <div class="flex flex-row-reverse justify-end items-center gap-1" role="radiogroup">
          <% (1..5).to_a.reverse.each do |n| %>
            <input type="radio" name="tp-rating" id="tp-rating-<%= n %>" value="<%= n %>" class="peer/<%= n %> sr-only">
            <label for="tp-rating-<%= n %>"
                   class="cursor-pointer text-gray-300 hover:text-amber-400 peer-checked/<%= n %>:text-amber-400 transition">
              <%= raw star_svg % "w-7 h-7" %>
              <span class="sr-only"><%= n %> star<%= 's' if n > 1 %></span>
            </label>
          <% end %>
        </div>
        <p class="mt-3 text-xs text-gray-500">Tip: this is purely CSS — no JS needed.</p>
      </div>
    </div>
  </section>

  <%# ── 22. Carousel ────────────────────────────────────────── %>
  <section class="bg-white border border-gray-200 rounded-lg p-6">
    <header class="mb-5">
      <h2 class="text-lg font-semibold text-talent-navy">22 · Carousel</h2>
      <p class="text-sm text-gray-500">Flowbite carousel with auto-rotate, indicators, prev/next, and slide captions.</p>
    </header>

    <div id="tp-carousel" class="relative w-full" data-carousel="slide">
      <%# Slides %>
      <div class="relative h-56 overflow-hidden rounded-lg md:h-72">
        <% slides = [
          { grad: "linear-gradient(135deg, #FC5A07 0%, #FF7A33 100%)", title: "Live SLA radar", body: "Track every defect from intake to sign-off — in real time." },
          { grad: "linear-gradient(135deg, #022043 0%, #06335E 100%)", title: "Contractor portal", body: "Tokenised links — no logins, no friction." },
          { grad: "linear-gradient(135deg, #0057AE 0%, #1B7AC9 100%)", title: "Resident sign-off", body: "Pointer-driven signature, captured on any phone." },
          { grad: "linear-gradient(135deg, #10B981 0%, #34D399 100%)", title: "Email intake",     body: "Defects+adur-14@acme — your inbox becomes the radar." }
        ] %>
        <% slides.each_with_index do |s, i| %>
          <div class="<%= 'hidden' unless i.zero? %> duration-700 ease-in-out absolute inset-0" data-carousel-item="<%= 'active' if i.zero? %>">
            <div class="absolute inset-0 grid place-items-center text-white text-center px-6" style="background: <%= s[:grad] %>;">
              <div>
                <h3 class="text-2xl font-semibold tracking-tight"><%= s[:title] %></h3>
                <p class="mt-2 text-sm max-w-md mx-auto text-white/80"><%= s[:body] %></p>
              </div>
            </div>
          </div>
        <% end %>
      </div>

      <%# Indicators %>
      <div class="absolute z-30 flex -translate-x-1/2 bottom-3 left-1/2 space-x-2">
        <% slides.each_with_index do |_, i| %>
          <button type="button" class="w-2 h-2 rounded-full bg-white/60 hover:bg-white" aria-current="<%= 'true' if i.zero? %>" aria-label="Slide <%= i + 1 %>" data-carousel-slide-to="<%= i %>"></button>
        <% end %>
      </div>

      <%# Prev / Next %>
      <button type="button" class="absolute top-0 start-0 z-30 flex items-center justify-center h-full px-4 cursor-pointer group focus:outline-none" data-carousel-prev>
        <span class="inline-flex items-center justify-center w-9 h-9 rounded-full bg-white/40 group-hover:bg-white/70 transition">
          <svg class="w-3 h-3 text-talent-navy" viewBox="0 0 6 10" fill="none"><path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 1 1 5l4 4"/></svg>
          <span class="sr-only">Previous</span>
        </span>
      </button>
      <button type="button" class="absolute top-0 end-0 z-30 flex items-center justify-center h-full px-4 cursor-pointer group focus:outline-none" data-carousel-next>
        <span class="inline-flex items-center justify-center w-9 h-9 rounded-full bg-white/40 group-hover:bg-white/70 transition">
          <svg class="w-3 h-3 text-talent-navy" viewBox="0 0 6 10" fill="none"><path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 9 4-4-4-4"/></svg>
          <span class="sr-only">Next</span>
        </span>
      </button>
    </div>
  </section>

  <%# ── 23. Banner ──────────────────────────────────────────── %>
  <section class="bg-white border border-gray-200 rounded-lg p-6">
    <header class="mb-5">
      <h2 class="text-lg font-semibold text-talent-navy">23 · Banner</h2>
      <p class="text-sm text-gray-500">Top-of-page announcement strip — dismissible via Flowbite <code class="px-1 py-0.5 bg-gray-100 rounded text-xs font-mono">data-dismiss-target</code>.</p>
    </header>

    <div id="tp-banner" tabindex="-1"
         class="flex items-center justify-between gap-3 p-3 rounded-lg border border-talent-orange-100 bg-talent-orange-50">
      <div class="flex items-center gap-3 text-sm text-talent-navy">
        <span class="inline-flex items-center justify-center w-7 h-7 rounded-full bg-talent-orange text-white">
          <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M11 5L6 9H2v6h4l5 4V5zM19.07 4.93a10 10 0 0 1 0 14.14M15.54 8.46a5 5 0 0 1 0 7.07"/></svg>
