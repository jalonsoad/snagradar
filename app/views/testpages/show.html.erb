<% content_for :title, "Component playground — SnagRadar" %>

<div class="space-y-10">

  <%# ── Header ──────────────────────────────────────────────── %>
  <div>
    <nav class="flex items-center gap-2 text-sm text-gray-500" aria-label="Breadcrumb">
      <%= link_to "Dashboard", dashboard_path, class: "hover:text-talent-navy transition" %>
      <svg class="h-3 w-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
      <span class="font-medium text-talent-navy">Component playground</span>
    </nav>
    <h1 class="mt-2 text-2xl sm:text-3xl font-semibold tracking-tight text-talent-navy">Flowbite component playground</h1>
    <p class="mt-1 text-sm text-gray-500">Quick smoke-test of the Flowbite components we rely on. If any trigger fails to react, Flowbite isn't initialising.</p>
  </div>

  <%# ── 1. Dropdown ─────────────────────────────────────────── %>
  <section class="bg-white border border-gray-200 rounded-lg p-6">
    <header class="mb-4">
      <h2 class="text-lg font-semibold text-talent-navy">1 · Dropdown</h2>
      <p class="text-sm text-gray-500">Click the button — a menu should appear positioned below.</p>
    </header>

    <button id="testpage-dropdown-trigger"
            data-dropdown-toggle="testpage-dropdown"
            data-dropdown-placement="bottom-start"
            class="inline-flex items-center gap-2 rounded-lg bg-talent-orange px-4 py-2 text-sm font-medium text-white hover:bg-talent-orange-600 cursor-pointer transition" type="button">
      Open dropdown
      <svg class="h-3 w-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="6 9 12 15 18 9"/></svg>
    </button>

    <div id="testpage-dropdown"
         class="z-50 hidden w-48 rounded-lg bg-white border border-gray-200 shadow-lg overflow-hidden">
      <ul class="py-1 text-sm text-talent-navy">
        <li><a href="#" class="block px-4 py-2 hover:bg-gray-50 transition">Settings</a></li>
        <li><a href="#" class="block px-4 py-2 hover:bg-gray-50 transition">Earnings</a></li>
        <li><a href="#" class="block px-4 py-2 hover:bg-gray-50 transition">Sign out</a></li>
      </ul>
    </div>
  </section>

  <%# ── 2. Modal ────────────────────────────────────────────── %>
  <section class="bg-white border border-gray-200 rounded-lg p-6">
    <header class="mb-4">
      <h2 class="text-lg font-semibold text-talent-navy">2 · Modal</h2>
      <p class="text-sm text-gray-500">Click the button — a centred modal with backdrop should overlay the page.</p>
    </header>

    <button data-modal-target="testpage-modal" data-modal-toggle="testpage-modal"
            class="inline-flex items-center gap-2 rounded-lg border border-gray-200 bg-white px-4 py-2 text-sm font-medium text-talent-navy hover:bg-gray-50 cursor-pointer transition" type="button">
      Open modal
    </button>

    <div id="testpage-modal" tabindex="-1" aria-hidden="true"
         class="hidden overflow-y-auto overflow-x-hidden fixed top-0 right-0 left-0 z-50 justify-center items-center w-full md:inset-0 h-[calc(100%-1rem)] max-h-full">
      <div class="relative p-4 w-full max-w-md max-h-full">
        <div class="relative bg-white rounded-lg shadow-lg border border-gray-200">
          <div class="flex items-center justify-between p-4 border-b border-gray-200">
            <h3 class="text-lg font-semibold text-talent-navy">Confirm action</h3>
            <button type="button" data-modal-hide="testpage-modal"
                    class="text-gray-400 bg-transparent hover:bg-gray-100 hover:text-talent-navy rounded-lg text-sm w-8 h-8 ms-auto inline-flex justify-center items-center cursor-pointer transition" aria-label="Close">
              <svg class="w-3 h-3" viewBox="0 0 14 14" fill="none"><path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 1 6 6m0 0 6 6M7 7l6-6M7 7l-6 6"/></svg>
            </button>
          </div>
          <div class="p-5 space-y-3 text-sm text-gray-600">
            <p>This is a Flowbite modal rendered from a Rails partial. It can be closed by the X button, the backdrop, or pressing <kbd class="px-1.5 py-0.5 rounded bg-gray-100 text-xs font-mono">Esc</kbd>.</p>
            <p>If you can see and dismiss this, modal initialisation works.</p>
          </div>
          <div class="flex items-center justify-end gap-2 p-4 border-t border-gray-200">
            <button type="button" data-modal-hide="testpage-modal"
                    class="rounded-lg border border-gray-200 bg-white px-4 py-2 text-sm font-medium text-talent-navy hover:bg-gray-50 cursor-pointer transition">Cancel</button>
            <button type="button" data-modal-hide="testpage-modal"
                    class="rounded-lg bg-talent-orange px-4 py-2 text-sm font-medium text-white hover:bg-talent-orange-600 cursor-pointer transition">Confirm</button>
          </div>
        </div>
      </div>
    </div>
  </section>

  <%# ── 3. Drawer ───────────────────────────────────────────── %>
  <section class="bg-white border border-gray-200 rounded-lg p-6">
    <header class="mb-4">
      <h2 class="text-lg font-semibold text-talent-navy">3 · Drawer</h2>
      <p class="text-sm text-gray-500">Click the button — a side drawer should slide in from the right.</p>
    </header>

    <button data-drawer-target="testpage-drawer" data-drawer-show="testpage-drawer"
            data-drawer-placement="right" aria-controls="testpage-drawer"
            class="inline-flex items-center gap-2 rounded-lg border border-gray-200 bg-white px-4 py-2 text-sm font-medium text-talent-navy hover:bg-gray-50 cursor-pointer transition" type="button">
      Open drawer
    </button>

    <div id="testpage-drawer" tabindex="-1" aria-labelledby="testpage-drawer-label"
         class="fixed top-0 right-0 z-50 h-screen p-5 overflow-y-auto bg-white w-80 border-l border-gray-200 transition-transform translate-x-full">
      <h5 id="testpage-drawer-label" class="inline-flex items-center text-base font-semibold text-talent-navy">Right drawer</h5>
      <button type="button" data-drawer-hide="testpage-drawer" aria-controls="testpage-drawer"
              class="text-gray-400 bg-transparent hover:bg-gray-100 hover:text-talent-navy rounded-lg text-sm w-8 h-8 absolute top-3 end-3 inline-flex items-center justify-center cursor-pointer transition" aria-label="Close menu">
        <svg class="w-3 h-3" viewBox="0 0 14 14" fill="none"><path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 1 6 6m0 0 6 6M7 7l6-6M7 7l-6 6"/></svg>
      </button>
      <p class="mt-4 text-sm text-gray-600">If you can see this drawer slide in and dismiss it, drawer init works.</p>
    </div>
  </section>

  <%# ── 4. Accordion ────────────────────────────────────────── %>
  <section class="bg-white border border-gray-200 rounded-lg p-6">
    <header class="mb-4">
      <h2 class="text-lg font-semibold text-talent-navy">4 · Accordion</h2>
      <p class="text-sm text-gray-500">Click a row — the body expands; clicking another collapses this one.</p>
    </header>

    <div id="testpage-accordion" data-accordion="collapse" class="rounded-lg border border-gray-200 overflow-hidden">
      <h3 id="acc-heading-1">
        <button type="button"
                class="flex items-center justify-between w-full px-4 py-3 font-medium text-left text-talent-navy bg-white hover:bg-gray-50 cursor-pointer transition"
                data-accordion-target="#acc-body-1" aria-expanded="true" aria-controls="acc-body-1">
          <span>What is SnagRadar?</span>
          <svg data-accordion-icon class="w-3 h-3 rotate-180 shrink-0" viewBox="0 0 10 6" fill="none"><path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5 5 1 1 5"/></svg>
        </button>
      </h3>
      <div id="acc-body-1" class="hidden" aria-labelledby="acc-heading-1">
        <div class="px-4 py-3 border-t border-gray-200 text-sm text-gray-600">A construction defects / customer-care platform.</div>
      </div>

      <h3 id="acc-heading-2">
        <button type="button"
                class="flex items-center justify-between w-full px-4 py-3 font-medium text-left text-talent-navy bg-white hover:bg-gray-50 border-t border-gray-200 cursor-pointer transition"
                data-accordion-target="#acc-body-2" aria-expanded="false" aria-controls="acc-body-2">
          <span>Is the dropdown above working?</span>
          <svg data-accordion-icon class="w-3 h-3 shrink-0" viewBox="0 0 10 6" fill="none"><path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5 5 1 1 5"/></svg>
        </button>
      </h3>
      <div id="acc-body-2" class="hidden" aria-labelledby="acc-heading-2">
        <div class="px-4 py-3 border-t border-gray-200 text-sm text-gray-600">If yes, then Flowbite is wired up correctly.</div>
      </div>
    </div>
  </section>

  <%# ── 5. Tabs ─────────────────────────────────────────────── %>
  <section class="bg-white border border-gray-200 rounded-lg p-6">
    <header class="mb-4">
      <h2 class="text-lg font-semibold text-talent-navy">5 · Tabs</h2>
      <p class="text-sm text-gray-500">Switching tabs swaps the panel below.</p>
    </header>

    <div class="border-b border-gray-200">
      <ul class="flex flex-wrap -mb-px text-sm font-medium" id="testpage-tabs" data-tabs-toggle="#testpage-tab-content" role="tablist">
        <li class="me-2" role="presentation">
          <button class="inline-block p-3 border-b-2 rounded-t-lg cursor-pointer" id="profile-tab" data-tabs-target="#profile" type="button" role="tab" aria-controls="profile" aria-selected="false">Profile</button>
        </li>
        <li class="me-2" role="presentation">
          <button class="inline-block p-3 border-b-2 rounded-t-lg cursor-pointer" id="dashboard-tab" data-tabs-target="#dashboard-panel" type="button" role="tab" aria-controls="dashboard-panel" aria-selected="false">Dashboard</button>
        </li>
        <li class="me-2" role="presentation">
          <button class="inline-block p-3 border-b-2 rounded-t-lg cursor-pointer" id="settings-tab" data-tabs-target="#settings-panel" type="button" role="tab" aria-controls="settings-panel" aria-selected="false">Settings</button>
        </li>
      </ul>
    </div>
    <div id="testpage-tab-content" class="pt-4">
      <div class="hidden text-sm text-gray-600" id="profile" role="tabpanel" aria-labelledby="profile-tab">Profile content goes here.</div>
      <div class="hidden text-sm text-gray-600" id="dashboard-panel" role="tabpanel" aria-labelledby="dashboard-tab">Dashboard content goes here.</div>
      <div class="hidden text-sm text-gray-600" id="settings-panel" role="tabpanel" aria-labelledby="settings-tab">Settings content goes here.</div>
    </div>
  </section>

  <%# ── 6. Tooltip ──────────────────────────────────────────── %>
  <section class="bg-white border border-gray-200 rounded-lg p-6">
    <header class="mb-4">
      <h2 class="text-lg font-semibold text-talent-navy">6 · Tooltip</h2>
      <p class="text-sm text-gray-500">Hover the button — a tooltip should float above it.</p>
    </header>
    <button data-tooltip-target="testpage-tooltip" data-tooltip-placement="top" type="button"
            class="inline-flex items-center gap-2 rounded-lg border border-gray-200 bg-white px-4 py-2 text-sm font-medium text-talent-navy hover:bg-gray-50 cursor-pointer transition">
      Hover me
    </button>
    <div id="testpage-tooltip" role="tooltip"
         class="absolute z-10 invisible inline-block px-3 py-2 text-xs font-medium text-white transition-opacity duration-300 bg-talent-navy rounded-lg shadow-sm opacity-0 tooltip">
      Floating Flowbite tooltip
      <div class="tooltip-arrow" data-popper-arrow></div>
    </div>
  </section>

  <%# ── 7. Form — every Flowbite field type ────────────────── %>
  <section class="bg-white border border-gray-200 rounded-lg p-6">
    <header class="mb-6">
      <h2 class="text-lg font-semibold text-talent-navy">7 · Form fields</h2>
      <p class="text-sm text-gray-500">All Flowbite-styled input types in one place — confirms the theme is consistent.</p>
    </header>

    <form class="grid sm:grid-cols-2 gap-5">

      <%# Text + helper text %>
      <div>
        <label for="tp-name" class="block mb-1 text-xs font-medium text-gray-700 uppercase tracking-wide">Full name</label>
        <input type="text" id="tp-name" placeholder="Sara Jenkins"
               class="block w-full rounded-lg border border-gray-200 bg-white px-3 py-2 text-sm focus:outline-none focus:border-talent-orange focus:ring-2 focus:ring-talent-orange/20">
        <p class="mt-1 text-xs text-gray-500">As it should appear on contracts.</p>
      </div>

      <%# Email with leading icon %>
      <div>
        <label for="tp-email" class="block mb-1 text-xs font-medium text-gray-700 uppercase tracking-wide">Email</label>
        <div class="relative">
          <span class="absolute inset-y-0 left-0 pl-3 flex items-center text-gray-400 pointer-events-none">
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          </span>
          <input type="email" id="tp-email" placeholder="you@example.com"
                 class="block w-full rounded-lg border border-gray-200 bg-white pl-10 pr-3 py-2 text-sm focus:outline-none focus:border-talent-orange focus:ring-2 focus:ring-talent-orange/20">
        </div>
      </div>

      <%# Password with real show/hide eye toggle (password_visibility_controller) %>
      <div data-controller="password-visibility">
        <label for="tp-password" class="block mb-1 text-xs font-medium text-gray-700 uppercase tracking-wide">Password</label>
        <div class="relative">
          <input data-password-visibility-target="input"
                 type="password" id="tp-password" placeholder="••••••••" autocomplete="new-password"
                 class="block w-full rounded-lg border border-gray-200 bg-white pl-3 pr-10 py-2 text-sm focus:outline-none focus:border-talent-orange focus:ring-2 focus:ring-talent-orange/20">
          <button type="button" data-action="password-visibility#toggle"
                  class="absolute inset-y-0 right-2 flex items-center text-gray-400 hover:text-talent-navy cursor-pointer" aria-label="Toggle password visibility">
            <svg data-password-visibility-target="iconShow" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
            <svg data-password-visibility-target="iconHide" class="hidden h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17.94 17.94A10.06 10.06 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/><line x1="1" y1="1" x2="23" y2="23"/></svg>
          </button>
        </div>
        <p class="mt-1 text-xs text-gray-500">At least 8 characters, mix of letters &amp; numbers.</p>
      </div>

      <%# Search with leading icon + suffix kbd %>
      <div>
        <label for="tp-search" class="block mb-1 text-xs font-medium text-gray-700 uppercase tracking-wide">Search</label>
        <div class="relative">
          <span class="absolute inset-y-0 left-0 pl-3 flex items-center text-gray-400 pointer-events-none">
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
          </span>
          <input type="search" id="tp-search" placeholder="Search…"
                 class="block w-full rounded-lg border border-gray-200 bg-white pl-10 pr-12 py-2 text-sm focus:outline-none focus:border-talent-orange focus:ring-2 focus:ring-talent-orange/20">
          <kbd class="absolute inset-y-0 right-2 my-auto h-5 px-1.5 inline-flex items-center rounded border border-gray-200 bg-gray-50 text-[10px] font-mono text-gray-500">⌘K</kbd>
        </div>
      </div>

      <%# Select %>
      <div>
        <label for="tp-trade" class="block mb-1 text-xs font-medium text-gray-700 uppercase tracking-wide">Trade</label>
        <select id="tp-trade"
                class="block w-full rounded-lg border border-gray-200 bg-white px-3 py-2 text-sm focus:outline-none focus:border-talent-orange focus:ring-2 focus:ring-talent-orange/20">
          <option>Plumbing</option><option>Electrical</option><option>Carpentry</option><option>Decoration</option>
        </select>
      </div>

      <%# Number %>
      <div>
        <label for="tp-priority" class="block mb-1 text-xs font-medium text-gray-700 uppercase tracking-wide">SLA days</label>
        <input type="number" id="tp-priority" min="1" max="30" value="7"
               class="block w-full rounded-lg border border-gray-200 bg-white px-3 py-2 text-sm focus:outline-none focus:border-talent-orange focus:ring-2 focus:ring-talent-orange/20">
      </div>

      <%# Date + Time pair (uses Flowbite datepicker if needed; native here is enough) %>
      <div>
        <label for="tp-date" class="block mb-1 text-xs font-medium text-gray-700 uppercase tracking-wide">Visit date</label>
        <input type="date" id="tp-date"
               class="block w-full rounded-lg border border-gray-200 bg-white px-3 py-2 text-sm focus:outline-none focus:border-talent-orange focus:ring-2 focus:ring-talent-orange/20">
      </div>
      <div>
        <label for="tp-time" class="block mb-1 text-xs font-medium text-gray-700 uppercase tracking-wide">Visit time</label>
        <input type="time" id="tp-time"
               class="block w-full rounded-lg border border-gray-200 bg-white px-3 py-2 text-sm focus:outline-none focus:border-talent-orange focus:ring-2 focus:ring-talent-orange/20">
      </div>

      <%# Textarea %>
      <div class="sm:col-span-2">
        <label for="tp-notes" class="block mb-1 text-xs font-medium text-gray-700 uppercase tracking-wide">Notes</label>
        <textarea id="tp-notes" rows="3" placeholder="Anything the contractor should know on site…"
                  class="block w-full rounded-lg border border-gray-200 bg-white px-3 py-2 text-sm focus:outline-none focus:border-talent-orange focus:ring-2 focus:ring-talent-orange/20 resize-none"></textarea>
        <p class="mt-1 text-xs text-gray-500"><span id="tp-notes-count">0</span> / 500 characters</p>
      </div>

      <%# File upload — Flowbite dropzone pattern (drag-and-drop or click) %>
      <div class="sm:col-span-2">
        <label class="block mb-1 text-xs font-medium text-gray-700 uppercase tracking-wide">Photos</label>
        <label for="tp-photos" class="flex flex-col items-center justify-center w-full h-32 rounded-lg border-2 border-gray-200 border-dashed cursor-pointer bg-gray-50 hover:bg-gray-100 hover:border-talent-orange/40 transition">
          <div class="flex flex-col items-center justify-center pt-5 pb-6 text-center">
            <svg class="mb-2 h-6 w-6 text-gray-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
            <p class="text-sm text-gray-600"><span class="font-medium text-talent-navy">Click to upload</span> or drag and drop</p>
            <p class="mt-0.5 text-xs text-gray-500">PNG, JPG up to 10 MB</p>
          </div>
          <input type="file" id="tp-photos" multiple accept="image/*" class="hidden">
        </label>
      </div>

      <%# Range %>
      <div class="sm:col-span-2">
        <label for="tp-range" class="block mb-1 text-xs font-medium text-gray-700 uppercase tracking-wide">Severity</label>
        <input type="range" id="tp-range" min="0" max="10" value="3"
               class="w-full h-2 bg-gray-100 rounded-lg appearance-none cursor-pointer accent-talent-orange">
        <div class="mt-1 flex justify-between text-[10px] text-gray-400 uppercase tracking-widest">
          <span>Low</span><span>Medium</span><span>Urgent</span>
        </div>
      </div>

      <%# Radio group (priority) %>
      <fieldset class="sm:col-span-2">
        <legend class="block mb-2 text-xs font-medium text-gray-700 uppercase tracking-wide">Priority</legend>
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-2">
          <% [["low", "emerald"], ["medium", "amber"], ["high", "rose"], ["urgent", "talent-navy"]].each_with_index do |(level, tone), i| %>
            <label class="flex items-center gap-2 rounded-lg border border-gray-200 px-3 py-2 text-sm cursor-pointer hover:bg-gray-50 transition has-[input:checked]:border-talent-orange has-[input:checked]:bg-talent-orange-50">
              <input type="radio" name="tp-priority-group" value="<%= level %>" <%= "checked" if i.zero? %>
                     class="h-4 w-4 border-gray-300 text-talent-orange focus:ring-talent-orange">
              <span class="capitalize text-talent-navy"><%= level %></span>
            </label>
          <% end %>
        </div>
      </fieldset>

      <%# Checkbox group %>
      <fieldset class="sm:col-span-2">
        <legend class="block mb-2 text-xs font-medium text-gray-700 uppercase tracking-wide">Notify</legend>
        <div class="space-y-2 text-sm text-talent-navy">
          <% ["Contractor", "Resident", "Site manager"].each_with_index do |who, i| %>
            <label class="flex items-center gap-2 cursor-pointer">
              <input type="checkbox" <%= "checked" if i < 2 %>
                     class="h-4 w-4 rounded border-gray-300 text-talent-orange focus:ring-talent-orange">
              <%= who %>
            </label>
          <% end %>
        </div>
      </fieldset>

      <%# Toggle switch (Flowbite pattern) %>
      <div class="sm:col-span-2">
        <label class="inline-flex items-center cursor-pointer">
          <input type="checkbox" value="" class="sr-only peer" checked>
          <div class="relative w-10 h-5 bg-gray-200 peer-focus:outline-none peer-focus:ring-2 peer-focus:ring-talent-orange/40 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-0.5 after:start-[2px] after:bg-white after:border after:border-gray-300 after:rounded-full after:h-4 after:w-4 after:transition-all peer-checked:bg-talent-orange"></div>
          <span class="ms-3 text-sm text-talent-navy">Send SMS reminders</span>
        </label>
      </div>

      <%# Inline alert / helper card %>
      <div class="sm:col-span-2 flex items-start gap-3 rounded-lg bg-talent-orange-50 border border-talent-orange-100 p-3 text-sm">
        <svg class="h-4 w-4 mt-0.5 text-talent-orange-700 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
        <div class="text-talent-navy">SLA target will be auto-calculated from the selected trade.</div>
      </div>

      <%# Error-state input example %>
      <div class="sm:col-span-2">
        <label for="tp-bad" class="block mb-1 text-xs font-medium text-rose-700 uppercase tracking-wide">Reference (error example)</label>
        <input type="text" id="tp-bad" value="ABC-12" aria-invalid="true"
               class="block w-full rounded-lg border border-rose-300 bg-rose-50 px-3 py-2 text-sm text-rose-900 placeholder-rose-300 focus:outline-none focus:border-rose-500 focus:ring-2 focus:ring-rose-500/30">
        <p class="mt-1 text-xs text-rose-600 flex items-center gap-1">
          <svg class="h-3 w-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
          Reference must be 6 characters or more.
        </p>
      </div>

      <div class="sm:col-span-2 flex justify-end gap-2 pt-2 border-t border-gray-100">
        <button type="reset" class="inline-flex items-center gap-2 rounded-lg border border-gray-200 bg-white px-4 py-2 text-sm font-medium text-talent-navy hover:bg-gray-50 cursor-pointer transition">Reset</button>
        <button type="submit" class="inline-flex items-center gap-2 rounded-lg bg-talent-orange px-4 py-2 text-sm font-medium text-white hover:bg-talent-orange-600 cursor-pointer transition">Save</button>
      </div>
    </form>
  </section>

  <%# ── 8. Charts (ApexCharts via Flowbite chart pattern) ──── %>
  <% chart_brand   = "#FC5A07" %>
  <% chart_navy    = "#022043" %>
  <% chart_blue    = "#0057AE" %>
  <% chart_emerald = "#10B981" %>
  <% chart_amber   = "#F59E0B" %>
  <% chart_rose    = "#F43F5E" %>

  <section class="bg-white border border-gray-200 rounded-lg p-6">
    <header class="mb-6">
      <h2 class="text-lg font-semibold text-talent-navy">8 · Charts</h2>
      <p class="text-sm text-gray-500">Flowbite chart components are ApexCharts under the hood. Rendered via a Stimulus controller (data-controller="chart") so they tear down cleanly on Turbo navigation.</p>
    </header>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">

      <%# ─── Area chart ──────────────────────────────────────── %>
      <% area_opts = {
        chart: { type: "area", height: 280, fontFamily: "Sofia Sans, ui-sans-serif", toolbar: { show: false }, zoom: { enabled: false } },
        colors: [chart_brand, chart_blue],
        series: [
          { name: "Defects logged",   data: [12, 18, 14, 22, 28, 24, 31] },
          { name: "Defects resolved", data: [8,  14, 11, 19, 21, 23, 27] }
        ],
        xaxis: { categories: %w[Mon Tue Wed Thu Fri Sat Sun], axisBorder: { show: false }, axisTicks: { show: false }, labels: { style: { colors: "#64748B", fontSize: "11px" } } },
        yaxis: { labels: { style: { colors: "#64748B", fontSize: "11px" } } },
        stroke: { curve: "smooth", width: 2 },
        fill:   { type: "gradient", gradient: { shadeIntensity: 1, opacityFrom: 0.4, opacityTo: 0.05, stops: [0, 100] } },
        dataLabels: { enabled: false },
        grid: { borderColor: "#E2E8F0", strokeDashArray: 4, padding: { left: 8, right: 8 } },
        legend: { position: "top", horizontalAlign: "right", fontSize: "12px", labels: { colors: "#334155" }, markers: { width: 8, height: 8, radius: 4 } },
        tooltip: { theme: "light" }
      } %>
      <div class="bg-white border border-gray-200 rounded-lg p-5">
        <div class="flex items-start justify-between">
          <div>
            <h3 class="text-sm font-medium text-gray-500 uppercase tracking-wide">Activity this week</h3>
            <div class="mt-2 flex items-baseline gap-2">
              <span class="text-3xl font-semibold text-talent-navy">149</span>
              <span class="inline-flex items-center gap-1 text-xs font-medium text-emerald-700">
                <svg class="h-3 w-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="18 15 12 9 6 15"/></svg>
                12.4%
              </span>
            </div>
          </div>
          <button data-dropdown-toggle="chart-area-menu" data-dropdown-placement="bottom-end"
                  class="h-8 w-8 rounded-lg grid place-items-center hover:bg-gray-100 text-gray-500 cursor-pointer" type="button" aria-label="Options">
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor"><circle cx="5" cy="12" r="1.5"/><circle cx="12" cy="12" r="1.5"/><circle cx="19" cy="12" r="1.5"/></svg>
          </button>
          <div id="chart-area-menu" class="z-50 hidden w-40 bg-white rounded-lg border border-gray-200 shadow-lg overflow-hidden">
            <ul class="py-1 text-sm">
              <li><a class="block px-4 py-2 text-talent-navy hover:bg-gray-50" href="#">Last 7 days</a></li>
              <li><a class="block px-4 py-2 text-talent-navy hover:bg-gray-50" href="#">Last 30 days</a></li>
              <li><a class="block px-4 py-2 text-talent-navy hover:bg-gray-50" href="#">Export CSV</a></li>
            </ul>
          </div>
        </div>
        <div class="mt-4" data-controller="chart" data-chart-options-value="<%= area_opts.to_json %>"></div>
      </div>

      <%# ─── Column chart ────────────────────────────────────── %>
      <% column_opts = {
        chart: { type: "bar", height: 280, fontFamily: "Sofia Sans, ui-sans-serif", toolbar: { show: false } },
        colors: [chart_brand],
        series: [{ name: "Defects logged", data: [22, 29, 18, 34, 41, 28, 31] }],
        xaxis: { categories: %w[Mon Tue Wed Thu Fri Sat Sun], axisBorder: { show: false }, axisTicks: { show: false }, labels: { style: { colors: "#64748B", fontSize: "11px" } } },
        yaxis: { labels: { style: { colors: "#64748B", fontSize: "11px" } } },
        plotOptions: { bar: { borderRadius: 6, borderRadiusApplication: "end", columnWidth: "55%" } },
        dataLabels: { enabled: false },
        grid: { borderColor: "#E2E8F0", strokeDashArray: 4, padding: { left: 8, right: 8 } },
        legend: { show: false },
        tooltip: { theme: "light" }
      } %>
      <div class="bg-white border border-gray-200 rounded-lg p-5">
        <div class="flex items-start justify-between">
          <div>
            <h3 class="text-sm font-medium text-gray-500 uppercase tracking-wide">Defects logged per day</h3>
            <div class="mt-2 flex items-baseline gap-2">
              <span class="text-3xl font-semibold text-talent-navy">203</span>
              <span class="text-xs text-gray-500">last 7 days</span>
            </div>
          </div>
        </div>
        <div class="mt-4" data-controller="chart" data-chart-options-value="<%= column_opts.to_json %>"></div>
      </div>

      <%# ─── Horizontal bar — defects by trade ──────────────── %>
      <% bar_opts = {
        chart: { type: "bar", height: 320, fontFamily: "Sofia Sans, ui-sans-serif", toolbar: { show: false } },
        colors: [chart_navy],
        series: [{ name: "Open", data: [38, 24, 22, 17, 14, 11, 9, 6] }],
        xaxis: { categories: ["Plumbing", "Electrical", "Carpentry", "Decoration", "Plastering", "Tiling", "Roofing", "Glazing"], axisBorder: { show: false }, axisTicks: { show: false }, labels: { style: { colors: "#64748B", fontSize: "11px" } } },
        yaxis: { labels: { style: { colors: "#334155", fontSize: "12px" } } },
        plotOptions: { bar: { horizontal: true, borderRadius: 6, borderRadiusApplication: "end", barHeight: "65%" } },
        dataLabels: { enabled: false },
        grid: { borderColor: "#E2E8F0", strokeDashArray: 4 },
        legend: { show: false }
      } %>
      <div class="bg-white border border-gray-200 rounded-lg p-5">
        <div class="flex items-start justify-between mb-2">
          <h3 class="text-sm font-medium text-gray-500 uppercase tracking-wide">Open defects by trade</h3>
          <span class="inline-flex items-center justify-center rounded-full bg-gray-100 text-gray-600 px-2 py-0.5 text-xs font-medium">141 total</span>
        </div>
        <div data-controller="chart" data-chart-options-value="<%= bar_opts.to_json %>"></div>
      </div>

      <%# ─── Donut — status breakdown ────────────────────────── %>
      <% donut_opts = {
        chart: { type: "donut", height: 320, fontFamily: "Sofia Sans, ui-sans-serif" },
        series: [42, 28, 16, 11, 3],
        labels: ["Logged", "In progress", "Completed", "Signed off", "Rejected"],
        colors: [chart_blue, chart_amber, chart_emerald, chart_brand, chart_rose],
        stroke: { width: 0 },
        dataLabels: { enabled: false },
        legend: { position: "bottom", fontSize: "12px", labels: { colors: "#334155" }, markers: { width: 8, height: 8, radius: 4 } },
        plotOptions: {
          pie: {
            donut: {
              size: "68%",
              labels: {
                show: true,
                name:  { show: true, fontSize: "12px", color: "#64748B", offsetY: -8 },
                value: { show: true, fontSize: "28px", color: "#022043", fontWeight: 600, offsetY: 4 },
                total: { show: true, label: "Total", color: "#64748B", fontSize: "12px" }
              }
            }
          }
        }
      } %>
      <div class="bg-white border border-gray-200 rounded-lg p-5">
        <div class="flex items-start justify-between mb-2">
          <h3 class="text-sm font-medium text-gray-500 uppercase tracking-wide">Status breakdown</h3>
          <button data-dropdown-toggle="chart-donut-menu" data-dropdown-placement="bottom-end"
                  class="h-8 w-8 rounded-lg grid place-items-center hover:bg-gray-100 text-gray-500 cursor-pointer" type="button" aria-label="Options">
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor"><circle cx="5" cy="12" r="1.5"/><circle cx="12" cy="12" r="1.5"/><circle cx="19" cy="12" r="1.5"/></svg>
          </button>
          <div id="chart-donut-menu" class="z-50 hidden w-40 bg-white rounded-lg border border-gray-200 shadow-lg overflow-hidden">
            <ul class="py-1 text-sm">
              <li><a class="block px-4 py-2 text-talent-navy hover:bg-gray-50" href="#">All sites</a></li>
              <li><a class="block px-4 py-2 text-talent-navy hover:bg-gray-50" href="#">Only mine</a></li>
            </ul>
          </div>
        </div>
        <div data-controller="chart" data-chart-options-value="<%= donut_opts.to_json %>"></div>
      </div>

      <%# ─── Radial — SLA compliance ─────────────────────────── %>
      <% radial_opts = {
        chart: { type: "radialBar", height: 320, fontFamily: "Sofia Sans, ui-sans-serif", sparkline: { enabled: false } },
        series: [86],
        labels: ["Compliance"],
        colors: [chart_emerald],
        plotOptions: {
          radialBar: {
            hollow: { size: "60%" },
            track:  { background: "#F1F5F9", strokeWidth: "100%" },
            dataLabels: {
              name:  { fontSize: "12px", color: "#64748B", offsetY: -10 },
              value: { fontSize: "32px", color: "#022043", fontWeight: 600, offsetY: 4 }
            }
          }
        },
        stroke: { lineCap: "round" }
      } %>
      <div class="bg-white border border-gray-200 rounded-lg p-5">
        <div class="flex items-start justify-between mb-2">
          <h3 class="text-sm font-medium text-gray-500 uppercase tracking-wide">SLA compliance</h3>
          <span class="inline-flex items-center gap-1 rounded-full bg-emerald-50 text-emerald-700 px-2 py-0.5 text-xs font-medium">
            <svg class="h-3 w-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="20 6 9 17 4 12"/></svg>
            On target
          </span>
        </div>
        <div data-controller="chart" data-chart-options-value="<%= radial_opts.to_json %>"></div>
      </div>

      <%# ─── Line + multiple series ──────────────────────────── %>
      <% line_opts = {
        chart: { type: "line", height: 320, fontFamily: "Sofia Sans, ui-sans-serif", toolbar: { show: false } },
        colors: [chart_brand, chart_navy, chart_blue],
        series: [
          { name: "Q1", data: [44, 55, 41, 67, 22, 43, 21, 49, 56, 41, 67, 47] },
          { name: "Q2", data: [13, 23, 20, 8, 13, 27, 41, 33, 18, 26, 14, 29] },
          { name: "Q3", data: [11, 17, 15, 15, 21, 14, 19, 22, 27, 19, 31, 21] }
        ],
        xaxis: { categories: %w[Jan Feb Mar Apr May Jun Jul Aug Sep Oct Nov Dec], axisBorder: { show: false }, axisTicks: { show: false }, labels: { style: { colors: "#64748B", fontSize: "11px" } } },
        yaxis: { labels: { style: { colors: "#64748B", fontSize: "11px" } } },
        stroke: { curve: "smooth", width: 2 },
        markers: { size: 0, hover: { size: 5 } },
        dataLabels: { enabled: false },
        grid: { borderColor: "#E2E8F0", strokeDashArray: 4 },
        legend: { position: "top", horizontalAlign: "right", fontSize: "12px", labels: { colors: "#334155" }, markers: { width: 8, height: 8, radius: 4 } }
      } %>
      <div class="bg-white border border-gray-200 rounded-lg p-5 lg:col-span-2">
        <div class="flex items-start justify-between mb-2">
          <div>
            <h3 class="text-sm font-medium text-gray-500 uppercase tracking-wide">Defects trend by quarter</h3>
            <div class="mt-2 flex items-baseline gap-2">
              <span class="text-3xl font-semibold text-talent-navy">1,284</span>
              <span class="text-xs text-gray-500">total this year</span>
            </div>
          </div>
          <div class="hidden sm:flex items-center gap-1 text-xs">
            <button class="px-2.5 py-1 rounded-md text-talent-navy bg-gray-100 font-medium cursor-pointer">Year</button>
            <button class="px-2.5 py-1 rounded-md text-gray-500 hover:bg-gray-50 cursor-pointer">Quarter</button>
            <button class="px-2.5 py-1 rounded-md text-gray-500 hover:bg-gray-50 cursor-pointer">Month</button>
          </div>
        </div>
        <div class="mt-4" data-controller="chart" data-chart-options-value="<%= line_opts.to_json %>"></div>
      </div>

      <%# ─── Sparkline KPI cards ─────────────────────────────── %>
      <% [
        { label: "Defects logged",   value: "203", change: "+12%",  tone: "emerald", series: [12,18,14,22,28,24,31], color: chart_emerald },
        { label: "Avg resolution",   value: "2.4d", change: "−8%",  tone: "emerald", series: [3.2,3.1,2.9,2.8,2.7,2.5,2.4], color: chart_brand },
        { label: "Overdue",          value: "14",   change: "+3",   tone: "rose",    series: [9,10,11,11,12,13,14], color: chart_rose },
        { label: "Sign-off rate",    value: "91%",  change: "+1.2", tone: "emerald", series: [86,87,88,89,89,90,91], color: chart_blue }
      ].each_with_index do |card, i| %>
        <% spark_opts = {
          chart: { type: "area", height: 60, sparkline: { enabled: true } },
          colors: [card[:color]],
          series: [{ data: card[:series] }],
          stroke: { curve: "smooth", width: 2 },
          fill:   { type: "gradient", gradient: { shadeIntensity: 1, opacityFrom: 0.35, opacityTo: 0.05 } },
          tooltip: { fixed: { enabled: false }, x: { show: false }, marker: { show: false } }
        } %>
        <div class="bg-white border border-gray-200 rounded-lg p-5 <%= 'lg:col-span-1' %>">
          <div class="flex items-start justify-between">
            <div>
              <div class="text-xs font-medium text-gray-500 uppercase tracking-wide"><%= card[:label] %></div>
              <div class="mt-1 flex items-baseline gap-2">
                <span class="text-2xl font-semibold text-talent-navy"><%= card[:value] %></span>
                <span class="text-xs font-medium text-<%= card[:tone] %>-700"><%= card[:change] %></span>
              </div>
            </div>
          </div>
          <div class="mt-2" data-controller="chart" data-chart-options-value="<%= spark_opts.to_json %>"></div>
        </div>
      <% end %>
    </div>
  </section>

  <%# ── 9. Confirmation modal (destructive action) ──────────── %>
  <section class="bg-white border border-gray-200 rounded-lg p-6">
    <header class="mb-4">
      <h2 class="text-lg font-semibold text-talent-navy">9 · Confirmation modal</h2>
      <p class="text-sm text-gray-500">A small centred modal for confirming destructive actions — Flowbite's standard pattern.</p>
    </header>

    <button data-modal-target="tp-confirm-modal" data-modal-toggle="tp-confirm-modal" type="button"
            class="inline-flex items-center gap-2 rounded-lg bg-rose-600 px-4 py-2 text-sm font-medium text-white hover:bg-rose-700 cursor-pointer transition">
      <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-2 14a2 2 0 0 1-2 2H9a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/></svg>
      Delete account
    </button>

    <div id="tp-confirm-modal" tabindex="-1" class="hidden overflow-y-auto overflow-x-hidden fixed top-0 right-0 left-0 z-50 justify-center items-center w-full md:inset-0 h-[calc(100%-1rem)] max-h-full">
      <div class="relative p-4 w-full max-w-md max-h-full">
        <div class="relative bg-white rounded-lg shadow-lg border border-gray-200">
          <button type="button" data-modal-hide="tp-confirm-modal"
                  class="absolute top-3 end-3 text-gray-400 bg-transparent hover:bg-gray-100 hover:text-talent-navy rounded-lg text-sm w-8 h-8 inline-flex justify-center items-center cursor-pointer transition" aria-label="Close">
            <svg class="w-3 h-3" viewBox="0 0 14 14" fill="none"><path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 1 6 6m0 0 6 6M7 7l6-6M7 7l-6 6"/></svg>
          </button>
          <div class="p-6 text-center">
            <div class="mx-auto mb-4 h-12 w-12 rounded-full bg-rose-50 text-rose-600 grid place-items-center">
              <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            </div>
            <h3 class="mb-2 text-lg font-semibold text-talent-navy">Delete this account?</h3>
            <p class="mb-5 text-sm text-gray-500">This will permanently remove the user and all their open defects. This cannot be undone.</p>
            <div class="flex items-center justify-center gap-2">
              <button type="button" data-modal-hide="tp-confirm-modal"
                      class="rounded-lg border border-gray-200 bg-white px-4 py-2 text-sm font-medium text-talent-navy hover:bg-gray-50 cursor-pointer transition">Cancel</button>
              <button type="button" data-modal-hide="tp-confirm-modal"
                      class="rounded-lg bg-rose-600 px-4 py-2 text-sm font-medium text-white hover:bg-rose-700 cursor-pointer transition">Yes, delete</button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <%# ── 10. Form in modal ──────────────────────────────────── %>
  <section class="bg-white border border-gray-200 rounded-lg p-6">
    <header class="mb-4">
      <h2 class="text-lg font-semibold text-talent-navy">10 · Form in modal</h2>
      <p class="text-sm text-gray-500">A larger modal hosting a multi-field form — useful for quick create flows without leaving the page.</p>
    </header>

    <button data-modal-target="tp-form-modal" data-modal-toggle="tp-form-modal" type="button"
            class="inline-flex items-center gap-2 rounded-lg bg-talent-orange px-4 py-2 text-sm font-medium text-white hover:bg-talent-orange-600 cursor-pointer transition">
      <%= icon "plus", class: "h-4 w-4" %>
      Log defect (modal)
    </button>

    <div id="tp-form-modal" tabindex="-1" aria-hidden="true"
         class="hidden overflow-y-auto overflow-x-hidden fixed top-0 right-0 left-0 z-50 justify-center items-center w-full md:inset-0 h-[calc(100%-1rem)] max-h-full">
      <div class="relative p-4 w-full max-w-2xl max-h-full">
        <div class="relative bg-white rounded-lg shadow-lg border border-gray-200">

          <div class="flex items-center justify-between p-5 border-b border-gray-200">
            <div>
              <h3 class="text-lg font-semibold text-talent-navy">Log a new defect</h3>
              <p class="text-xs text-gray-500 mt-0.5">Fill in the essentials — SLA target auto-populates from the trade.</p>
            </div>
            <button type="button" data-modal-hide="tp-form-modal"
                    class="text-gray-400 bg-transparent hover:bg-gray-100 hover:text-talent-navy rounded-lg text-sm w-8 h-8 ms-auto inline-flex justify-center items-center cursor-pointer transition" aria-label="Close">
              <svg class="w-3 h-3" viewBox="0 0 14 14" fill="none"><path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 1 6 6m0 0 6 6M7 7l6-6M7 7l-6 6"/></svg>
            </button>
          </div>

          <form class="p-5 grid sm:grid-cols-2 gap-4">
            <div class="sm:col-span-2">
              <label for="tpm-title" class="block mb-1 text-xs font-medium text-gray-700 uppercase tracking-wide">Title</label>
              <input type="text" id="tpm-title" placeholder="Leaking kitchen tap"
                     class="block w-full rounded-lg border border-gray-200 bg-white px-3 py-2 text-sm focus:outline-none focus:border-talent-orange focus:ring-2 focus:ring-talent-orange/20">
            </div>
            <div>
              <label for="tpm-site" class="block mb-1 text-xs font-medium text-gray-700 uppercase tracking-wide">Site</label>
              <select id="tpm-site" class="block w-full rounded-lg border border-gray-200 bg-white px-3 py-2 text-sm focus:outline-none focus:border-talent-orange focus:ring-2 focus:ring-talent-orange/20">
                <option>Adur Apartments</option><option>Marina Quarter</option><option>Cedar Court</option>
              </select>
            </div>
            <div>
              <label for="tpm-plot" class="block mb-1 text-xs font-medium text-gray-700 uppercase tracking-wide">Plot</label>
              <input type="text" id="tpm-plot" placeholder="Plot 14"
                     class="block w-full rounded-lg border border-gray-200 bg-white px-3 py-2 text-sm focus:outline-none focus:border-talent-orange focus:ring-2 focus:ring-talent-orange/20">
            </div>
            <div>
              <label for="tpm-trade" class="block mb-1 text-xs font-medium text-gray-700 uppercase tracking-wide">Trade</label>
              <select id="tpm-trade" class="block w-full rounded-lg border border-gray-200 bg-white px-3 py-2 text-sm focus:outline-none focus:border-talent-orange focus:ring-2 focus:ring-talent-orange/20">
                <option>Plumbing</option><option>Electrical</option><option>Carpentry</option><option>Decoration</option>
              </select>
            </div>
            <div>
              <label for="tpm-sla" class="block mb-1 text-xs font-medium text-gray-700 uppercase tracking-wide">SLA target</label>
              <input type="date" id="tpm-sla"
                     class="block w-full rounded-lg border border-gray-200 bg-white px-3 py-2 text-sm focus:outline-none focus:border-talent-orange focus:ring-2 focus:ring-talent-orange/20">
            </div>
            <fieldset class="sm:col-span-2">
              <legend class="block mb-2 text-xs font-medium text-gray-700 uppercase tracking-wide">Priority</legend>
              <div class="grid grid-cols-4 gap-2">
                <% %w[low medium high urgent].each_with_index do |level, i| %>
                  <label class="flex items-center justify-center gap-2 rounded-lg border border-gray-200 px-3 py-2 text-sm cursor-pointer hover:bg-gray-50 transition has-[input:checked]:border-talent-orange has-[input:checked]:bg-talent-orange-50">
                    <input type="radio" name="tpm-priority" value="<%= level %>" <%= "checked" if i == 1 %>
                           class="h-4 w-4 border-gray-300 text-talent-orange focus:ring-talent-orange">
                    <span class="capitalize text-talent-navy"><%= level %></span>
                  </label>
                <% end %>
              </div>
            </fieldset>
            <div class="sm:col-span-2">
              <label for="tpm-notes" class="block mb-1 text-xs font-medium text-gray-700 uppercase tracking-wide">Notes</label>
              <textarea id="tpm-notes" rows="3" placeholder="Anything the contractor should know on site…"
                        class="block w-full rounded-lg border border-gray-200 bg-white px-3 py-2 text-sm focus:outline-none focus:border-talent-orange focus:ring-2 focus:ring-talent-orange/20 resize-none"></textarea>
            </div>
            <div class="sm:col-span-2">
              <label class="block mb-1 text-xs font-medium text-gray-700 uppercase tracking-wide">Photos</label>
              <label for="tpm-photos" class="flex flex-col items-center justify-center w-full h-28 rounded-lg border-2 border-gray-200 border-dashed cursor-pointer bg-gray-50 hover:bg-gray-100 hover:border-talent-orange/40 transition">
                <div class="flex flex-col items-center justify-center pt-4 pb-5 text-center">
                  <svg class="mb-1.5 h-5 w-5 text-gray-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
                  <p class="text-sm text-gray-600"><span class="font-medium text-talent-navy">Click to upload</span> or drag and drop</p>
                  <p class="mt-0.5 text-xs text-gray-500">PNG, JPG up to 10 MB</p>
                </div>
                <input type="file" id="tpm-photos" multiple accept="image/*" class="hidden">
              </label>
            </div>
          </form>

          <div class="flex items-center justify-end gap-2 p-4 border-t border-gray-200">
            <button type="button" data-modal-hide="tp-form-modal"
                    class="rounded-lg border border-gray-200 bg-white px-4 py-2 text-sm font-medium text-talent-navy hover:bg-gray-50 cursor-pointer transition">Cancel</button>
            <button type="button" data-modal-hide="tp-form-modal"
                    class="rounded-lg bg-talent-orange px-4 py-2 text-sm font-medium text-white hover:bg-talent-orange-600 cursor-pointer transition">Save defect</button>
          </div>
        </div>
      </div>
    </div>
  </section>

  <%# ── 11. Toasts ──────────────────────────────────────────── %>
  <section class="bg-white border border-gray-200 rounded-lg p-6">
    <header class="mb-5">
      <h2 class="text-lg font-semibold text-talent-navy">11 · Toasts</h2>
      <p class="text-sm text-gray-500">Static inline toasts (one per variant) — each dismisses via Flowbite's <code class="px-1 py-0.5 bg-gray-100 rounded text-xs font-mono">data-dismiss-target</code>. Click any × to confirm dismiss works.</p>
    </header>

    <div class="space-y-3 max-w-md">

      <%# Success %>
      <div id="tp-toast-success" role="alert"
           class="flex items-center w-full p-4 text-talent-navy bg-white rounded-lg border border-gray-200 shadow-sm">
        <div class="inline-flex items-center justify-center flex-shrink-0 w-8 h-8 text-emerald-600 bg-emerald-100 rounded-lg">
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
        </div>
        <div class="ms-3 text-sm font-medium">Defect signed off successfully.</div>
        <button type="button" data-dismiss-target="#tp-toast-success" aria-label="Close"
                class="ms-auto -mx-1.5 -my-1.5 bg-white text-gray-400 hover:text-talent-navy rounded-lg focus:ring-2 focus:ring-gray-200 p-1.5 hover:bg-gray-100 inline-flex items-center justify-center h-8 w-8 cursor-pointer transition">
          <svg class="w-3 h-3" viewBox="0 0 14 14" fill="none"><path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 1 6 6m0 0 6 6M7 7l6-6M7 7l-6 6"/></svg>
        </button>
      </div>

      <%# Info %>
      <div id="tp-toast-info" role="alert"
           class="flex items-center w-full p-4 text-talent-navy bg-white rounded-lg border border-gray-200 shadow-sm">
        <div class="inline-flex items-center justify-center flex-shrink-0 w-8 h-8 text-talent-blue bg-blue-50 rounded-lg">
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
        </div>
        <div class="ms-3 text-sm font-medium">Contractor accepted the job — visit booked for Friday.</div>
        <button type="button" data-dismiss-target="#tp-toast-info" aria-label="Close"
                class="ms-auto -mx-1.5 -my-1.5 bg-white text-gray-400 hover:text-talent-navy rounded-lg focus:ring-2 focus:ring-gray-200 p-1.5 hover:bg-gray-100 inline-flex items-center justify-center h-8 w-8 cursor-pointer transition">
          <svg class="w-3 h-3" viewBox="0 0 14 14" fill="none"><path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 1 6 6m0 0 6 6M7 7l6-6M7 7l-6 6"/></svg>
        </button>
      </div>

      <%# Warning %>
      <div id="tp-toast-warning" role="alert"
           class="flex items-center w-full p-4 text-talent-navy bg-white rounded-lg border border-gray-200 shadow-sm">
        <div class="inline-flex items-center justify-center flex-shrink-0 w-8 h-8 text-amber-600 bg-amber-100 rounded-lg">
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
        </div>
        <div class="ms-3 text-sm font-medium">SLA breach in under 24 hours — review escalations.</div>
        <button type="button" data-dismiss-target="#tp-toast-warning" aria-label="Close"
                class="ms-auto -mx-1.5 -my-1.5 bg-white text-gray-400 hover:text-talent-navy rounded-lg focus:ring-2 focus:ring-gray-200 p-1.5 hover:bg-gray-100 inline-flex items-center justify-center h-8 w-8 cursor-pointer transition">
          <svg class="w-3 h-3" viewBox="0 0 14 14" fill="none"><path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 1 6 6m0 0 6 6M7 7l6-6M7 7l-6 6"/></svg>
        </button>
      </div>

      <%# Danger / error %>
      <div id="tp-toast-danger" role="alert"
           class="flex items-center w-full p-4 text-talent-navy bg-white rounded-lg border border-gray-200 shadow-sm">
        <div class="inline-flex items-center justify-center flex-shrink-0 w-8 h-8 text-rose-600 bg-rose-100 rounded-lg">
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
        </div>
        <div class="ms-3 text-sm font-medium">Sign-off failed — please re-capture the resident signature.</div>
        <button type="button" data-dismiss-target="#tp-toast-danger" aria-label="Close"
                class="ms-auto -mx-1.5 -my-1.5 bg-white text-gray-400 hover:text-talent-navy rounded-lg focus:ring-2 focus:ring-gray-200 p-1.5 hover:bg-gray-100 inline-flex items-center justify-center h-8 w-8 cursor-pointer transition">
          <svg class="w-3 h-3" viewBox="0 0 14 14" fill="none"><path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 1 6 6m0 0 6 6M7 7l6-6M7 7l-6 6"/></svg>
        </button>
      </div>

      <%# Richer toast with avatar + actions %>
      <div id="tp-toast-message" role="alert"
           class="w-full p-4 text-talent-navy bg-white rounded-lg border border-gray-200 shadow-sm">
        <div class="flex items-center mb-3">
          <span class="mb-1 text-xs font-medium text-gray-500 uppercase tracking-wide">Message</span>
          <button type="button" data-dismiss-target="#tp-toast-message" aria-label="Close"
                  class="ms-auto -mx-1.5 -my-1.5 bg-white text-gray-400 hover:text-talent-navy rounded-lg focus:ring-2 focus:ring-gray-200 p-1.5 hover:bg-gray-100 inline-flex items-center justify-center h-7 w-7 cursor-pointer transition">
            <svg class="w-3 h-3" viewBox="0 0 14 14" fill="none"><path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 1 6 6m0 0 6 6M7 7l6-6M7 7l-6 6"/></svg>
          </button>
        </div>
        <div class="flex items-start gap-3">
          <div class="inline-flex items-center justify-center flex-shrink-0 w-9 h-9 rounded-full bg-talent-orange text-white text-sm font-bold">SJ</div>
          <div class="flex-1 min-w-0">
            <div class="text-sm font-semibold">Sara Jenkins</div>
            <div class="text-xs text-gray-500 mt-0.5">"The plumber is on site — should be done in an hour."</div>
            <div class="mt-2 flex gap-2">
              <button class="rounded-md bg-talent-orange px-3 py-1 text-xs font-medium text-white hover:bg-talent-orange-600 cursor-pointer transition">Reply</button>
              <button class="rounded-md border border-gray-200 bg-white px-3 py-1 text-xs font-medium text-talent-navy hover:bg-gray-50 cursor-pointer transition">Dismiss</button>
            </div>
          </div>
        </div>
      </div>
    </div>

    <p class="mt-5 text-xs text-gray-500">Production toasts typically appear fixed in a corner; the same markup works inside <code class="px-1 py-0.5 bg-gray-100 rounded text-xs font-mono">fixed bottom-5 end-5 z-40</code> wrapped via a Turbo Stream from controllers.</p>
  </section>

  <%# ── 12. Calendar (datepicker + month grid) ─────────────── %>
  <section class="bg-white border border-gray-200 rounded-lg p-6">
    <header class="mb-5">
      <h2 class="text-lg font-semibold text-talent-navy">12 · Calendar</h2>
      <p class="text-sm text-gray-500">Flowbite inline datepicker (left) and a month-grid event calendar (right) — same Sofia Sans, same palette.</p>
    </header>

    <div class="grid lg:grid-cols-5 gap-6">

      <%# Flowbite inline datepicker (1/5) %>
      <div class="lg:col-span-2">
        <h3 class="text-xs font-medium text-gray-500 uppercase tracking-wide mb-3">Datepicker</h3>
        <div class="rounded-lg border border-gray-200 p-1 bg-white">
          <div inline-datepicker data-date="<%= Date.current.iso8601 %>"></div>
        </div>

        <div class="mt-4">
          <label for="tp-datepicker-input" class="block mb-1 text-xs font-medium text-gray-700 uppercase tracking-wide">Pick a date</label>
          <div class="relative">
            <span class="absolute inset-y-0 left-0 pl-3 flex items-center text-gray-400 pointer-events-none">
              <%= icon "calendar", class: "h-4 w-4" %>
            </span>
            <input id="tp-datepicker-input" datepicker datepicker-autohide datepicker-format="dd / mm / yyyy" type="text" placeholder="dd / mm / yyyy"
                   class="block w-full rounded-lg border border-gray-200 bg-white pl-10 pr-3 py-2 text-sm focus:outline-none focus:border-talent-orange focus:ring-2 focus:ring-talent-orange/20">
          </div>
        </div>
      </div>

      <%# Month-grid event calendar (4/5) — month controlled by ?testpage_month=YYYY-MM %>
      <%
        anchor         = @calendar_anchor
        today          = Date.current
        first_of_month = anchor.beginning_of_month
        start_offset   = first_of_month.wday                # 0=Sun
        days_in_month  = anchor.end_of_month.day
        prev_month     = (first_of_month - 1.month).strftime("%Y-%m")
        next_month     = (first_of_month + 1.month).strftime("%Y-%m")
        events = {
          first_of_month + 2  => [{ title: "Plumbing snag · Plot 14", tone: "talent-orange" }],
          first_of_month + 4  => [{ title: "Joinery visit · Plot 7",  tone: "talent-blue"   }],
          first_of_month + 9  => [{ title: "Electrical sign-off",     tone: "emerald"        },
                                  { title: "Resident walkthrough",    tone: "talent-orange" }],
          first_of_month + 14 => [{ title: "SLA review · all sites",  tone: "amber"          }],
          first_of_month + 18 => [{ title: "PMC quarterly review",    tone: "talent-blue"    }],
          first_of_month + 22 => [{ title: "Final inspection · Adur", tone: "talent-orange" }]
        }
        events[today] = (events[today] || []) + [{ title: "Daily standup", tone: "talent-navy" }] if today.between?(first_of_month, anchor.end_of_month)
      %>
      <div class="lg:col-span-3" id="testpage-calendar">
        <div class="flex items-center justify-between mb-3">
          <h3 class="text-xs font-medium text-gray-500 uppercase tracking-wide">Month view</h3>
          <div class="flex items-center gap-1.5">
            <%= link_to testpage_path(testpage_month: prev_month, anchor: "testpage-calendar"),
                  class: "h-7 w-7 grid place-items-center rounded-md border border-gray-200 bg-white text-gray-500 hover:bg-gray-50 hover:text-talent-navy cursor-pointer transition",
                  aria: { label: "Previous month" } do %>
              <svg class="h-3 w-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="15 18 9 12 15 6"/></svg>
            <% end %>
            <%= link_to testpage_path(anchor: "testpage-calendar"),
                  class: "text-sm font-semibold text-talent-navy px-2 min-w-[10ch] text-center hover:text-talent-orange transition",
                  title: "Jump to today" do %>
              <%= anchor.strftime("%B %Y") %>
            <% end %>
            <%= link_to testpage_path(testpage_month: next_month, anchor: "testpage-calendar"),
                  class: "h-7 w-7 grid place-items-center rounded-md border border-gray-200 bg-white text-gray-500 hover:bg-gray-50 hover:text-talent-navy cursor-pointer transition",
                  aria: { label: "Next month" } do %>
              <svg class="h-3 w-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="9 18 15 12 9 6"/></svg>
            <% end %>
          </div>
        </div>

        <div class="rounded-lg border border-gray-200 overflow-hidden">
          <%# Weekday header %>
          <div class="grid grid-cols-7 text-[10px] font-semibold uppercase tracking-widest text-gray-500 bg-gray-50 border-b border-gray-200">
            <% %w[Sun Mon Tue Wed Thu Fri Sat].each do |wd| %>
              <div class="px-2 py-2 text-center"><%= wd %></div>
            <% end %>
          </div>

          <%# Day grid %>
          <div class="grid grid-cols-7 grid-rows-[repeat(6,minmax(80px,1fr))] divide-x divide-y divide-gray-100 bg-gray-50">
            <% start_offset.times do %>
              <div class="bg-gray-50/40"></div>
            <% end %>
            <% (1..days_in_month).each do |day| %>
              <% date = first_of_month + (day - 1) %>
              <% is_today = (date == today) %>
              <% day_events = events[date] || [] %>
              <div class="bg-white p-1.5 text-left overflow-hidden">
                <div class="flex items-center justify-between mb-1">
                  <span class="<%= is_today ? 'inline-flex items-center justify-center h-5 w-5 rounded-full bg-talent-orange text-white text-[11px] font-semibold' : 'text-[11px] font-medium text-gray-500' %>"><%= day %></span>
                  <% if day_events.size > 1 %>
                    <span class="text-[9px] text-gray-400 font-mono">+<%= day_events.size %></span>
                  <% end %>
                </div>
                <% day_events.first(2).each do |evt| %>
                  <div class="mb-1 px-1.5 py-0.5 rounded text-[10px] font-medium leading-tight bg-<%= evt[:tone] %>/10 text-<%= evt[:tone] %>-700 truncate">
                    <%= evt[:title] %>
                  </div>
                <% end %>
              </div>
            <% end %>
            <% trailing = (start_offset + days_in_month) % 7 %>
            <% (trailing.zero? ? 0 : 7 - trailing).times do %>
              <div class="bg-gray-50/40"></div>
            <% end %>
          </div>
        </div>

        <%# Legend %>
        <div class="mt-3 flex flex-wrap gap-x-4 gap-y-1.5 text-xs text-gray-500">
          <span class="inline-flex items-center gap-1.5"><span class="h-2 w-2 rounded-sm bg-talent-orange"></span>Defects</span>
          <span class="inline-flex items-center gap-1.5"><span class="h-2 w-2 rounded-sm bg-talent-blue"></span>Visits</span>
          <span class="inline-flex items-center gap-1.5"><span class="h-2 w-2 rounded-sm bg-emerald-500"></span>Sign-offs</span>
          <span class="inline-flex items-center gap-1.5"><span class="h-2 w-2 rounded-sm bg-amber-500"></span>Reviews</span>
        </div>
      </div>
    </div>
  </section>

  <%# ── 13. Kanban board — Flowbite application UI pattern ─── %>
