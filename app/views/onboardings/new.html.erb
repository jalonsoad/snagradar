<% content_for :title, "Set up your organisation — SnagRadar" %>
<% content_for :auth_top_link do %>
  <%= link_to "Sign out", session_path, data: { turbo_method: :delete }, class: "font-semibold text-talent-muted hover:text-talent-navy transition" %>
<% end %>

<div>
  <span class="inline-flex items-center gap-2 rounded-full bg-talent-orange-50 px-3 py-1 text-xs font-semibold uppercase tracking-wide text-talent-orange-700">Step 1 of 1</span>
  <h1 class="mt-4 font-display text-3xl font-extrabold tracking-tight text-talent-navy">Set up your organisation</h1>
  <p class="mt-2 text-talent-slate">
    This is the workspace your team will share — customer care, site managers and contractors all see the same sites and defects.
  </p>

  <% if flash.now[:alert].present? %>
    <div class="mt-6 rounded-2xl bg-rose-50 ring-1 ring-rose-200 p-4 flex items-start gap-3" role="alert">
      <svg class="h-5 w-5 text-rose-600 flex-shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
      <div class="text-sm font-medium text-rose-800"><%= flash.now[:alert] %></div>
    </div>
  <% end %>

  <%= form_with model: @organization, url: onboarding_path, class: "mt-8 space-y-5" do |f| %>
    <div>
      <%= f.label :name, "Organisation name", class: "block text-xs font-semibold uppercase tracking-wide text-talent-muted" %>
      <div class="relative mt-2">
        <span class="absolute inset-y-0 left-0 pl-4 flex items-center text-talent-muted">
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 21h18M5 21V8l7-5 7 5v13M9 21v-6h6v6"/></svg>
        </span>
        <%= f.text_field :name, required: true, autofocus: true, placeholder: "e.g. PMC Customer Care", class: "block w-full rounded-xl border border-talent-navy/10 pl-11 pr-4 py-3 text-sm focus:outline-none focus:border-talent-orange focus:ring-2 focus:ring-talent-orange/20" %>
      </div>
      <p class="mt-2 text-xs text-talent-muted">You can rename or invite more teammates later from Settings.</p>
    </div>

    <div class="rounded-2xl bg-talent-mist p-4 text-sm text-talent-slate">
      <div class="font-display font-semibold text-talent-navy">What we'll set up for you</div>
      <ul class="mt-3 space-y-2">
        <li class="flex gap-2"><span class="text-talent-orange">✓</span> 8 default trades (Plumbing, Electrical, Carpentry, Decorating, Tiling, Roofing, Glazing, General) with standard SLA windows</li>
        <li class="flex gap-2"><span class="text-talent-orange">✓</span> Your user account as <b>admin</b> of the organisation</li>
        <li class="flex gap-2"><span class="text-talent-orange">✓</span> A blank Radar dashboard ready for your first defect</li>
      </ul>
    </div>

    <%= f.submit "Create organisation →", class: "btn-primary w-full justify-center cursor-pointer" %>
  <% end %>
</div>
