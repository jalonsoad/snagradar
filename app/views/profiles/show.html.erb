<% content_for :title, "Profile — SnagRadar" %>

<div class="max-w-3xl space-y-6">

  <%# Header %>
  <div>
    <nav class="flex items-center gap-2 text-sm text-gray-500" aria-label="Breadcrumb">
      <%= link_to "Dashboard", dashboard_path, class: "hover:text-talent-navy transition" %>
      <svg class="h-3 w-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
      <span class="font-medium text-talent-navy">Profile</span>
    </nav>
    <h1 class="mt-2 text-2xl sm:text-3xl font-semibold tracking-tight text-talent-navy">Your profile</h1>
    <p class="mt-1 text-sm text-gray-500">Update how you appear across the workspace. Email + role are managed by an admin.</p>
  </div>

  <%# Profile card %>
  <%= form_with model: @user, url: profile_path, method: :patch, multipart: true,
        class: "bg-white border border-gray-200 rounded-lg p-6 space-y-6" do |f| %>

    <% if @user.errors.any? %>
      <div class="rounded-lg bg-rose-50 border border-rose-200 p-3 text-sm">
        <div class="font-medium text-rose-800 mb-1">Please fix the highlighted fields:</div>
        <ul class="list-disc list-inside text-xs text-rose-700">
          <% @user.errors.full_messages.each do |msg| %><li><%= msg %></li><% end %>
        </ul>
      </div>
    <% end %>

    <%# Avatar row — live preview via avatar_preview_controller. %>
    <div class="flex items-start gap-5 flex-wrap" data-controller="avatar-preview">
      <div class="flex-shrink-0 relative">
        <%# The image target is shown when the user has either an existing avatar
            OR has just picked a new file. The placeholder shows the initials. %>
        <% has_avatar = @user.avatar.attached? %>
        <img data-avatar-preview-target="image"
             src="<%= has_avatar ? url_for(@user.avatar.variant(:thumb)) : '' %>"
             alt="Your avatar"
             class="<%= 'hidden' unless has_avatar %> h-24 w-24 rounded-full object-cover ring-4 ring-white border border-gray-200">
        <div data-avatar-preview-target="placeholder"
             class="<%= 'hidden' if has_avatar %> h-24 w-24 rounded-full bg-talent-orange grid place-items-center text-white text-3xl font-bold ring-4 ring-white border border-gray-200">
          <%= @user.initials %>
        </div>
      </div>

      <div class="flex-1 min-w-0">
        <div class="text-xs font-medium text-gray-700 uppercase tracking-wide mb-2">Profile picture</div>
        <label for="user_avatar" class="flex flex-col items-center justify-center w-full h-28 rounded-lg border-2 border-gray-200 border-dashed cursor-pointer bg-gray-50 hover:bg-gray-100 hover:border-talent-orange/40 transition">
          <div class="flex flex-col items-center justify-center pt-4 pb-5 text-center">
            <svg class="mb-1.5 h-5 w-5 text-gray-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
            <p class="text-sm text-gray-600"><span class="font-medium text-talent-navy">Click to upload</span> or drag and drop</p>
            <p class="mt-0.5 text-xs text-gray-500">PNG, JPG, WebP — square works best, max 5 MB</p>
          </div>
          <%= f.file_field :avatar, accept: "image/png,image/jpeg,image/webp", class: "hidden",
                data: { action: "change->avatar-preview#change" } %>
        </label>
        <p data-avatar-preview-target="filename" class="mt-1 text-xs text-gray-500"></p>

        <% if @user.avatar.attached? %>
          <%# Opens a dedicated Flowbite confirmation modal that contains the
              actual DELETE form (no setConfirmMethod, no Stimulus). Pure
              Flowbite data-attributes — the most reliable wiring. %>
          <button type="button" data-modal-target="remove-avatar-modal" data-modal-toggle="remove-avatar-modal"
                  class="mt-2 inline-flex items-center gap-1.5 text-xs font-medium text-rose-600 hover:text-rose-700 cursor-pointer transition">
            <svg class="h-3 w-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M3 6h18M19 6l-2 14a2 2 0 0 1-2 2H9a2 2 0 0 1-2-2L5 6"/></svg>
            Remove avatar
          </button>
        <% end %>
      </div>
    </div>

    <%# Name %>
    <div>
      <%= f.label :name, "Display name", class: "block mb-1 text-xs font-medium text-gray-700 uppercase tracking-wide" %>
      <%= f.text_field :name, placeholder: "Sara Jenkins", autocomplete: "name",
            class: "block w-full rounded-lg border border-gray-200 bg-white px-3 py-2 text-sm focus:outline-none focus:border-talent-orange focus:ring-2 focus:ring-talent-orange/20" %>
      <p class="mt-1 text-xs text-gray-500">Shown in the topbar, comments, and activity feed.</p>
    </div>

    <%# Read-only details %>
    <div class="grid sm:grid-cols-2 gap-4 pt-2 border-t border-gray-100">
      <div>
        <div class="text-[11px] font-semibold uppercase tracking-wide text-gray-500">Email</div>
        <div class="mt-1 text-sm text-talent-navy"><%= @user.email_address %></div>
      </div>
      <div>
        <div class="text-[11px] font-semibold uppercase tracking-wide text-gray-500">Role</div>
        <div class="mt-1 text-sm text-talent-navy capitalize"><%= @user.role.tr("_", " ") %></div>
      </div>
      <div>
        <div class="text-[11px] font-semibold uppercase tracking-wide text-gray-500">Organisation</div>
        <div class="mt-1 text-sm text-talent-navy"><%= Current.organization&.name %></div>
      </div>
      <div>
        <div class="text-[11px] font-semibold uppercase tracking-wide text-gray-500">Member since</div>
        <div class="mt-1 text-sm text-talent-navy"><%= @user.created_at.to_date.strftime("%d %b %Y") %></div>
      </div>
    </div>

    <%# Actions %>
    <div class="flex items-center justify-end gap-2 pt-4 border-t border-gray-100">
      <%= link_to "Cancel", dashboard_path,
            class: "inline-flex items-center gap-2 rounded-lg border border-gray-200 bg-white px-4 py-2 text-sm font-medium text-talent-navy hover:bg-gray-50 transition" %>
      <%= f.submit "Save changes",
            class: "inline-flex items-center gap-2 rounded-lg bg-talent-orange px-4 py-2 text-sm font-medium text-white hover:bg-talent-orange-600 cursor-pointer transition" %>
    </div>
  <% end %>

  <%# ── Dedicated Remove-avatar confirmation modal ───────────── %>
  <% if @user.avatar.attached? %>
    <div id="remove-avatar-modal" tabindex="-1" aria-hidden="true"
         class="hidden overflow-y-auto overflow-x-hidden fixed top-0 right-0 left-0 z-50 justify-center items-center w-full md:inset-0 h-[calc(100%-1rem)] max-h-full">
      <div class="relative p-4 w-full max-w-md max-h-full">
        <div class="relative bg-white rounded-lg shadow-lg border border-gray-200">
          <button type="button" data-modal-hide="remove-avatar-modal"
                  class="absolute top-3 end-3 text-gray-400 bg-transparent hover:bg-gray-100 hover:text-talent-navy rounded-lg text-sm w-8 h-8 inline-flex justify-center items-center cursor-pointer transition" aria-label="Close">
            <svg class="w-3 h-3" viewBox="0 0 14 14" fill="none"><path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 1 6 6m0 0 6 6M7 7l6-6M7 7l-6 6"/></svg>
          </button>

          <div class="p-6 text-center">
            <div class="mx-auto mb-4 h-12 w-12 rounded-full bg-rose-50 text-rose-600 grid place-items-center">
              <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            </div>
            <h3 class="mb-2 text-lg font-semibold text-talent-navy">Remove your profile picture?</h3>
            <p class="mb-5 text-sm text-gray-500">Your initials will show on every comment and activity entry until you upload a new one.</p>

            <%= form_with url: avatar_profile_path, method: :delete, class: "flex items-center justify-center gap-2" do %>
              <button type="button" data-modal-hide="remove-avatar-modal"
                      class="rounded-lg border border-gray-200 bg-white px-4 py-2 text-sm font-medium text-talent-navy hover:bg-gray-50 cursor-pointer transition">Cancel</button>
              <button type="submit"
                      class="rounded-lg bg-rose-600 px-4 py-2 text-sm font-medium text-white hover:bg-rose-700 cursor-pointer transition">Yes, remove</button>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  <% end %>

  <%# Security card %>
  <div class="bg-white border border-gray-200 rounded-lg p-6">
    <h3 class="text-sm font-semibold text-talent-navy">Security</h3>
    <p class="mt-1 text-xs text-gray-500">Reset your password via email if you need to change it.</p>
    <div class="mt-4 flex flex-wrap gap-2">
      <%= link_to new_password_path,
            class: "inline-flex items-center gap-2 rounded-lg border border-gray-200 bg-white px-4 py-2 text-sm font-medium text-talent-navy hover:bg-gray-50 transition" do %>
        <svg class="h-4 w-4 text-gray-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
        Reset password
      <% end %>
      <%= button_to session_path, method: :delete,
            class: "inline-flex items-center gap-2 rounded-lg border border-rose-200 bg-white px-4 py-2 text-sm font-medium text-rose-700 hover:bg-rose-50 cursor-pointer transition" do %>
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
        Sign out
      <% end %>
    </div>
  </div>
</div>
