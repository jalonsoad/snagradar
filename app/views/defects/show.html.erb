<% content_for :title, "#{@defect.title} — SnagRadar" %>

<%# Combine activity events + comments into a single chronological feed.
    Each entry is a struct-like hash so the timeline template stays simple. %>
<%
  feed = []
  @activity_events.each do |e|
    feed << { kind: :event,   at: e.created_at, payload: e }
  end
  @comments.each do |c|
    feed << { kind: :comment, at: c.created_at, payload: c }
  end
  feed.sort_by! { |f| f[:at] }
%>

<div class="space-y-6">

  <%# ─── Header card ─────────────────────────────────────────────── %>
  <div class="bg-white border border-gray-200 rounded-lg p-6">
    <div class="flex items-start justify-between gap-4 flex-wrap">
      <div class="min-w-0">
        <%# Breadcrumb %>
        <nav class="flex items-center gap-2 text-sm text-gray-500" aria-label="Breadcrumb">
          <%= link_to "Defects", defects_path, class: "hover:text-talent-navy transition" %>
          <svg class="h-3 w-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
          <span class="font-mono text-xs"><%= @defect.reference || "##{@defect.id}" %></span>
        </nav>
        <h1 class="mt-2 text-2xl sm:text-3xl font-semibold tracking-tight text-talent-navy"><%= @defect.title %></h1>
        <div class="mt-3 flex items-center gap-3 flex-wrap text-sm text-gray-500">
          <span><%= @defect.site&.name %></span>
          <% if @defect.plot %><span class="text-gray-300">·</span><span><%= @defect.plot.label %></span><% end %>
          <span class="text-gray-300">·</span><span><%= @defect.trade&.name %></span>
          <span class="text-gray-300">·</span>
          <span class="inline-flex items-center gap-1 capitalize">
            <span class="h-1.5 w-1.5 rounded-full <%= @defect.priority_urgent? || @defect.priority_high? ? 'bg-rose-500' : @defect.priority_medium? ? 'bg-amber-500' : 'bg-emerald-500' %>"></span>
            <%= @defect.priority %> priority
          </span>
        </div>
      </div>

      <div class="flex flex-col items-end gap-2">
        <div class="flex items-center gap-2">
          <%= render "defects/sla_badge", defect: @defect %>
          <%= render "defects/status_badge", status: @defect.status %>
        </div>
        <div class="flex items-center gap-2">
          <%= link_to edit_defect_path(@defect), class: "inline-flex items-center gap-2 rounded-lg border border-gray-200 bg-white px-3 py-2 text-sm font-medium text-talent-navy hover:bg-gray-50 cursor-pointer transition" do %>
            <%= icon "edit", class: "h-4 w-4 text-gray-500" %>
            Edit
          <% end %>
          <button data-dropdown-toggle="defect-header-actions" data-dropdown-placement="bottom-end"
                  class="inline-flex h-9 w-9 items-center justify-center rounded-lg border border-gray-200 bg-white text-gray-500 hover:bg-gray-50 hover:text-talent-navy cursor-pointer transition" type="button" aria-label="More actions">
            <%= icon "more", class: "h-4 w-4" %>
          </button>
          <div id="defect-header-actions" class="z-50 hidden w-48 bg-white rounded-lg border border-gray-200 shadow-lg overflow-hidden">
            <ul class="py-1 text-sm text-talent-navy">
              <% if @defect.status_closed? %>
                <li>
                  <%= button_to reopen_defect_path(@defect), class: "w-full flex items-center gap-2 px-4 py-2 hover:bg-gray-50 cursor-pointer transition text-left" do %>
                    <%= icon "edit", class: "h-4 w-4 text-gray-500" %>
                    Reopen
                  <% end %>
                </li>
              <% else %>
                <li>
                  <%= button_to close_defect_path(@defect), class: "w-full flex items-center gap-2 px-4 py-2 hover:bg-gray-50 cursor-pointer transition text-left" do %>
                    <%= icon "check", class: "h-4 w-4 text-emerald-600" %>
                    Close
                  <% end %>
                </li>
              <% end %>
              <li class="border-t border-gray-100">
                <%= button_to defect_path(@defect), method: :delete,
                      data: { turbo_confirm: "Delete this defect?" },
                      class: "w-full flex items-center gap-2 px-4 py-2 text-rose-600 hover:bg-rose-50 cursor-pointer transition text-left" do %>
                  <%= icon "delete", class: "h-4 w-4" %>
                  Delete
                <% end %>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="grid lg:grid-cols-12 gap-6">

    <%# ─── LEFT col: description / photos / timeline ──────────────── %>
    <div class="lg:col-span-8 space-y-6">

      <% if @defect.description.present? %>
        <div class="bg-white border border-gray-200 rounded-lg p-6">
          <h3 class="text-sm font-semibold text-gray-500 uppercase tracking-wide">Description</h3>
          <div class="mt-3 text-talent-navy leading-relaxed prose prose-sm max-w-none"><%= simple_format @defect.description %></div>
        </div>
      <% end %>

      <% if @defect.photos.attached? %>
        <div class="bg-white border border-gray-200 rounded-lg p-6">
          <div class="flex items-center justify-between mb-4">
            <h3 class="text-sm font-semibold text-gray-500 uppercase tracking-wide">Photos</h3>
            <span class="inline-flex items-center justify-center rounded-full bg-gray-100 text-gray-600 px-2 py-0.5 text-xs font-medium"><%= @defect.photos.size %></span>
          </div>
          <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
            <% @defect.photos.each do |photo| %>
              <%= link_to url_for(photo), target: "_blank", rel: "noopener", class: "block aspect-square rounded-lg overflow-hidden bg-gray-100 hover:ring-2 hover:ring-talent-orange transition" do %>
                <%= image_tag photo.variant(resize_to_fill: [400, 400]).processed, class: "w-full h-full object-cover" rescue image_tag(photo, class: "w-full h-full object-cover") %>
              <% end %>
            <% end %>
          </div>
        </div>
      <% end %>

      <%# ─── Activity timeline (Flowbite vertical timeline) ──────── %>
      <div class="bg-white border border-gray-200 rounded-lg p-6">
        <h3 class="text-sm font-semibold text-gray-500 uppercase tracking-wide">Activity</h3>

        <ol class="relative mt-6 border-l border-gray-200 ml-3">
          <% feed.each do |item| %>
            <% if item[:kind] == :event %>
              <% e = item[:payload] %>
              <li class="mb-6 ml-6">
                <span class="absolute -left-3 flex items-center justify-center w-6 h-6 rounded-full bg-talent-orange-50 ring-4 ring-white text-talent-orange">
                  <%= icon "lightning", class: "h-3 w-3" %>
                </span>
                <div class="flex items-center justify-between gap-3 flex-wrap">
                  <h4 class="text-sm font-semibold text-talent-navy">
                    <%= e.actor_label %>
                    <span class="text-gray-500 font-normal"><%= e.event_type.tr(".", " ").humanize.downcase %></span>
                  </h4>
                  <time class="text-xs font-mono text-gray-400 whitespace-nowrap"><%= e.created_at.strftime("%d %b · %H:%M") %></time>
                </div>
                <% if e.metadata.present? %>
                  <p class="mt-1 text-xs text-gray-500">
                    <% e.metadata.each_with_index do |(k, v), i| %><%= "· " if i.positive? %><%= k %>: <span class="text-talent-navy"><%= v %></span> <% end %>
                  </p>
                <% end %>
              </li>
            <% else %>
              <% c = item[:payload] %>
              <li class="mb-6 ml-6">
                <span class="absolute -left-3 flex items-center justify-center w-6 h-6 rounded-full bg-talent-navy ring-4 ring-white text-white text-[10px] font-bold">
                  <%= c.user.initials %>
                </span>
                <div class="flex items-center justify-between gap-3 flex-wrap">
                  <h4 class="text-sm font-semibold text-talent-navy"><%= c.user.display_name %></h4>
                  <time class="text-xs font-mono text-gray-400 whitespace-nowrap"><%= c.created_at.strftime("%d %b · %H:%M") %></time>
                </div>
                <div class="mt-2 rounded-lg bg-gray-50 border border-gray-100 px-4 py-3 text-sm text-talent-navy leading-relaxed">
                  <%= simple_format c.body %>
                </div>
              </li>
            <% end %>
          <% end %>
        </ol>

        <%# Comment form %>
        <div class="mt-2 pt-6 border-t border-gray-100">
          <%= form_with model: @new_comment, url: defect_comments_path(@defect), class: "flex gap-3" do |f| %>
            <div class="h-9 w-9 rounded-full bg-talent-orange grid place-items-center text-white text-sm font-bold flex-shrink-0"><%= Current.user.initials %></div>
            <div class="flex-1 space-y-2">
              <%= f.text_area :body, rows: 2, placeholder: "Add a note…",
                    class: "block w-full rounded-lg border border-gray-200 px-4 py-2.5 text-sm focus:outline-none focus:border-talent-orange focus:ring-2 focus:ring-talent-orange/20 resize-none" %>
              <div class="flex justify-end">
                <%= f.submit "Post comment", class: "inline-flex items-center gap-2 rounded-lg bg-talent-orange px-4 py-2 text-sm font-medium text-white hover:bg-talent-orange-600 cursor-pointer transition" %>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    </div>

    <%# ─── RIGHT col: next action / appointments / meta ──────────── %>
    <aside class="lg:col-span-4 space-y-6">

      <%# Next action card %>
      <div class="bg-white border border-gray-200 rounded-lg p-5">
        <h3 class="text-sm font-semibold text-gray-500 uppercase tracking-wide mb-4">Next action</h3>
        <% case @defect.status %>
        <% when "logged" %>
          <%= form_with url: assign_defect_path(@defect), class: "space-y-2" do |f| %>
            <%= f.select :contractor_company_id,
                  Current.organization.contractor_companies.order(:name).map { [_1.name, _1.id] },
                  { include_blank: "Pick a contractor" },
                  class: "block w-full rounded-lg border border-gray-200 px-3 py-2 text-sm focus:outline-none focus:border-talent-orange focus:ring-2 focus:ring-talent-orange/20" %>
            <%= f.submit "Assign", class: "inline-flex items-center justify-center gap-2 w-full rounded-lg bg-talent-orange px-4 py-2 text-sm font-medium text-white hover:bg-talent-orange-600 cursor-pointer transition" %>
          <% end %>
        <% when "assigned" %>
          <%= button_to accept_defect_path(@defect), class: "inline-flex items-center justify-center gap-2 w-full rounded-lg bg-talent-orange px-4 py-2 text-sm font-medium text-white hover:bg-talent-orange-600 cursor-pointer transition" do %>
            <%= icon "check", class: "h-4 w-4" %>
            Mark accepted
          <% end %>
          <%= button_to reject_defect_path(@defect), class: "mt-2 inline-flex items-center justify-center gap-2 w-full rounded-lg bg-white border border-rose-200 text-rose-700 px-4 py-2 text-sm font-medium hover:bg-rose-50 cursor-pointer transition" do %>
            <%= icon "close", class: "h-4 w-4" %>
            Reject
          <% end %>
        <% when "accepted", "booked", "in_progress" %>
          <%= button_to complete_defect_path(@defect), class: "inline-flex items-center justify-center gap-2 w-full rounded-lg bg-talent-orange px-4 py-2 text-sm font-medium text-white hover:bg-talent-orange-600 cursor-pointer transition" do %>
            <%= icon "check", class: "h-4 w-4" %>
            Mark complete
          <% end %>
        <% when "completed" %>
          <p class="text-sm text-gray-500 mb-3">Awaiting resident sign-off.</p>
          <%= button_to close_defect_path(@defect), class: "inline-flex items-center justify-center gap-2 w-full rounded-lg bg-talent-orange px-4 py-2 text-sm font-medium text-white hover:bg-talent-orange-600 cursor-pointer transition" do %>
            <%= icon "check", class: "h-4 w-4" %>
            Close defect
          <% end %>
        <% when "signed_off" %>
          <%= button_to close_defect_path(@defect), class: "inline-flex items-center justify-center gap-2 w-full rounded-lg bg-talent-orange px-4 py-2 text-sm font-medium text-white hover:bg-talent-orange-600 cursor-pointer transition" do %>
            <%= icon "check", class: "h-4 w-4" %>
            Close defect
          <% end %>
        <% when "closed" %>
          <p class="text-sm text-emerald-700 font-medium mb-3">Defect closed.</p>
          <%= button_to reopen_defect_path(@defect), class: "inline-flex items-center justify-center gap-2 w-full rounded-lg bg-white border border-gray-200 text-talent-navy px-4 py-2 text-sm font-medium hover:bg-gray-50 cursor-pointer transition" do %>
            Reopen
          <% end %>
        <% when "rejected" %>
          <p class="text-sm text-rose-700">Rejected.</p>
        <% end %>
      </div>

      <%# Appointments %>
      <div class="bg-white border border-gray-200 rounded-lg">
        <div class="px-5 py-4 border-b border-gray-200 flex items-center justify-between">
          <h3 class="text-sm font-semibold text-gray-500 uppercase tracking-wide">Appointments</h3>
          <span class="inline-flex items-center justify-center rounded-full bg-gray-100 text-gray-600 px-2 py-0.5 text-xs font-medium"><%= @defect.appointments.size %></span>
        </div>

        <% if @defect.appointments.any? %>
          <ul class="divide-y divide-gray-100">
            <% @defect.appointments.order(:scheduled_at).each do |appt| %>
              <li class="px-5 py-3 flex items-center justify-between gap-3">
                <div class="flex items-center gap-3 min-w-0">
                  <span class="inline-flex h-9 w-9 items-center justify-center rounded-lg bg-talent-orange-50 text-talent-orange flex-shrink-0">
                    <%= icon "calendar", class: "h-4 w-4" %>
                  </span>
                  <div class="min-w-0">
                    <div class="font-medium text-talent-navy text-sm truncate"><%= appt.scheduled_at.strftime("%a %d %b · %H:%M") %></div>
                    <div class="text-xs text-gray-500 capitalize"><%= appt.status %></div>
                  </div>
                </div>
                <div class="flex items-center gap-1.5 flex-shrink-0">
                  <% if appt.status == "proposed" %>
                    <%= button_to "Confirm", defect_appointment_path(@defect, appt), method: :patch, params: { appointment: { status: :confirmed } },
                          class: "rounded-md bg-emerald-50 text-emerald-700 px-2.5 py-1 text-xs font-medium hover:bg-emerald-100 cursor-pointer transition" %>
                  <% elsif appt.status == "confirmed" %>
                    <%= button_to "Attended", defect_appointment_path(@defect, appt), method: :patch, params: { appointment: { status: :attended } },
                          class: "rounded-md bg-talent-navy text-white px-2.5 py-1 text-xs font-medium hover:bg-talent-navy-700 cursor-pointer transition" %>
                  <% end %>
                  <%= button_to defect_appointment_path(@defect, appt), method: :delete,
                        class: "inline-flex h-7 w-7 items-center justify-center rounded-md text-gray-400 hover:bg-rose-50 hover:text-rose-600 cursor-pointer transition",
                        data: { turbo_confirm: "Cancel this appointment?" } do %>
                    <%= icon "close", class: "h-3 w-3" %>
                  <% end %>
                </div>
              </li>
            <% end %>
          </ul>
        <% else %>
          <p class="px-5 py-4 text-sm text-gray-500">No appointments yet.</p>
        <% end %>

        <%# Add appointment form (scope: :appointment so params.expect works) %>
        <div class="px-5 py-3 bg-gray-50 border-t border-gray-200">
          <%= form_with url: defect_appointments_path(@defect), scope: :appointment, class: "flex items-center gap-2" do |f| %>
            <%= f.datetime_local_field :scheduled_at, required: true,
                  class: "flex-1 rounded-md border border-gray-200 bg-white px-3 py-1.5 text-xs focus:outline-none focus:border-talent-orange focus:ring-2 focus:ring-talent-orange/20" %>
            <%= f.submit "Add", class: "inline-flex items-center gap-1 rounded-md bg-talent-navy text-white px-3 py-1.5 text-xs font-medium hover:bg-talent-navy-700 cursor-pointer transition" %>
          <% end %>
        </div>
      </div>

      <%# Meta details (Flowbite description list) %>
      <div class="bg-white border border-gray-200 rounded-lg p-5">
        <h3 class="text-sm font-semibold text-gray-500 uppercase tracking-wide mb-4">Details</h3>
        <dl class="space-y-3 text-sm">
          <div class="flex items-start justify-between gap-3">
            <dt class="text-gray-500">Contractor</dt>
            <dd class="text-talent-navy font-medium text-right"><%= @defect.contractor_company&.name || "Not yet assigned" %></dd>
          </div>
          <div class="flex items-start justify-between gap-3">
            <dt class="text-gray-500">SLA target</dt>
            <dd class="text-talent-navy font-medium text-right"><%= @defect.sla_target_date&.strftime("%d %b %Y") || "—" %></dd>
          </div>
          <div class="flex items-start justify-between gap-3">
            <dt class="text-gray-500">Logged by</dt>
            <dd class="text-talent-navy font-medium text-right"><%= @defect.reporter&.display_name || "—" %></dd>
          </div>
          <div class="flex items-start justify-between gap-3">
            <dt class="text-gray-500">Created</dt>
            <dd class="text-talent-navy font-medium text-right"><%= @defect.created_at.strftime("%d %b %Y") %></dd>
          </div>
        </dl>
      </div>
    </aside>
  </div>
</div>
