<% content_for :title, "New defect — SnagRadar" %>

<div class="max-w-3xl mx-auto">
  <nav class="flex items-center gap-2 text-sm text-gray-500" aria-label="Breadcrumb">
    <%= link_to "Defects", defects_path, class: "hover:text-talent-navy transition" %>
    <svg class="h-3 w-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
    <span class="font-medium text-talent-navy">New defect</span>
  </nav>

  <h1 class="mt-2 text-2xl sm:text-3xl font-semibold tracking-tight text-talent-navy">Log a defect</h1>
  <p class="mt-1 text-sm text-gray-500">Two minutes max — site, plot, trade, priority, photos. The SLA target date defaults from the trade.</p>

  <div class="mt-6 rounded-lg bg-white border border-gray-200 p-6 sm:p-8">
    <%= render "form", defect: @defect %>
  </div>
</div>
