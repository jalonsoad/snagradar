<%#
  Reusable password input with a left lock icon + right eye-toggle.
  Locals:
    form        — the form_with builder
    field       — attribute name symbol (e.g. :password)
    label       — text for <label>
    autocomplete — autocomplete value (current-password / new-password)
    autofocus   — boolean (default false)
%>
<% autofocus_attr = local_assigns.fetch(:autofocus, false) %>
<% autocomplete   = local_assigns.fetch(:autocomplete, "current-password") %>
<% placeholder    = local_assigns.fetch(:placeholder, "••••••••") %>
<% minlength      = local_assigns.fetch(:minlength, 8) %>

<div data-controller="password-visibility">
  <%= form.label field, label, class: "block text-xs font-semibold uppercase tracking-wide text-talent-muted" %>
  <div class="relative mt-2">
    <span class="absolute inset-y-0 left-0 pl-4 flex items-center text-talent-muted pointer-events-none">
      <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>
      </svg>
    </span>

    <%= form.password_field field,
        required: true,
        minlength: minlength,
        maxlength: 72,
        autofocus: autofocus_attr,
        autocomplete: autocomplete,
        placeholder: placeholder,
        data: { password_visibility_target: "input" },
        class: "block w-full rounded-xl border border-talent-navy/10 pl-11 pr-12 py-3 text-sm focus:outline-none focus:border-talent-orange focus:ring-2 focus:ring-talent-orange/20" %>

    <button type="button"
            data-action="click->password-visibility#toggle"
            class="absolute inset-y-0 right-0 pr-4 flex items-center text-talent-muted hover:text-talent-navy transition-colors cursor-pointer"
            aria-label="Show/hide password">
      <%# Eye (show) %>
      <svg data-password-visibility-target="iconShow" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>
      </svg>
      <%# Eye-off (hide) %>
      <svg data-password-visibility-target="iconHide" class="hidden h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/><line x1="1" y1="1" x2="23" y2="23"/>
      </svg>
    </button>
  </div>
</div>
