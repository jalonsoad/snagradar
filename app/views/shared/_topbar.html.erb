<%# Fixed full-width top nav (Flowbite shell pattern).
    Holds the mobile sidebar trigger, brand + search on the left, and
    notifications + user menu on the right. %>
<nav class="bg-white border-b border-gray-200 px-4 py-2.5 fixed left-0 right-0 top-0 z-50">
  <div class="flex flex-wrap justify-between items-center">

    <%# LEFT: hamburger (mobile) + brand + search %>
    <div class="flex justify-start items-center">
      <button data-drawer-target="sidebar-default" data-drawer-toggle="sidebar-default" aria-controls="sidebar-default"
              class="p-2 mr-2 text-gray-500 rounded-lg cursor-pointer md:hidden hover:text-talent-navy hover:bg-gray-100 focus:bg-gray-100 focus:ring-2 focus:ring-gray-100 transition" aria-label="Toggle sidebar">
        <svg aria-hidden="true" class="w-6 h-6" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
          <path fill-rule="evenodd" clip-rule="evenodd" d="M3 5a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zM3 10a1 1 0 011-1h6a1 1 0 110 2H4a1 1 0 01-1-1zM3 15a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1z"/>
        </svg>
      </button>

      <%= link_to dashboard_path, class: "flex items-center justify-between mr-4" do %>
        <%= image_tag "snagradar-icon.png", alt: "", class: "mr-3 h-8 w-8 object-contain" %>
        <span class="self-center text-xl font-extrabold whitespace-nowrap tracking-tight">
          <span class="text-talent-navy">Snag</span><span class="text-talent-orange">Radar</span>
        </span>
      <% end %>

      <%# Inline search (md+) %>
      <div class="hidden md:block md:pl-2"
           data-controller="topbar-search"
           data-topbar-search-url-value="<%= search_path %>"
           data-action="click@window->topbar-search#clickOutside">
        <%= form_with url: search_path, method: :get do |f| %>
          <label for="topbar-search" class="sr-only">Search</label>
          <div class="relative md:w-72 lg:w-96">
            <div class="flex absolute inset-y-0 left-0 items-center pl-3 pointer-events-none text-gray-400">
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
            </div>
            <%= f.search_field :q, id: "topbar-search",
                  placeholder: "Search defects, sites, contractors…",
                  data: { topbar_search_target: "input",
                          action: "input->topbar-search#schedule focus->topbar-search#schedule" },
                  class: "bg-gray-50 border border-gray-200 text-talent-navy text-sm rounded-lg focus:ring-2 focus:ring-talent-orange/20 focus:border-talent-orange block w-full pl-10 p-2" %>
            <%# Live results dropdown %>
            <div data-topbar-search-target="panel"
                 class="hidden absolute top-full left-0 right-0 mt-2 rounded-lg bg-white border border-gray-200 shadow-lg overflow-hidden max-h-[28rem] overflow-y-auto z-50">
              <div data-topbar-search-target="results"></div>
            </div>
          </div>
        <% end %>
      </div>
    </div>

    <%# RIGHT: notifications + user menu %>
    <div class="flex items-center lg:order-2">

      <%# Quick-create: log defect %>
      <%= link_to new_defect_path, class: "hidden sm:inline-flex items-center gap-2 mr-1 px-3 py-1.5 text-xs font-semibold text-talent-navy bg-white border border-gray-200 rounded-lg hover:bg-gray-50 cursor-pointer transition" do %>
        <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
        New defect
      <% end %>

      <%# Notifications dropdown %>
      <% unread_count = Current.user&.notifications&.unread&.count.to_i %>
      <% recent_notifications = Current.user&.notifications&.recent&.limit(5)&.to_a || [] %>
      <button type="button" data-dropdown-toggle="notification-dropdown"
              class="relative p-2 mr-1 text-gray-500 rounded-lg hover:text-talent-navy hover:bg-gray-100 focus:ring-4 focus:ring-gray-100 cursor-pointer transition" aria-label="View notifications">
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
        <% if unread_count > 0 %>
          <span class="absolute -top-0.5 -right-0.5 min-w-[18px] h-[18px] px-1 rounded-full bg-talent-orange text-white text-[10px] font-bold grid place-items-center ring-2 ring-white"><%= [unread_count, 99].min %></span>
        <% end %>
      </button>
      <div id="notification-dropdown" class="hidden overflow-hidden z-50 my-4 max-w-sm w-80 text-base list-none bg-white rounded-lg shadow-lg border border-gray-200 divide-y divide-gray-100">
        <div class="flex items-center justify-between py-2 px-4 text-sm font-semibold text-talent-navy bg-gray-50">
          <span>Notifications</span>
          <span class="text-xs font-medium text-gray-500"><%= unread_count %> unread</span>
        </div>
        <% if recent_notifications.any? %>
          <div class="max-h-80 overflow-y-auto divide-y divide-gray-100">
            <% recent_notifications.each do |n| %>
              <%= link_to (n.defect ? defect_path(n.defect) : notifications_path),
                          class: "flex py-3 px-4 hover:bg-gray-50 transition #{'bg-talent-orange-50/40' if n.read_at.nil?}" do %>
                <span class="flex-shrink-0 inline-flex items-center justify-center w-9 h-9 rounded-full bg-talent-orange-50 text-talent-orange">
                  <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/></svg>
                </span>
                <div class="pl-3 w-full min-w-0">
                  <div class="text-sm text-talent-navy font-medium truncate"><%= n.subject || n.event_type.humanize %></div>
                  <% if n.preview.present? %>
                    <div class="text-xs text-gray-500 truncate"><%= n.preview %></div>
                  <% end %>
                  <div class="text-[10px] text-talent-orange font-medium mt-0.5"><%= time_ago_in_words(n.created_at) %> ago</div>
                </div>
              <% end %>
            <% end %>
          </div>
          <%= link_to notifications_path, class: "block py-2 text-sm font-medium text-center text-talent-navy bg-gray-50 hover:bg-gray-100 transition" do %>
            <span class="inline-flex items-center gap-1.5">
              <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7z"/></svg>
              View all
            </span>
          <% end %>
        <% else %>
          <div class="px-4 py-6 text-center text-sm text-gray-500">You're all caught up.</div>
        <% end %>
      </div>

      <%# User avatar + menu %>
      <% user = Current.user %>
      <button type="button" data-dropdown-toggle="user-dropdown"
              class="flex mx-3 text-sm rounded-full md:mr-0 focus:ring-4 focus:ring-talent-orange/20 cursor-pointer overflow-hidden <%= 'bg-talent-orange' unless user&.avatar&.attached? %>">
        <span class="sr-only">Open user menu</span>
        <% if user&.avatar&.attached? %>
          <%= image_tag user.avatar.variant(:small), class: "h-8 w-8 rounded-full object-cover", alt: user.display_name %>
        <% else %>
          <span class="inline-flex h-8 w-8 items-center justify-center rounded-full text-white text-xs font-bold"><%= user&.initials %></span>
        <% end %>
      </button>
      <div id="user-dropdown" class="hidden z-50 my-4 w-60 text-base list-none bg-white rounded-lg shadow-lg border border-gray-200 divide-y divide-gray-100">
        <div class="py-3 px-4">
          <span class="block text-sm font-semibold text-talent-navy"><%= user&.display_name %></span>
          <span class="block text-xs text-gray-500 truncate"><%= user&.email_address %></span>
          <span class="block text-xs text-gray-500 mt-0.5 capitalize"><%= user&.role&.tr("_", " ") %> · <%= Current.organization&.name %></span>
        </div>
        <ul class="py-1 text-sm text-talent-navy">
          <li><%= link_to profile_path, class: "flex items-center gap-3 px-4 py-2 hover:bg-gray-50 transition" do %>
            <svg class="h-4 w-4 text-gray-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
            Profile
          <% end %></li>
          <li><a href="#"                   class="flex items-center gap-3 px-4 py-2 hover:bg-gray-50 transition">
            <svg class="h-4 w-4 text-gray-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9 1.65 1.65 0 0 0 4.27 7.18l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
            Account settings
          </a></li>
          <li><%= link_to invitations_path, class: "flex items-center gap-3 px-4 py-2 hover:bg-gray-50 transition" do %>
            <svg class="h-4 w-4 text-gray-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            Team
          <% end %></li>
          <li><%= link_to testpage_path, class: "flex items-center gap-3 px-4 py-2 hover:bg-gray-50 transition" do %>
            <svg class="h-4 w-4 text-gray-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/></svg>
            Component playground
          <% end %></li>
        </ul>
        <ul class="py-1 text-sm">
          <li>
            <%= button_to session_path, method: :delete,
                  class: "w-full flex items-center gap-3 px-4 py-2 text-rose-600 hover:bg-rose-50 cursor-pointer transition text-left" do %>
              <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
              Sign out
            <% end %>
          </li>
        </ul>
      </div>
    </div>
  </div>
</nav>
