<header class="sticky top-0 z-40 bg-white border-b border-talent-navy/5">
  <div class="flex items-center justify-between gap-4 px-6 lg:px-10 h-16">
    <%# Mobile menu trigger %>
    <button type="button" class="lg:hidden inline-flex h-9 w-9 items-center justify-center rounded-lg text-talent-navy" aria-label="Menu">
      <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="4" y1="7" x2="20" y2="7"/><line x1="4" y1="12" x2="20" y2="12"/><line x1="4" y1="17" x2="20" y2="17"/></svg>
    </button>

    <%# Search %>
    <div class="hidden md:flex flex-1 max-w-md">
      <div class="relative w-full">
        <span class="absolute inset-y-0 left-0 pl-3 flex items-center text-talent-muted">
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        </span>
        <input type="search" placeholder="Search defects, sites, contractors…" class="block w-full rounded-xl border border-talent-navy/10 bg-talent-mist/60 pl-10 pr-4 py-2 text-sm focus:outline-none focus:border-talent-orange focus:bg-white focus:ring-2 focus:ring-talent-orange/20">
      </div>
    </div>

    <%# Right cluster %>
    <div class="flex items-center gap-2 sm:gap-3">
      <%= link_to new_defect_path, class: "hidden sm:inline-flex items-center gap-2 rounded-full border border-talent-navy/10 bg-white px-3 py-1.5 text-xs font-semibold text-talent-navy hover:bg-talent-mist transition" do %>
        <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
        New defect
      <% end %>

      <button class="relative h-9 w-9 grid place-items-center rounded-full hover:bg-talent-mist transition" aria-label="Notifications">
        <svg class="h-5 w-5 text-talent-navy" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
        <span class="absolute top-2 right-2 h-2 w-2 rounded-full bg-talent-orange ring-2 ring-white"></span>
      </button>

      <% user = Current.user %>
      <div class="flex items-center gap-2.5 pl-2 sm:pl-3 sm:border-l sm:border-talent-navy/10 sm:ml-1">
        <div class="h-9 w-9 rounded-full bg-gradient-to-br from-talent-orange to-talent-orange-600 grid place-items-center text-white text-sm font-bold">
          <%= user&.initials %>
        </div>
        <div class="hidden sm:block leading-tight">
          <div class="text-sm font-semibold text-talent-navy truncate max-w-[140px]"><%= user&.display_name %></div>
          <div class="text-xs text-talent-muted capitalize"><%= user&.role&.tr("_", " ") %></div>
        </div>
      </div>
    </div>
  </div>
</header>
