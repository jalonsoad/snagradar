<% content_for :title, "Contractors — SnagRadar" %>

<div class="space-y-6">
  <div class="flex items-end justify-between gap-4">
    <div>
      <h1 class="font-display text-3xl font-extrabold tracking-tight text-talent-navy">Contractors</h1>
      <p class="mt-1 text-talent-slate">Subcontractor companies you assign defects to.</p>
    </div>
    <%= link_to new_contractor_company_path, class: "btn-primary cursor-pointer" do %>
      <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
      Add contractor
    <% end %>
  </div>

  <div class="rounded-2xl bg-white border border-talent-navy/5 shadow-soft overflow-hidden">
    <% if @companies.any? %>
      <table class="w-full text-sm">
        <thead class="bg-talent-mist/50 border-b border-talent-navy/5">
          <tr class="text-left text-xs font-semibold uppercase tracking-wider text-talent-muted">
            <th class="px-5 py-3">Company</th>
            <th class="px-5 py-3">Trade</th>
            <th class="px-5 py-3">Email</th>
            <th class="px-5 py-3">Phone</th>
            <th class="px-5 py-3 text-right">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-talent-navy/5">
          <% @companies.each do |c| %>
            <tr class="hover:bg-talent-mist/40 transition">
              <td class="px-5 py-3.5 font-semibold text-talent-navy"><%= c.name %></td>
              <td class="px-5 py-3.5 text-talent-slate"><%= c.trade&.name || "—" %></td>
              <td class="px-5 py-3.5 text-talent-slate"><%= c.contact_email || "—" %></td>
              <td class="px-5 py-3.5 text-talent-slate"><%= c.phone || "—" %></td>
              <td class="px-5 py-3.5 text-right space-x-3">
                <%= link_to "Edit", edit_contractor_company_path(c), class: "text-talent-orange hover:text-talent-orange-700 font-semibold" %>
                <%= button_to "Remove", contractor_company_path(c), method: :delete, class: "text-rose-600 hover:text-rose-700 inline", data: { turbo_confirm: "Remove #{c.name}?" } %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <div class="p-10 text-center">
        <h3 class="font-display text-xl font-extrabold text-talent-navy">No contractors yet</h3>
        <p class="mt-2 text-talent-muted">Add the trades you regularly route defects to.</p>
        <%= link_to "Add contractor", new_contractor_company_path, class: "btn-primary mt-5 inline-flex cursor-pointer" %>
      </div>
    <% end %>
  </div>
</div>
