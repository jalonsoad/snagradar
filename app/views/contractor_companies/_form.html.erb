<% input_classes = "mt-2 w-full rounded-xl border border-talent-navy/10 px-4 py-3 text-sm focus:outline-none focus:border-talent-orange focus:ring-2 focus:ring-talent-orange/20" %>
<% label_classes = "block text-xs font-semibold uppercase tracking-wide text-talent-muted" %>

<%= form_with model: company, url: (company.persisted? ? contractor_company_path(company) : contractor_companies_path), class: "space-y-5" do |f| %>
  <div>
    <%= f.label :name, "Company name", class: label_classes %>
    <%= f.text_field :name, class: input_classes, required: true, autofocus: true %>
  </div>
  <div class="grid sm:grid-cols-2 gap-5">
    <div>
      <%= f.label :trade_id, "Default trade", class: label_classes %>
      <%= f.collection_select :trade_id, Current.organization.trades.order(:name), :id, :name, { include_blank: "None" }, class: input_classes %>
    </div>
    <div>
      <%= f.label :phone, class: label_classes %>
      <%= f.telephone_field :phone, class: input_classes %>
    </div>
    <div class="sm:col-span-2">
      <%= f.label :contact_email, "Contact email", class: label_classes %>
      <%= f.email_field :contact_email, class: input_classes %>
    </div>
  </div>
  <div class="flex gap-3">
    <%= f.submit (company.persisted? ? "Save" : "Add contractor"), class: "btn-primary cursor-pointer" %>
    <%= link_to "Cancel", contractor_companies_path, class: "inline-flex items-center justify-center rounded-full bg-white text-talent-navy border border-talent-navy/10 px-7 py-3 text-sm font-semibold hover:bg-talent-mist transition" %>
  </div>
<% end %>
