                  <span class="rounded-lg border border-talent-navy/10 px-3 py-1 text-talent-muted">Medium</span>
                  <span class="rounded-lg border-2 border-talent-orange bg-talent-orange/10 text-talent-orange-700 px-3 py-1 font-semibold">High</span>
                </div>
              </div>

              <%# SLA date row %>
              <div class="flex items-center gap-4">
                <div class="flex items-center gap-2 w-32 text-talent-muted">
                  <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                  <span>SLA target</span>
                </div>
                <span class="text-talent-navy font-medium">22 May 2026</span>
              </div>

              <%# Status row %>
              <div class="flex items-center gap-4">
                <div class="flex items-center gap-2 w-32 text-talent-muted">
                  <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/></svg>
                  <span>Status</span>
                </div>
                <div class="inline-flex items-center gap-2 rounded-lg border border-talent-navy/10 px-3 py-1 text-talent-navy font-medium">
                  <span class="h-2 w-2 rounded-full bg-amber-500"></span>
                  In Progress
                  <svg class="h-3.5 w-3.5 text-talent-muted" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="6 9 12 15 18 9"/></svg>
                </div>
              </div>

              <%# Assignee row %>
              <div class="flex items-center gap-4">
                <div class="flex items-center gap-2 w-32 text-talent-muted">
                  <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8a4 4 0 0 1-4 4H10a4 4 0 0 1 0-8h4a4 4 0 0 1 4 4z"/><path d="M22 22V13"/></svg>
                  <span>Assigned</span>
                </div>
                <div class="inline-flex items-center gap-2 rounded-lg border border-talent-navy/10 px-2 py-1">
                  <span class="h-6 w-6 rounded-full bg-talent-orange text-white grid place-items-center text-xs font-bold">R</span>
                  <span class="text-talent-navy text-sm font-medium">Robson Plumbing</span>
                  <svg class="h-3.5 w-3.5 text-talent-muted" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="6 9 12 15 18 9"/></svg>
                </div>
              </div>
            </div>

            <%# Divider %>
            <div class="my-6 h-px bg-talent-navy/10"></div>

            <%# Checklist %>
            <ul class="space-y-3">
              <li class="flex items-center gap-3">
                <span class="h-5 w-5 rounded bg-talent-navy text-white grid place-items-center">
                  <svg class="h-3 w-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                </span>
                <span class="text-talent-muted line-through">Photos uploaded by site manager</span>
              </li>
              <li class="flex items-center gap-3">
                <span class="h-5 w-5 rounded border-2 border-talent-navy/20"></span>
                <span class="text-talent-navy">Trade accepted appointment slot</span>
              </li>
              <li class="flex items-center gap-3">
                <span class="h-5 w-5 rounded border-2 border-talent-navy/20"></span>
                <span class="text-talent-navy">Resident sign-off via magic link</span>
              </li>
            </ul>

            <%# Comments tab heading %>
            <div class="mt-7 border-b border-talent-navy/10 flex gap-6 text-sm">
              <button class="pb-2 font-semibold text-talent-navy border-b-2 border-talent-orange -mb-px">Comments &amp; Activity</button>
              <button class="pb-2 text-talent-muted">Files</button>
              <button class="pb-2 text-talent-muted">Audit</button>
            </div>

            <%# Comment %>
            <div class="mt-5 flex gap-3">
              <span class="h-9 w-9 rounded-full bg-gradient-to-br from-talent-orange to-talent-orange-600 grid place-items-center text-white text-xs font-bold flex-shrink-0">P</span>
              <div class="flex-1">
                <p class="text-sm text-talent-navy leading-relaxed">
                  <a class="text-talent-blue font-semibold">@robson-plumbing</a>
                  on site Thursday 11:00 — bringing replacement valve and a backup tail piece, all good for resident
                </p>
                <div class="mt-2 inline-flex items-center gap-2 rounded-lg bg-talent-mist px-2.5 py-1.5 text-xs font-medium text-talent-navy">
                  <span class="h-6 w-6 rounded bg-talent-blue grid place-items-center text-white text-[10px] font-bold">PDF</span>
                  Site_access_notes.pdf
                  <svg class="h-3 w-3 text-talent-muted" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                </div>
              </div>
            </div>
          </div>

          <%# Floating accent badge %>
          <div class="hidden md:flex absolute -top-3 -right-3 items-center gap-1.5 rounded-full bg-talent-orange text-white px-3 py-1.5 text-xs font-semibold shadow-[var(--shadow-glow-orange)]">
            <span class="relative flex h-1.5 w-1.5">
              <span class="absolute inline-flex h-full w-full rounded-full bg-white opacity-75 animate-ping"></span>
              <span class="relative inline-flex h-1.5 w-1.5 rounded-full bg-white"></span>
            </span>
            Live
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<%# ============== TESTIMONIALS (single-card slider, Uniflow style) ============== %>
<section class="section bg-talent-mist">
  <div class="mx-auto max-w-6xl px-5 sm:px-8" data-controller="reveal">
    <div class="text-center reveal">
      <span class="eyebrow">From the pilot</span>
      <h2 class="mt-4 font-display text-4xl sm:text-5xl font-extrabold tracking-tight">Customer testimonials</h2>
    </div>

    <% testimonials = [
         { file: "photos/eleanor-marshall.png", quote: "With SnagRadar, everything just syncs automatically to my workflow. It feels like I have an extra team member handling the repetitive stuff for me.", name: "Eleanor Marshall", role: "Customer Care Lead, PMC" },
         { file: "photos/daniel-thornton.png",  quote: "I log a defect on site with one photo and three taps. The trade gets it, accepts, books — I see the whole thing from my pocket.",                  name: "Daniel Thornton",  role: "Site Manager, Adur Shoreham" },
         { file: "photos/marisa-kovacs.png",    quote: "The resident sign-off link is the killer feature. No more chasing paper forms or waiting on a clipboard.",                                          name: "Marisa Kovacs",    role: "Aftercare Manager" },
         { file: "photos/phil-roberts.png",     quote: "It's the first defect tool my trades didn't complain about. Big tap targets, no logins, no app to install.",                                        name: "Phil Roberts",     role: "Subcontractor, Plumbing" }
       ] %>

    <div
      class="mt-12 reveal"
      data-controller="carousel"
      data-carousel-auto-value="true"
      data-carousel-interval-value="8000"
      style="transition-delay: .1s"
    >
      <div class="overflow-hidden rounded-[2rem]">
        <div class="flex transition-transform duration-700 ease-out" data-carousel-target="track">
          <% testimonials.each do |t| %>
            <article data-carousel-target="slide" class="min-w-full">
              <div class="grid lg:grid-cols-12 bg-white shadow-card overflow-hidden">
                <%# Portrait %>
                <div class="lg:col-span-5 relative aspect-[4/5] lg:aspect-auto bg-talent-navy">
                  <%= image_tag t[:file], alt: t[:name], class: "absolute inset-0 w-full h-full object-cover" %>
                  <div class="absolute top-5 left-5 h-12 w-12 rounded-2xl bg-talent-orange grid place-items-center text-white shadow-[var(--shadow-glow-orange)]">
                    <svg class="h-6 w-6" viewBox="0 0 24 24" fill="currentColor"><path d="M9 7H5a2 2 0 0 0-2 2v6h6V9H7c0-1.1.9-2 2-2V7zm10 0h-4a2 2 0 0 0-2 2v6h6V9h-2c0-1.1.9-2 2-2V7z"/></svg>
                  </div>
                </div>
                <%# Quote %>
                <div class="lg:col-span-7 p-8 sm:p-12 lg:p-14 flex flex-col">
                  <div class="flex gap-1 text-amber-400">
                    <% 5.times do %><svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor"><polygon points="12,2 15,9 22,9 16,13 18,21 12,17 6,21 8,13 2,9 9,9"/></svg><% end %>
                  </div>
                  <blockquote class="mt-6 font-display text-2xl sm:text-3xl font-bold leading-snug tracking-tight text-talent-navy">
                    &ldquo;<%= t[:quote] %>&rdquo;
                  </blockquote>
                  <figcaption class="mt-auto pt-8">
                    <div class="font-display text-lg font-extrabold text-talent-navy"><%= t[:name] %></div>
                    <div class="text-sm text-talent-muted"><%= t[:role] %></div>
                  </figcaption>
                </div>
              </div>
            </article>
          <% end %>
        </div>
      </div>

      <%# Controls: dots + arrows %>
      <div class="mt-8 flex items-center justify-center gap-6">
        <button type="button" data-action="carousel#prev" class="h-12 w-12 rounded-full bg-white shadow-soft grid place-items-center text-talent-navy hover:bg-talent-navy hover:text-white transition" aria-label="Previous testimonial">
          <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
        </button>

        <div class="flex items-center gap-2">
          <% testimonials.each_with_index do |_, i| %>
            <button
              type="button"
              data-action="carousel#go"
              data-index="<%= i %>"
              data-carousel-target="dot"
              class="h-2 rounded-full transition-all <%= i == 0 ? 'w-8 bg-talent-navy' : 'w-2 bg-talent-navy/20' %>"
              aria-label="Go to testimonial <%= i + 1 %>"
            ></button>
          <% end %>
        </div>

        <button type="button" data-action="carousel#next" class="h-12 w-12 rounded-full bg-talent-navy text-white shadow-soft grid place-items-center hover:bg-talent-orange transition" aria-label="Next testimonial">
          <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
        </button>
      </div>
    </div>
  </div>
</section>

<%# ============== CONNECT WITHOUT LIMITS — integrations spider diagram ============== %>
<section class="bg-white relative overflow-hidden py-24 sm:py-32">
  <%# Soft ambient backdrop %>
  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 h-[36rem] w-[36rem] rounded-full bg-gradient-to-br from-talent-orange/10 via-transparent to-talent-blue/10 blur-3xl"></div>
  </div>

  <div class="relative mx-auto max-w-7xl px-5 sm:px-8" data-controller="reveal">
    <div class="text-center max-w-3xl mx-auto reveal">
      <h2 class="font-display text-5xl sm:text-6xl lg:text-7xl font-extrabold tracking-tighter leading-[1.02] text-talent-navy">Connect without limits</h2>
      <p class="mt-5 mx-auto max-w-xl text-lg text-talent-slate leading-relaxed">
        From inbox and calendar to Slack and Stripe, SnagRadar plugs into the tools your customer-care team already uses — no IT ticket required.
      </p>
    </div>

    <%# Diagram — large screens show the spider; small screens get a grid fallback %>
    <div class="relative mt-14 reveal" style="transition-delay: .1s">

      <%# DESKTOP: positioned tiles + SVG lines + central hub %>
      <div class="hidden lg:block relative h-[560px]">
        <%# Connection lines layer %>
        <svg class="absolute inset-0 w-full h-full" viewBox="0 0 1200 560" fill="none" preserveAspectRatio="none" aria-hidden="true">
          <defs>
            <linearGradient id="grad-orange" x1="0" x2="1" y1="0" y2="0">
              <stop offset="0"   stop-color="#FC5A07" stop-opacity=".15"/>
              <stop offset=".5"  stop-color="#FC5A07" stop-opacity=".55"/>
              <stop offset="1"   stop-color="#FC5A07" stop-opacity=".15"/>
            </linearGradient>
            <linearGradient id="grad-blue" x1="0" x2="1" y1="0" y2="0">
              <stop offset="0"   stop-color="#0057AE" stop-opacity=".15"/>
              <stop offset=".5"  stop-color="#0057AE" stop-opacity=".55"/>
              <stop offset="1"   stop-color="#0057AE" stop-opacity=".15"/>
            </linearGradient>
            <linearGradient id="grad-violet" x1="0" x2="1" y1="0" y2="0">
              <stop offset="0"   stop-color="#7c3aed" stop-opacity=".15"/>
              <stop offset=".5"  stop-color="#7c3aed" stop-opacity=".55"/>
              <stop offset="1"   stop-color="#7c3aed" stop-opacity=".15"/>
            </linearGradient>
          </defs>
          <%# Left-side connections fan in to (600,280) %>
          <path d="M 110,100 C 280,140 480,260 600,280" stroke="url(#grad-orange)" stroke-width="2"/>
          <path d="M 60,260  C 250,265 460,275 600,280"  stroke="url(#grad-blue)"   stroke-width="2"/>
          <path d="M 110,420 C 280,400 480,310 600,280" stroke="url(#grad-violet)" stroke-width="2"/>
          <path d="M 230,80  C 340,140 500,240 600,280" stroke="url(#grad-blue)"   stroke-width="2"/>
          <%# Right-side connections %>
          <path d="M 1090,100 C 920,140 720,260 600,280" stroke="url(#grad-orange)" stroke-width="2"/>
          <path d="M 1140,260 C 950,265 740,275 600,280" stroke="url(#grad-violet)" stroke-width="2"/>
          <path d="M 1090,420 C 920,400 720,310 600,280" stroke="url(#grad-blue)"   stroke-width="2"/>
          <path d="M 970,80   C 860,140 700,240 600,280" stroke="url(#grad-orange)" stroke-width="2"/>
        </svg>

        <%# Brand tiles positioned absolutely. Each tile shows a small label outside the white square. %>
        <% tiles = [
             { brand: "gmail",           label: "Email intake",      pos: "left-[6%]   top-[12%]" },
             { brand: "slack",           label: "Slack",             pos: "left-[16%]  top-[2%]"  },
             { brand: "whatsapp",        label: "WhatsApp",          pos: "left-[2%]   top-[42%]" },
             { brand: "outlook",         label: "Outlook",           pos: "left-[6%]   bottom-[8%]" },

             { brand: "google-calendar", label: "Calendar",          pos: "right-[6%]  top-[12%]" },
             { brand: "teams",           label: "MS Teams",          pos: "right-[16%] top-[2%]"  },
             { brand: "stripe",          label: "Stripe billing",    pos: "right-[2%]  top-[42%]" },
             { brand: "zapier",          label: "Zapier",            pos: "right-[6%]  bottom-[8%]" }
           ] %>
        <% tiles.each_with_index do |t, i| %>
          <div class="absolute <%= t[:pos] %> group">
            <div class="h-20 w-20 rounded-2xl bg-white shadow-[0_18px_36px_-12px_rgba(2,32,67,0.18)] ring-1 ring-talent-navy/5 grid place-items-center transition-transform duration-300 group-hover:-translate-y-1 group-hover:shadow-[0_24px_44px_-12px_rgba(2,32,67,0.28)]">
              <%= image_tag "icons/brands/#{t[:brand]}.svg", alt: t[:label], class: "h-11 w-11" %>
            </div>
            <div class="absolute left-1/2 -translate-x-1/2 top-full mt-2 text-xs font-semibold text-talent-muted whitespace-nowrap opacity-0 group-hover:opacity-100 transition"><%= t[:label] %></div>
          </div>
        <% end %>

        <%# Central hub — SnagRadar mark with concentric pulse rings %>
        <div class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2">
          <div class="relative">
            <span class="absolute inset-0 m-auto h-56 w-56 rounded-full bg-talent-orange/10 blur-2xl"></span>
            <%# Three concentric rings with subtle gradient stroke %>
            <svg class="absolute inset-0 m-auto h-52 w-52" viewBox="0 0 200 200" fill="none">
              <circle cx="100" cy="100" r="95" stroke="url(#grad-orange)" stroke-width="1"/>
              <circle cx="100" cy="100" r="72" stroke="url(#grad-blue)"   stroke-width="1"/>
              <circle cx="100" cy="100" r="50" stroke="url(#grad-violet)" stroke-width="1"/>
            </svg>
            <%# Outer ring with brand gradient %>
            <div class="relative h-36 w-36 rounded-full p-[3px]"
                 style="background: conic-gradient(from 0deg, #FC5A07, #FF8B47, #FFC57A, #0057AE, #7c3aed, #FC5A07);">
              <div class="h-full w-full rounded-full bg-white grid place-items-center shadow-[0_20px_50px_-12px_rgba(252,90,7,0.45)]">
                <%= image_tag "snagradar-icon.png", alt: "SnagRadar", class: "h-20 w-20 object-contain" %>
              </div>
            </div>
          </div>
        </div>
      </div>

      <%# MOBILE / tablet fallback: grid of tiles with the radar hub in the middle row %>
      <div class="lg:hidden grid grid-cols-3 gap-4 sm:gap-5 max-w-md mx-auto">
        <% mobile_brands = %w[gmail slack whatsapp outlook google-calendar teams stripe zapier] %>
        <% mobile_brands.first(4).each do |b| %>
          <div class="aspect-square rounded-2xl bg-white shadow-soft ring-1 ring-talent-navy/5 grid place-items-center">
            <%= image_tag "icons/brands/#{b}.svg", alt: b, class: "h-10 w-10" %>
          </div>
        <% end %>
        <%# Center hub %>
        <div class="aspect-square col-span-1 row-span-1 relative">
          <div class="absolute inset-0 rounded-full p-[3px]" style="background: conic-gradient(from 0deg, #FC5A07, #FF8B47, #0057AE, #7c3aed, #FC5A07);">
            <div class="h-full w-full rounded-full bg-white grid place-items-center">
              <%= image_tag "snagradar-icon.png", alt: "SnagRadar", class: "h-14 w-14 object-contain" %>
            </div>
          </div>
        </div>
        <% mobile_brands.last(4).each do |b| %>
          <div class="aspect-square rounded-2xl bg-white shadow-soft ring-1 ring-talent-navy/5 grid place-items-center">
            <%= image_tag "icons/brands/#{b}.svg", alt: b, class: "h-10 w-10" %>
          </div>
        <% end %>
      </div>
    </div>

    <%# Small tagline below diagram %>
    <div class="mt-10 text-center text-sm text-talent-muted reveal" style="transition-delay: .25s">
      Plus webhooks, REST API, SSO &amp; more.
      <%= link_to "See all integrations →", features_path, class: "text-talent-orange font-semibold hover:text-talent-orange-700 transition ml-1" %>
    </div>
  </div>
</section>

<%# ============== WORKFLOW ============== %>
<section class="section bg-talent-navy text-white relative overflow-hidden">
  <div class="absolute inset-0 bp-grid opacity-40 pointer-events-none"></div>
  <%# Layered ambient glow %>
  <div class="absolute -top-40 right-1/4 h-[28rem] w-[28rem] rounded-full bg-talent-orange/20 blur-3xl pointer-events-none"></div>
  <div class="absolute -bottom-40 -left-32 h-[28rem] w-[28rem] rounded-full bg-talent-blue/30 blur-3xl pointer-events-none"></div>

  <div class="relative mx-auto max-w-7xl px-5 sm:px-8" data-controller="reveal">
    <div class="max-w-3xl reveal">
      <span class="inline-flex items-center gap-2 rounded-full bg-white/10 px-3 py-1 text-xs font-semibold tracking-wide uppercase ring-1 ring-white/20 text-white">The workflow</span>
      <h2 class="mt-5 font-display text-4xl sm:text-5xl lg:text-6xl font-extrabold tracking-tight leading-[1.05] text-white">From resident report to <span class="text-talent-orange">digital sign-off</span> — without leaving the radar.</h2>
      <p class="mt-5 text-lg text-white/70 leading-relaxed">Five steps. One timeline. Every status, photo and signature stored as immutable evidence.</p>
    </div>

    <%# Connector line behind cards, desktop only %>
    <div class="relative mt-14 reveal" style="transition-delay: .1s">
      <div class="hidden lg:block absolute left-0 right-0 top-[3.5rem] h-px bg-gradient-to-r from-transparent via-talent-orange/40 to-transparent pointer-events-none"></div>

      <div class="grid md:grid-cols-2 lg:grid-cols-5 gap-4">
        <% steps = [
             { num: "01", icon: "home",       title: "Resident reports",   body: "Issue comes in by phone, email or via Hyde / customer-care channel." },
             { num: "02", icon: "inspection", title: "Care logs defect",   body: "PMC adds plot, trade, photos, Hyde reference and SLA target date." },
             { num: "03", icon: "handshake",  title: "Trade accepts",      body: "Contractor accepts in one tap. Proposes an appointment from mobile." },
             { num: "04", icon: "camera",     title: "Work + evidence",    body: "Trade attends, uploads completion photos and any notes." },
             { num: "05", icon: "signature",  title: "Resident signs off", body: "Tokenised magic link. Digital signature. Defect closes itself." }
           ] %>
        <% steps.each do |s| %>
          <div class="relative rounded-2xl bg-white/[0.04] ring-1 ring-white/10 backdrop-blur-sm p-6 hover:bg-white/[0.07] hover:ring-talent-orange/30 transition-all group">
            <%# Icon tile %>
            <div class="relative h-14 w-14 rounded-2xl bg-gradient-to-br from-talent-orange/25 to-talent-orange/10 ring-1 ring-talent-orange/40 grid place-items-center text-talent-orange group-hover:scale-110 group-hover:shadow-[0_8px_22px_-6px_rgba(252,90,7,0.55)] transition-all">
              <%= icon s[:icon], class: "h-7 w-7" %>
            </div>
            <%# Step number absolute top-right %>
            <div class="absolute top-5 right-5 font-mono text-[11px] font-bold tracking-widest text-talent-orange/70"><%= s[:num] %></div>
            <h3 class="mt-5 font-display text-lg font-extrabold text-white"><%= s[:title] %></h3>
            <p class="mt-2 text-sm text-white/65 leading-relaxed"><%= s[:body] %></p>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</section>

<%# ============== FEATURES GRID ============== %>
<section class="section bg-white">
  <div class="mx-auto max-w-7xl px-5 sm:px-8" data-controller="reveal">
    <div class="text-center max-w-2xl mx-auto reveal">
      <span class="eyebrow">Everything you need</span>
      <h2 class="mt-4 font-display text-4xl sm:text-5xl font-extrabold tracking-tight leading-[1.05]">Defect management without the spreadsheet tax.</h2>
      <p class="mt-5 text-lg text-talent-slate leading-relaxed">Built around real customer-care workflows, not generic project management.</p>
    </div>

    <div class="mt-14 grid md:grid-cols-2 lg:grid-cols-3 gap-5 reveal" style="transition-delay: .1s">
      <% features = [
           { icon: "inspection", title: "Two-minute defect intake",       body: "Site, plot, trade, priority, Hyde reference, photos. From form to assigned trade in under two minutes." },
           { icon: "satellite",  title: "Live Radar dashboard",           body: "Traffic-light SLA view. Configurable amber threshold. Filters by site, trade, contractor, status.", accent: true },
           { icon: "smartphone", title: "Mobile-first contractor portal", body: "Trades accept, book appointments and upload completion photos from a phone — no app install." },
           { icon: "timer",      title: "SLA timers + auto reminders",    body: "Solid Queue jobs fire reminders before breach. Overdue items escalate to a finishing manager." },
           { icon: "signature",  title: "Tokenised resident sign-off",    body: "Expiring magic links, captured digital signature, evidence stored against the defect." },
           { icon: "shield",     title: "Immutable audit timeline",       body: "Every status change, comment, photo and signature is timestamped, attributed and unchangeable." }
         ] %>
      <% features.each do |f| %>
        <% accent = f[:accent] %>
        <article class="<%= accent ? 'card-accent-orange text-white' : 'card-surface hover:-translate-y-1 hover:shadow-card' %> p-7 relative overflow-hidden transition group">
          <% if accent %><div class="absolute inset-0 bp-grid opacity-30 pointer-events-none"></div><% end %>
          <div class="relative">
            <div class="h-14 w-14 rounded-2xl <%= accent ? 'bg-white/20 ring-1 ring-white/30 text-white' : 'bg-talent-orange-50 text-talent-orange-700' %> grid place-items-center group-hover:scale-110 transition-transform">
              <%= icon f[:icon], class: "h-7 w-7" %>
            </div>
            <h3 class="mt-5 font-display text-xl font-extrabold <%= accent ? 'text-white' : 'text-talent-navy' %>"><%= f[:title] %></h3>
            <p class="mt-2 text-sm leading-relaxed <%= accent ? 'text-white/90' : 'text-talent-slate' %>"><%= f[:body] %></p>
          </div>
        </article>
      <% end %>
    </div>

    <div class="mt-10 text-center">
      <%= link_to "Explore the full feature set", features_path, class: "link-arrow text-base" %>
    </div>
  </div>
</section>

<%# ============== FAQ ============== %>
<section class="section bg-talent-mist">
  <div class="mx-auto max-w-4xl px-5 sm:px-8" data-controller="reveal faq">
    <div class="text-center reveal">
      <h2 class="font-display text-4xl sm:text-5xl font-extrabold tracking-tight">FAQs</h2>
    </div>

    <div class="mt-12 space-y-3 reveal" style="transition-delay: .1s">
      <% faqs = [
           { q: "How is SnagRadar different from a project management tool?",
             a: "We're built specifically for construction aftercare — defects, SLAs, trade routing, evidence and resident sign-off. Not generic tasks." },
           { q: "Do my subcontractors need to install an app?",
             a: "No. The contractor portal is a mobile web experience — they tap a link, accept the defect, book an appointment and upload photos." },
           { q: "How does the resident sign-off work?",
             a: "We send the resident a tokenised magic link. They open it on their phone, see the completion photos, draw their signature, and the defect closes." },
           { q: "Can I customise SLAs by trade or priority?",
             a: "Yes. Each trade has a default SLA. You can override per-priority or per-site, and configure the amber threshold." },
           { q: "Is my data secure?",
             a: "Encrypted in transit and at rest. Role-based access. Contractors only see defects assigned to their company." },
           { q: "Does it work offline on site?",
             a: "We use Hotwire to keep the UI snappy, and uploads queue when signal is poor. Full offline mode is on the roadmap." }
         ] %>
      <% faqs.each do |f| %>
        <div class="rounded-2xl bg-white" data-faq-target="item">
          <button class="w-full flex items-center justify-between gap-4 p-5 text-left" data-action="click->faq#toggle">
            <span class="font-display text-lg font-semibold"><%= f[:q] %></span>
            <span class="flex-shrink-0 h-8 w-8 rounded-full bg-talent-mist grid place-items-center text-talent-orange transition-transform" data-faq-target="icon">
              <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            </span>
          </button>
          <div class="hidden px-5 pb-5 text-talent-slate leading-relaxed" data-faq-target="body"><%= f[:a] %></div>
        </div>
      <% end %>
    </div>
  </div>
</section>

<%# ============== FINAL CTA (Uniflow gradient card with floating trade icons) ============== %>
<section class="bg-white pt-12 pb-24">
  <div class="mx-auto max-w-7xl px-5 sm:px-8">
    <div class="relative cta-gradient overflow-hidden px-6 py-16 sm:p-16 lg:p-20 min-h-[460px]">
      <%# Floating decorative trade icons in white circles, like Uniflow's app icons %>
      <% float_icons = [
           { name: "lightning", tint: "text-amber-500",         pos: "left-[6%]   top-[18%]",    delay: "0s"   },
           { name: "plumbing",  tint: "text-talent-blue",       pos: "left-[28%]  top-[8%]",     delay: ".7s"  },
           { name: "home",      tint: "text-talent-navy",       pos: "left-[8%]   bottom-[15%]", delay: "1.4s" },
           { name: "tile",      tint: "text-emerald-600",       pos: "right-[28%] top-[8%]",     delay: ".4s"  },
           { name: "roller",    tint: "text-violet-600",        pos: "right-[6%]  bottom-[18%]", delay: "1.1s" },
           { name: "hammer",    tint: "text-talent-orange-700", pos: "right-[8%]  top-[20%]",    delay: "1.8s" }
         ] %>
      <% float_icons.each do |fi| %>
        <div class="absolute <%= fi[:pos] %> h-16 w-16 rounded-full bg-white shadow-[0_12px_28px_-8px_rgba(2,32,67,0.25)] hidden md:grid place-items-center animate-[float_6s_ease-in-out_infinite] <%= fi[:tint] %>" style="animation-delay: <%= fi[:delay] %>;">
          <%= icon fi[:name], class: "h-8 w-8" %>
        </div>
      <% end %>

      <div class="relative text-center max-w-3xl mx-auto">
        <h2 class="font-display text-4xl sm:text-5xl lg:text-6xl font-extrabold tracking-tighter leading-[1.02] text-white">Ready to get started?</h2>
        <p class="mt-5 mx-auto max-w-xl text-lg text-white/90 leading-relaxed">
          Book a 20-minute walkthrough. We'll show you the radar, log a real defect, and answer everything about pilot pricing.
        </p>
        <div class="mt-9 flex justify-center">
          <%= link_to "Get Started for Free", contact_path, class: "btn-dark" %>
        </div>
      </div>
    </div>
  </div>
</section>
