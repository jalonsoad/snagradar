<% content_for :title, "SnagRadar — Defects on the radar. Trades on the move." %>
<% content_for :description, "Replace spreadsheets, inboxes and WhatsApp with one mobile-first command centre for construction defects, SLAs and resident sign-off." %>

<%# ============== HERO (Uniflow style: centered, white bg, dashboard image below) ============== %>
<section class="relative bg-white overflow-hidden pt-32 sm:pt-40 lg:pt-44 pb-24 sm:pb-32">
  <div class="absolute inset-0 hero-backdrop pointer-events-none"></div>

  <div class="relative mx-auto max-w-5xl px-5 sm:px-8 text-center" data-controller="reveal">
    <div class="reveal">
      <span class="inline-flex items-center gap-2 rounded-full bg-talent-mist text-talent-navy px-3 py-1 text-xs font-semibold tracking-wide uppercase ring-1 ring-talent-navy/5">
        <span class="relative flex h-2 w-2">
          <span class="absolute inline-flex h-full w-full rounded-full bg-talent-orange opacity-75 animate-ping"></span>
          <span class="relative inline-flex h-2 w-2 rounded-full bg-talent-orange"></span>
        </span>
        Now in private pilot · Construction aftercare
      </span>

      <h1 class="mt-6 font-display text-5xl sm:text-6xl lg:text-7xl font-extrabold tracking-tighter leading-[1.02] text-talent-navy">
        Defects on the radar.<br>
        <span class="text-talent-orange">Trades on the move.</span>
      </h1>

      <p class="mt-6 mx-auto max-w-2xl text-lg sm:text-xl text-talent-slate leading-relaxed">
        Replace inboxes, spreadsheets and WhatsApp threads with one mobile-first command centre. Track every defect from intake to resident sign-off — with SLAs, evidence and audit trails baked in.
      </p>

      <div class="mt-9 flex flex-wrap items-center justify-center gap-3">
        <%= link_to "Book a demo", contact_path, class: "btn-primary" %>
        <%= link_to "#radar", class: "btn-dark" do %>
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor"><polygon points="6,4 20,12 6,20"/></svg>
          See the Radar
        <% end %>
      </div>
    </div>

    <%# Arc of trade icons connecting to a central hub — Uniflow integrations pattern %>
    <div class="relative mt-16 sm:mt-20 reveal" style="transition-delay: .15s">
      <svg viewBox="0 0 720 200" class="mx-auto w-full max-w-2xl" aria-hidden="true">
        <defs>
          <linearGradient id="arc-grad" x1="0" x2="1" y1="0" y2="0">
            <stop offset="0" stop-color="#0057AE" stop-opacity=".15"/>
            <stop offset=".5" stop-color="#FC5A07" stop-opacity=".7"/>
            <stop offset="1" stop-color="#0057AE" stop-opacity=".15"/>
          </linearGradient>
        </defs>
        <%# Curved lines from each icon to the central hub %>
        <path d="M60,80 C220,180 280,180 360,180" fill="none" stroke="url(#arc-grad)" stroke-width="1.5"/>
        <path d="M180,40 C260,140 320,180 360,180" fill="none" stroke="url(#arc-grad)" stroke-width="1.5"/>
        <path d="M360,20 L360,180" fill="none" stroke="url(#arc-grad)" stroke-width="1.5"/>
        <path d="M540,40 C460,140 400,180 360,180" fill="none" stroke="url(#arc-grad)" stroke-width="1.5"/>
        <path d="M660,80 C500,180 440,180 360,180" fill="none" stroke="url(#arc-grad)" stroke-width="1.5"/>
      </svg>
      <%# Trade icons positioned absolutely along the arc — inline Icons8 SVGs with currentColor %>
      <div class="absolute inset-0">
        <% trades = [
             { name: "plumbing",  tint: "bg-talent-blue/15 text-talent-blue",            pos: "left-[5%]   top-[18%]" },
             { name: "lightning", tint: "bg-amber-100       text-amber-600",             pos: "left-[24%]  top-[2%]"  },
             { name: "hammer",    tint: "bg-talent-orange-100 text-talent-orange-700",   pos: "left-1/2 -translate-x-1/2 top-[-10%]" },
             { name: "tile",      tint: "bg-emerald-100     text-emerald-600",           pos: "right-[24%] top-[2%]"  },
             { name: "roller",    tint: "bg-violet-100      text-violet-600",            pos: "right-[5%]  top-[18%]" }
           ] %>
        <% trades.each do |t| %>
          <div class="absolute <%= t[:pos] %> h-16 w-16 rounded-2xl bg-white shadow-card grid place-items-center transition hover:-translate-y-1">
            <div class="h-11 w-11 rounded-xl <%= t[:tint] %> grid place-items-center">
              <%= icon t[:name], class: "h-7 w-7" %>
            </div>
          </div>
        <% end %>
        <%# Central hub: SnagRadar icon %>
        <div class="absolute left-1/2 -translate-x-1/2 bottom-0 h-20 w-20 rounded-3xl bg-white shadow-[var(--shadow-glow-orange)] grid place-items-center ring-1 ring-talent-navy/5">
          <%= image_tag "snagradar-icon.png", alt: "", class: "h-14 w-14 object-contain", aria: { hidden: true } %>
        </div>
      </div>
    </div>

    <%# Big centered dashboard image (Uniflow's "screenshot below" pattern) %>
    <div class="relative mt-20 sm:mt-28 reveal" style="transition-delay: .25s">
      <%# Gradient peeking from sides %>
      <div class="absolute -inset-6 -z-10">
        <div class="absolute inset-y-8 -left-6 w-1/3 rounded-3xl bg-gradient-to-br from-talent-orange/30 to-talent-blue/30 blur-2xl"></div>
        <div class="absolute inset-y-8 -right-6 w-1/3 rounded-3xl bg-gradient-to-bl from-talent-blue/30 to-talent-orange/30 blur-2xl"></div>
      </div>

      <div class="relative rounded-3xl bg-talent-navy text-white shadow-[0_30px_60px_-20px_rgba(2,32,67,0.45)] overflow-hidden ring-1 ring-talent-navy/10">
        <%# Chrome bar %>
        <div class="px-5 py-3 flex items-center justify-between border-b border-white/10">
          <div class="flex items-center gap-2">
            <span class="h-2.5 w-2.5 rounded-full bg-red-400/80"></span>
            <span class="h-2.5 w-2.5 rounded-full bg-amber-400/80"></span>
            <span class="h-2.5 w-2.5 rounded-full bg-emerald-400/80"></span>
          </div>
          <div class="text-xs font-mono text-white/55">app.snagradar.co.uk/radar</div>
          <div class="text-xs text-white/40">●●●</div>
        </div>

        <%# Dashboard body %>
        <div class="p-6 sm:p-8 bg-white text-talent-navy">
          <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-3 mb-6 text-left">
            <div>
              <div class="text-xs font-semibold uppercase tracking-wider text-talent-muted">Live Radar — Adur Shoreham</div>
              <div class="font-display text-2xl font-extrabold mt-0.5">14 open defects</div>
            </div>
            <div class="flex items-center gap-2">
              <span class="sla-amber"><span class="dot bg-amber-500"></span> 3 approaching breach</span>
              <span class="sla-red"><span class="dot bg-red-500"></span> 2 overdue</span>
            </div>
          </div>

          <%# KPI grid %>
          <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-6">
            <% [
                 { label: "Open",         value: 14,  bg: "bg-talent-navy text-white"       },
                 { label: "Overdue",      value: 2,   bg: "bg-red-100 text-red-700"         },
                 { label: "≤48h SLA",     value: 3,   bg: "bg-amber-100 text-amber-700"     },
                 { label: "Signed off",   value: 22,  bg: "bg-emerald-100 text-emerald-700" }
               ].each do |k| %>
              <div class="rounded-2xl p-4 <%= k[:bg] %> text-left">
                <div class="text-[10px] font-semibold uppercase tracking-wider opacity-80"><%= k[:label] %></div>
                <div class="font-display text-3xl font-extrabold mt-1"><%= k[:value] %></div>
              </div>
            <% end %>
          </div>

          <%# Defect rows %>
          <div class="space-y-2 text-left">
            <% defects = [
                 { ref: "HY-2487", plot: "Plot 14", trade: "Plumbing",   title: "Leak under sink — kitchen",  sla: :red,   due: "2 days overdue" },
                 { ref: "HY-2491", plot: "Plot 02", trade: "Electrical", title: "Hallway light flickering",   sla: :amber, due: "Due in 36h" },
                 { ref: "HY-2495", plot: "Plot 08", trade: "Decorating", title: "Touch-up paint, master bed", sla: :green, due: "On track" }
               ] %>
            <% defects.each do |d| %>
              <div class="flex items-center gap-3 rounded-xl border border-talent-navy/5 bg-white p-3 hover:shadow-soft transition">
                <div class="h-9 w-9 rounded-lg bg-talent-mist grid place-items-center text-talent-navy flex-shrink-0">
                  <svg class="h-4.5 w-4.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 21l6-6"/><path d="M9 15l9-9 3 3-9 9z"/></svg>
                </div>
                <div class="flex-1 min-w-0">
                  <div class="flex items-center gap-2 text-xs text-talent-muted">
                    <span class="font-mono"><%= d[:ref] %></span>
                    <span>·</span><span><%= d[:plot] %></span>
                    <span>·</span><span><%= d[:trade] %></span>
                  </div>
                  <div class="text-sm font-semibold text-talent-navy truncate"><%= d[:title] %></div>
                </div>
                <span class="<%= "sla-#{d[:sla]}" %>">
                  <span class="dot <%= { red: 'bg-red-500', amber: 'bg-amber-500', green: 'bg-emerald-500' }[d[:sla]] %>"></span>
                  <%= d[:due] %>
                </span>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<%# ============== LOGO STRIP — editorial / hand-drawn flourish ============== %>
<section class="bg-white pb-24 relative">
  <div class="mx-auto max-w-7xl px-5 sm:px-8">
    <%# Hand-drawn label tilted, with curved arrow pointing at the marquee %>
    <div class="relative h-16 mb-4 hidden md:block" aria-hidden="true">
      <div class="absolute left-[10%] top-0 -rotate-[6deg] flex items-end gap-2">
        <svg class="h-7 w-7 text-talent-orange" viewBox="0 0 24 24" fill="currentColor"><polygon points="13 2 4 14 11 14 9 22 20 10 13 10 13 2"/></svg>
        <span style="font-family: var(--font-handwritten);" class="text-3xl font-bold text-talent-navy leading-none">Builders love it</span>
      </div>
      <%# Hand-drawn curved arrow %>
      <svg class="absolute left-[26%] top-6 h-14 w-32 text-talent-navy" viewBox="0 0 200 80" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M5,15 C 50,5 90,25 130,55" stroke-dasharray="0" />
        <path d="M120,40 L130,55 L120,62" />
      </svg>
    </div>

    <%# Mixed-typography logo marquee — different fonts per "brand" for editorial feel %>
    <div class="marquee overflow-hidden">
      <div class="flex w-max items-center gap-14 animate-[marquee_42s_linear_infinite]">
        <% logos = [
             { name: "Hyde Group",              cls: "font-display text-3xl font-extrabold italic tracking-tight" },
             { name: "Adur Homes",              cls: "font-display text-3xl font-bold tracking-[-0.04em]" },
             { name: "PMC ◆ Care",              cls: "font-display text-3xl font-black uppercase tracking-[0.18em]" },
             { name: "northwall",                cls: "text-3xl font-light lowercase tracking-tight",                style: "font-family: var(--font-handwritten); font-size: 2.6rem;" },
             { name: "Stonecrest",              cls: "font-display text-3xl font-bold tracking-tight",                  serif: true },
             { name: "Bridgemoor",              cls: "font-display text-3xl font-extrabold tracking-tight" },
             { name: "THORNSBY",                cls: "font-display text-2xl font-black uppercase tracking-[0.32em]" },
             { name: "Caversham&nbsp;Build",    cls: "font-display text-3xl font-medium italic tracking-tight" }
           ] %>
        <% (logos + logos).each do |l| %>
          <div class="flex items-center gap-2.5 text-talent-navy/55 whitespace-nowrap hover:text-talent-navy transition-colors" style="<%= l[:style] %>">
            <% if l[:serif] %>
              <span style="font-family: Georgia, serif;" class="text-3xl font-bold"><%== l[:name] %></span>
            <% else %>
              <span class="<%= l[:cls] %>"><%== l[:name] %></span>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>

    <div class="mt-6 text-center text-xs font-semibold uppercase tracking-[0.25em] text-talent-muted">
      Built for builders, housing associations &amp; aftercare teams
    </div>
  </div>
</section>

<%# ============== PROBLEM ============== %>
<section class="section bg-talent-mist relative overflow-hidden">
  <div class="mx-auto max-w-7xl px-5 sm:px-8" data-controller="reveal">
    <div class="grid lg:grid-cols-12 gap-12 items-center">
      <div class="lg:col-span-5 reveal">
        <span class="eyebrow">The problem</span>
        <h2 class="mt-4 font-display text-4xl sm:text-5xl font-extrabold tracking-tight leading-[1.05]">
          Aftercare lives in <span class="line-through text-talent-muted/70">15 places</span>. None of them are accountable.
        </h2>
        <p class="mt-6 text-lg text-talent-slate leading-relaxed">
          Site managers WhatsApp the trade. Customer care emails the resident. Someone copies it into a spreadsheet. Nobody knows what's overdue, who promised what, or where the photos live.
        </p>
        <p class="mt-4 text-talent-slate">
          SnagRadar pulls every defect into one timeline — assignment, photos, appointment, completion, sign-off — so accountability is a column, not a guess.
        </p>
      </div>

      <div class="lg:col-span-7 reveal" style="transition-delay: .15s">
        <div class="grid grid-cols-2 gap-4">
          <% [
               { icon: "email",       tint: "bg-talent-blue/15  text-talent-blue",    title: "Inbox",        count: "412 unread",  note: "Lost defect threads" },
               { icon: "whatsapp",    tint: "bg-emerald-100     text-emerald-600",    title: "WhatsApp",     count: "9 groups",    note: "No audit, no SLA" },
               { icon: "spreadsheet", tint: "bg-amber-100       text-amber-700",      title: "Spreadsheets", count: "v17_final",   note: "Whose copy is right?" },
               { icon: "journal",     tint: "bg-violet-100      text-violet-600",     title: "Site notebook",count: "Handwritten", note: "Photos on someone's phone" }
             ].each do |c| %>
            <div class="card-surface p-5 hover:-translate-y-1 hover:shadow-card transition group">
              <div class="h-12 w-12 rounded-xl <%= c[:tint] %> grid place-items-center group-hover:scale-110 transition-transform">
                <%= icon c[:icon], class: "h-6 w-6" %>
              </div>
              <div class="mt-4 font-display text-lg font-extrabold"><%= c[:title] %></div>
              <div class="font-mono text-xs text-talent-orange mt-1"><%= c[:count] %></div>
              <div class="text-sm text-talent-muted mt-2"><%= c[:note] %></div>
            </div>
          <% end %>
        </div>

        <div class="mt-4 card-accent-navy p-6 relative overflow-hidden">
          <div class="absolute inset-0 bp-grid opacity-50 pointer-events-none"></div>
          <div class="relative flex items-center gap-4">
            <div class="h-14 w-14 rounded-2xl bg-talent-orange grid place-items-center text-white">
              <%= icon "arrow-right", class: "h-7 w-7" %>
            </div>
            <div>
              <div class="font-display text-xl font-extrabold">One radar. Every defect. Every owner.</div>
              <div class="text-talent-sky/80 text-sm mt-1">Web for office. Mobile for site. Magic links for residents.</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<%# ============== RADAR DASHBOARD (kept — SnagRadar specific) ============== %>
<section id="radar" class="section bg-white relative overflow-hidden">
  <div class="mx-auto max-w-7xl px-5 sm:px-8" data-controller="reveal">
    <div class="max-w-3xl mx-auto text-center reveal">
      <span class="eyebrow-blue">The Radar dashboard</span>
      <h2 class="mt-4 font-display text-4xl sm:text-5xl font-extrabold tracking-tight leading-[1.05]">
        Know what's open, who owns it, when it's due, and whether the resident has signed it off.
      </h2>
      <p class="mt-6 text-lg text-talent-slate leading-relaxed">
        A traffic-light operational view designed to be glanced at — not interpreted. Green is healthy, amber is approaching breach, red is overdue.
      </p>
    </div>

    <div class="mt-12 grid lg:grid-cols-12 gap-6 reveal" style="transition-delay: .1s">
      <div class="lg:col-span-8 relative rounded-3xl bg-talent-mist border border-talent-navy/5 overflow-hidden shadow-card">
        <div class="px-5 py-3.5 flex items-center justify-between border-b border-talent-navy/5 bg-white/80 backdrop-blur">
          <div class="flex items-center gap-3">
            <%= image_tag "snagradar-icon.png", class: "h-7 w-7 object-contain", alt: "" %>
            <div class="text-sm font-semibold">Live Radar — All sites</div>
          </div>
          <div class="hidden sm:flex items-center gap-2 text-xs text-talent-muted">
            <span class="dot bg-emerald-500 animate-pulse"></span>
            Updated 4s ago
          </div>
        </div>

        <div class="p-5 sm:p-7">
          <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
            <% [
                 { label: "Open",        value: 87, accent: "bg-talent-navy text-white"  },
                 { label: "Overdue",     value: 6,  accent: "bg-red-100 text-red-700"    },
                 { label: "≤48h to SLA", value: 11, accent: "bg-amber-100 text-amber-700"},
                 { label: "Signed off",  value: 134,accent: "bg-emerald-100 text-emerald-700"}
               ].each do |k| %>
              <div class="rounded-2xl p-4 <%= k[:accent] %>">
                <div class="text-xs font-semibold uppercase tracking-wide opacity-80"><%= k[:label] %></div>
                <div class="font-display text-3xl font-extrabold mt-1"><%= k[:value] %></div>
              </div>
            <% end %>
          </div>

          <div class="mt-7">
            <div class="flex items-center justify-between mb-3">
              <div class="text-sm font-semibold">Open defects by trade</div>
              <div class="flex items-center gap-3 text-xs text-talent-muted">
                <span class="flex items-center gap-1"><span class="dot bg-emerald-500"></span> Green</span>
                <span class="flex items-center gap-1"><span class="dot bg-amber-500"></span> Amber</span>
                <span class="flex items-center gap-1"><span class="dot bg-red-500"></span> Red</span>
              </div>
            </div>
            <% trades = [
                 { name: "Plumbing",   g: 12, a: 4, r: 2 },
                 { name: "Electrical", g: 8,  a: 3, r: 1 },
                 { name: "Decorating", g: 18, a: 1, r: 0 },
                 { name: "Carpentry",  g: 7,  a: 2, r: 1 },
                 { name: "Tiling",     g: 5,  a: 1, r: 2 },
               ] %>
            <% trades.each do |t| %>
              <% total = t[:g] + t[:a] + t[:r] %>
              <div class="grid grid-cols-12 items-center gap-3 py-2">
                <div class="col-span-3 text-sm font-medium"><%= t[:name] %></div>
                <div class="col-span-8 h-7 rounded-full bg-white overflow-hidden flex">
                  <div class="bg-emerald-400" style="width: <%= 100.0 * t[:g] / total %>%"></div>
                  <div class="bg-amber-400"   style="width: <%= 100.0 * t[:a] / total %>%"></div>
                  <div class="bg-red-400"     style="width: <%= 100.0 * t[:r] / total %>%"></div>
                </div>
                <div class="col-span-1 text-right text-sm font-semibold text-talent-navy"><%= total %></div>
              </div>
            <% end %>
          </div>
        </div>
      </div>

      <div class="lg:col-span-4 flex flex-col gap-4">
        <div class="card-accent-orange p-6 relative overflow-hidden">
          <div class="absolute inset-0 bp-grid opacity-40 pointer-events-none"></div>
          <div class="relative">
            <div class="text-xs font-semibold uppercase tracking-wider text-white/80">Awaiting acceptance</div>
            <div class="font-display text-5xl font-extrabold mt-2">9</div>
            <p class="mt-2 text-sm text-white/90 leading-relaxed">Trades who haven't replied within 24h are auto-flagged. Nudge them in one click.</p>
          </div>
        </div>

        <div class="card-surface p-5">
          <div class="text-xs font-semibold uppercase tracking-wider text-talent-muted">Awaiting sign-off</div>
          <div class="flex items-end justify-between mt-2">
            <div class="font-display text-4xl font-extrabold">17</div>
            <div class="text-xs text-emerald-600 font-semibold flex items-center gap-1">92% within 5d</div>
          </div>
          <div class="mt-3 h-12">
            <svg viewBox="0 0 200 40" class="w-full h-full" preserveAspectRatio="none">
              <polyline points="0,32 20,28 40,30 60,22 80,24 100,16 120,18 140,12 160,14 180,8 200,10" fill="none" stroke="#FC5A07" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
        </div>

        <div class="card-surface p-5">
          <div class="text-xs font-semibold uppercase tracking-wider text-talent-muted">Time to acceptance</div>
          <div class="flex items-end gap-2 mt-2">
            <div class="font-display text-4xl font-extrabold">4.2h</div>
            <div class="text-xs text-emerald-600 font-semibold pb-1">↓ 38% MoM</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<%# ============== GET YOUR TIME BACK — two-column with realistic defect card ============== %>
<section class="bg-white py-24 sm:py-32 relative overflow-hidden">
  <%# Subtle aurora backdrop %>
  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute -top-20 left-1/3 h-96 w-96 rounded-full bg-talent-sky/60 blur-3xl"></div>
    <div class="absolute -bottom-20 right-1/4 h-96 w-96 rounded-full bg-talent-cream/80 blur-3xl"></div>
  </div>

  <div class="relative mx-auto max-w-7xl px-5 sm:px-8" data-controller="reveal">
    <div class="grid lg:grid-cols-12 gap-12 lg:gap-16 items-center">

      <%# LEFT: heading + paragraph + checklist %>
      <div class="lg:col-span-5 reveal">
        <h2 class="font-display text-5xl sm:text-6xl font-extrabold tracking-tighter leading-[1.02] text-talent-navy">
          Get your<br>time back
        </h2>
        <p class="mt-6 text-lg text-talent-slate leading-relaxed">
          Focus on the work that matters while routine defect admin happens in the background.
        </p>

        <ul class="mt-10 space-y-5">
          <% [
               "Free your customer-care team from email chases.",
               "Reclaim hours each week for high-impact site visits.",
               "Let background jobs handle SLA reminders and routing.",
               "Spend more time on residents, less on spreadsheets."
             ].each do |line| %>
            <li class="flex gap-4 items-start">
              <span class="flex-shrink-0 mt-1 h-6 w-6 rounded-full bg-talent-navy text-white grid place-items-center">
                <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              </span>
              <span class="text-talent-navy text-base leading-relaxed"><%= line %></span>
            </li>
          <% end %>
        </ul>
      </div>

      <%# RIGHT: realistic defect-card mockup on a soft gradient backdrop %>
      <div class="lg:col-span-7 reveal" style="transition-delay: .15s">
        <div class="relative">
          <%# Backdrop card with rounded corners %>
          <div class="absolute -inset-3 sm:-inset-6 rounded-[2.5rem] bg-gradient-to-br from-talent-sky via-white to-talent-cream"></div>

          <%# The defect card %>
          <div class="relative rounded-2xl bg-white shadow-[0_30px_60px_-20px_rgba(2,32,67,0.25)] ring-1 ring-talent-navy/5 p-8 sm:p-10">

            <%# Title %>
            <div class="font-display text-2xl sm:text-3xl font-extrabold tracking-tight text-talent-navy">
              <span class="font-mono text-base text-talent-muted font-semibold mr-2">HY-2487</span> Leak under kitchen sink
            </div>

            <%# Properties %>
            <div class="mt-6 space-y-3.5 text-sm">
              <%# Priority row %>
              <div class="flex items-center gap-4">
                <div class="flex items-center gap-2 w-32 text-talent-muted">
                  <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
