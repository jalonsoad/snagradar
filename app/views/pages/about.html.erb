<% content_for :title, "About — SnagRadar" %>
<% content_for :description, "We're building the operational backbone of construction aftercare." %>

<%# ============== HERO ============== %>
<section class="relative bg-talent-navy text-white overflow-hidden">
  <div class="absolute inset-0 bp-grid opacity-60 pointer-events-none"></div>
  <div class="absolute -top-32 left-1/4 h-96 w-96 rounded-full bg-talent-orange/25 blur-3xl pointer-events-none"></div>
  <div class="absolute -bottom-40 -right-20 h-[28rem] w-[28rem] rounded-full bg-talent-blue/30 blur-3xl pointer-events-none"></div>

  <div class="relative mx-auto max-w-7xl px-5 sm:px-8 pt-36 sm:pt-44 pb-24 sm:pb-32 text-center" data-controller="reveal">
    <div class="max-w-3xl mx-auto reveal">
      <span class="inline-flex items-center gap-2 rounded-full bg-white/10 px-3 py-1 text-xs font-semibold tracking-wide uppercase backdrop-blur ring-1 ring-white/20">Our story</span>
      <h1 class="mt-5 font-display text-5xl sm:text-6xl lg:text-7xl font-extrabold tracking-tighter leading-[1.02] text-white">
        Built by site teams,<br>
        <span class="text-talent-orange">for site teams.</span>
      </h1>
      <p class="mt-6 text-lg text-talent-sky/85 leading-relaxed">
        SnagRadar started in a kitchen-cabinet inbox of 412 unread emails. We've been on the wrong side of a missed defect, and we built the tool we wished we'd had.
      </p>
    </div>
  </div>
</section>

<%# ============== MISSION + STATS ============== %>
<section class="section bg-white">
  <div class="mx-auto max-w-7xl px-5 sm:px-8" data-controller="reveal">
    <div class="grid lg:grid-cols-12 gap-12 items-center">
      <div class="lg:col-span-5 reveal">
        <span class="eyebrow">Our mission</span>
        <h2 class="mt-4 font-display text-4xl sm:text-5xl font-bold tracking-tight leading-[1.05]">Make aftercare accountable. Make sign-off boring.</h2>
        <p class="mt-5 text-lg text-talent-slate leading-relaxed">
          Most defect tools either pretend to be project management or balloon into enterprise platforms only a procurement team could love. We're building the in-between — a focused operational tool that site managers, customer care and subcontractors actually want to open.
        </p>
        <p class="mt-4 text-talent-slate leading-relaxed">
          We believe the next decade of UK housing depends on aftercare done right: faster fixes, clearer evidence, happier residents — without burying customer-care teams in admin.
        </p>
      </div>

      <div class="lg:col-span-7 grid grid-cols-2 gap-5 reveal" style="transition-delay: .15s">
        <% stats = [
             { value: "3.1d", label: "Average time to fix",   sub: "Across pilot sites" },
             { value: "92%",  label: "Resident sign-off rate", sub: "Within 5 days of completion" },
             { value: "−38%", label: "Time to acceptance",    sub: "Month-on-month, pilot" },
             { value: "0",    label: "Spreadsheets opened",    sub: "By our pilot customers, last week" }
           ] %>
        <% stats.each_with_index do |s, i| %>
          <% bg = case i
                  when 0 then "card-accent-navy text-white"
                  when 3 then "card-accent-orange text-white"
                  else "card-surface"
                  end %>
          <div class="<%= bg %> p-6 relative overflow-hidden">
            <% if bg.include?("accent") %><div class="absolute inset-0 bp-grid opacity-30 pointer-events-none"></div><% end %>
            <div class="relative">
              <div class="font-display text-4xl sm:text-5xl font-bold tracking-tighter"><%= s[:value] %></div>
              <div class="mt-3 text-sm font-semibold"><%= s[:label] %></div>
              <div class="text-xs <%= bg.include?('accent') ? 'text-white/70' : 'text-talent-muted' %> mt-1"><%= s[:sub] %></div>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</section>

<%# ============== TIMELINE ============== %>
<section class="section bg-talent-mist">
  <div class="mx-auto max-w-5xl px-5 sm:px-8" data-controller="reveal">
    <div class="text-center reveal">
      <span class="eyebrow-blue">How we got here</span>
      <h2 class="mt-4 font-display text-4xl sm:text-5xl font-bold tracking-tight">A short timeline</h2>
    </div>

    <div class="mt-14 relative reveal" style="transition-delay: .1s">
      <span class="hidden md:block absolute left-1/2 top-2 bottom-2 w-px bg-talent-navy/10 -translate-x-1/2"></span>
      <% milestones = [
           { date: "2024 · Spring", title: "The 412-email inbox", body: "After a difficult handover, our founder spent a week reconciling defect emails by hand. The spreadsheet had 11 tabs." },
           { date: "2024 · Summer", title: "First sketches",     body: "We started drawing a 'radar' — open, overdue, sign-off — on the back of a site plan. Customer-care leads said: 'I'd buy that.'" },
           { date: "2025 · Winter", title: "Pilot prototype",     body: "First version live on two real sites. Trades accepted defects on mobile within minutes. Customer care logged in three taps." },
           { date: "2026 · Spring", title: "Public MVP",          body: "Rails 8, Hotwire, PostgreSQL. AI roadmap defined. Pilot customers active. Public site live (you're on it)." },
         ] %>
      <% milestones.each_with_index do |m, i| %>
        <div class="relative grid md:grid-cols-2 gap-6 mb-10 last:mb-0 <%= 'md:text-right' if i.even? %>">
          <div class="<%= 'md:order-2' if i.odd? %>">
            <div class="rounded-2xl bg-white shadow-soft border border-talent-navy/5 p-6 inline-block max-w-md">
              <div class="text-xs font-mono font-semibold text-talent-orange uppercase tracking-wider"><%= m[:date] %></div>
              <div class="mt-2 font-display text-xl font-bold"><%= m[:title] %></div>
              <p class="mt-2 text-sm text-talent-slate leading-relaxed"><%= m[:body] %></p>
            </div>
          </div>
          <div class="hidden md:block absolute left-1/2 top-6 h-4 w-4 rounded-full bg-talent-orange ring-4 ring-talent-mist -translate-x-1/2"></div>
        </div>
      <% end %>
    </div>
  </div>
</section>

<%# ============== VALUES ============== %>
<section class="section bg-white">
  <div class="mx-auto max-w-7xl px-5 sm:px-8" data-controller="reveal">
    <div class="text-center max-w-2xl mx-auto reveal">
      <span class="eyebrow">What we value</span>
      <h2 class="mt-4 font-display text-4xl sm:text-5xl font-bold tracking-tight leading-[1.05]">Operational, not philosophical.</h2>
    </div>

    <div class="mt-14 grid md:grid-cols-3 gap-5 reveal" style="transition-delay: .1s">
      <% values = [
           { title: "Less typing", body: "If a site manager has to type it twice, we've already lost. Forms are short, taps are big, defaults are smart." },
           { title: "Audit by default", body: "Every action is timestamped, attributed, immutable. Accountability is a feature, not an add-on." },
           { title: "Trades-friendly", body: "Subcontractors don't want logins. They want links. We meet them where they are — on a phone, on site, in the rain." }
         ] %>
      <% values.each_with_index do |v, i| %>
        <div class="<%= i == 1 ? 'card-accent-orange text-white' : 'card-surface' %> p-7 relative overflow-hidden">
          <% if i == 1 %><div class="absolute inset-0 bp-grid opacity-25 pointer-events-none"></div><% end %>
          <div class="relative">
            <div class="font-mono text-sm font-semibold <%= i == 1 ? 'text-white/70' : 'text-talent-orange' %>">0<%= i + 1 %></div>
            <h3 class="mt-3 font-display text-2xl font-bold"><%= v[:title] %></h3>
            <p class="mt-3 leading-relaxed <%= i == 1 ? 'text-white/90' : 'text-talent-slate' %>"><%= v[:body] %></p>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</section>

<%# ============== CTA ============== %>
<section class="relative overflow-hidden">
  <div class="mx-auto max-w-7xl px-5 sm:px-8 py-20">
    <div class="card-accent-navy relative overflow-hidden p-10 sm:p-14">
      <div class="absolute inset-0 bp-grid opacity-50 pointer-events-none"></div>
      <div class="relative grid lg:grid-cols-12 gap-8 items-center">
        <div class="lg:col-span-8">
          <h2 class="font-display text-4xl sm:text-5xl font-bold tracking-tighter leading-[1.05] text-white">Want to chat about your sites?</h2>
          <p class="mt-4 text-lg text-talent-sky/85">We'd love to hear what your team is wrestling with.</p>
        </div>
        <div class="lg:col-span-4 flex">
          <%= link_to "Get in touch", contact_path, class: "btn-pill-orange w-full justify-center text-base py-4" %>
        </div>
      </div>
    </div>
  </div>
</section>
