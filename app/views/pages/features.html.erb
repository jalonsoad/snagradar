<% content_for :title, "Features — SnagRadar" %>
<% content_for :description, "Every defect, owner, SLA and evidence trail in one operational command centre." %>

<%# ============== HERO ============== %>
<section class="relative bg-talent-navy text-white overflow-hidden">
  <div class="absolute inset-0 bp-grid opacity-60 pointer-events-none"></div>
  <div class="absolute -top-40 -right-20 h-[28rem] w-[28rem] rounded-full bg-talent-orange/25 blur-3xl pointer-events-none"></div>
  <div class="absolute -bottom-32 -left-20 h-[28rem] w-[28rem] rounded-full bg-talent-blue/30 blur-3xl pointer-events-none"></div>

  <div class="relative mx-auto max-w-7xl px-5 sm:px-8 pt-36 sm:pt-40 pb-24 sm:pb-32" data-controller="reveal">
    <div class="grid lg:grid-cols-12 gap-12 items-center">

      <%# LEFT: copy %>
      <div class="lg:col-span-6 reveal">
        <span class="inline-flex items-center gap-2 rounded-full bg-white/10 px-3 py-1 text-xs font-semibold tracking-wide uppercase ring-1 ring-white/20 text-white">The product</span>
        <h1 class="mt-5 font-display text-5xl sm:text-6xl lg:text-7xl font-extrabold tracking-tighter leading-[1.02] text-white">
          Every defect.<br>
          <span class="text-talent-orange">Every owner.</span>
          <br>One radar.
        </h1>
        <p class="mt-6 text-lg text-white/75 leading-relaxed max-w-xl">
          SnagRadar is built around the way customer care, site teams and subcontractors actually work — not the way a generic ticketing tool wishes they did.
        </p>

        <%# Inline KPI chips %>
        <div class="mt-8 flex flex-wrap gap-3">
          <div class="inline-flex items-center gap-2 rounded-full bg-white/[0.06] ring-1 ring-white/10 px-4 py-2 text-sm">
            <span class="font-display text-lg font-extrabold text-talent-orange">3.1d</span>
            <span class="text-white/70">avg time-to-fix</span>
          </div>
          <div class="inline-flex items-center gap-2 rounded-full bg-white/[0.06] ring-1 ring-white/10 px-4 py-2 text-sm">
            <span class="font-display text-lg font-extrabold text-talent-orange">92%</span>
            <span class="text-white/70">sign-off rate</span>
          </div>
          <div class="inline-flex items-center gap-2 rounded-full bg-white/[0.06] ring-1 ring-white/10 px-4 py-2 text-sm">
            <span class="font-display text-lg font-extrabold text-talent-orange">−38%</span>
            <span class="text-white/70">acceptance time</span>
          </div>
        </div>
      </div>

      <%# RIGHT: layered defect-card stack with radar pulse behind %>
      <div class="lg:col-span-6 reveal" style="transition-delay: .15s">
        <div class="relative mx-auto h-[420px] sm:h-[480px] max-w-md">

          <%# Radar pulse rings behind %>
          <div class="absolute inset-0 grid place-items-center pointer-events-none">
            <div class="relative h-72 w-72">
              <span class="absolute inset-0 rounded-full ring-1 ring-talent-orange/30 animate-[radar_2.6s_ease-out_infinite]"></span>
              <span class="absolute inset-0 rounded-full ring-1 ring-talent-orange/30 animate-[radar_2.6s_ease-out_infinite] [animation-delay:.9s]"></span>
              <span class="absolute inset-0 rounded-full ring-1 ring-talent-orange/30 animate-[radar_2.6s_ease-out_infinite] [animation-delay:1.7s]"></span>
            </div>
          </div>

          <%# Card 1 — RED (overdue) — back, tilted left %>
          <div class="absolute left-2 top-4 w-72 rounded-2xl bg-white p-5 shadow-[0_30px_60px_-20px_rgba(0,0,0,0.45)] -rotate-6 ring-1 ring-talent-navy/5">
            <div class="flex items-center justify-between">
              <span class="font-mono text-xs font-semibold text-talent-muted">HY-2451</span>
              <span class="sla-red"><span class="dot bg-red-500"></span> 2d overdue</span>
            </div>
            <div class="mt-3 font-display text-base font-extrabold text-talent-navy">Leak under bathroom sink</div>
            <div class="mt-1 text-xs text-talent-muted">Plot 04 · Plumbing · High priority</div>
            <div class="mt-3 flex items-center gap-2">
              <span class="h-6 w-6 rounded-full bg-talent-blue grid place-items-center text-white text-[10px] font-bold">R</span>
              <span class="text-xs text-talent-muted">Robson Plumbing</span>
            </div>
          </div>

          <%# Card 3 — GREEN (on track) — back-right, tilted right %>
          <div class="absolute right-0 top-10 w-64 rounded-2xl bg-white p-5 shadow-[0_30px_60px_-20px_rgba(0,0,0,0.4)] rotate-6 ring-1 ring-talent-navy/5">
            <div class="flex items-center justify-between">
              <span class="font-mono text-xs font-semibold text-talent-muted">HY-2502</span>
              <span class="sla-green"><span class="dot bg-emerald-500"></span> 6d left</span>
            </div>
            <div class="mt-3 font-display text-base font-extrabold text-talent-navy">Skirting touch-up</div>
            <div class="mt-1 text-xs text-talent-muted">Plot 21 · Decorating · Low</div>
            <div class="mt-3 flex items-center gap-2">
              <span class="h-6 w-6 rounded-full bg-violet-500 grid place-items-center text-white text-[10px] font-bold">P</span>
              <span class="text-xs text-talent-muted">Pemberton Decor</span>
            </div>
          </div>

          <%# Card 2 — AMBER (approaching) — FRONT, centered, no tilt, larger %>
          <div class="absolute left-1/2 -translate-x-1/2 top-32 w-80 rounded-2xl bg-white p-6 shadow-[0_40px_80px_-20px_rgba(0,0,0,0.55)] ring-1 ring-talent-navy/5">
            <div class="flex items-center justify-between">
              <span class="font-mono text-xs font-semibold text-talent-muted">HY-2487</span>
              <span class="sla-amber"><span class="dot bg-amber-500"></span> Due in 36h</span>
            </div>
            <div class="mt-3 font-display text-lg font-extrabold text-talent-navy">Leak under kitchen sink</div>
            <div class="mt-1 text-xs text-talent-muted">Adur Shoreham · Plot 14 · Plumbing</div>

            <%# Progress chips %>
            <div class="mt-4 grid grid-cols-4 gap-1.5">
              <div class="h-1.5 rounded-full bg-emerald-500"></div>
              <div class="h-1.5 rounded-full bg-emerald-500"></div>
              <div class="h-1.5 rounded-full bg-amber-500"></div>
              <div class="h-1.5 rounded-full bg-talent-navy/10"></div>
            </div>
            <div class="mt-2 flex justify-between text-[10px] font-semibold text-talent-muted">
              <span>Logged</span><span>Accepted</span><span>Booked</span><span>Closed</span>
            </div>

            <div class="mt-4 flex items-center justify-between border-t border-talent-navy/5 pt-4">
              <div class="flex items-center gap-2">
                <span class="h-7 w-7 rounded-full bg-talent-orange grid place-items-center text-white text-xs font-bold">R</span>
                <div>
                  <div class="text-xs font-semibold text-talent-navy">Robson Plumbing</div>
                  <div class="text-[10px] text-talent-muted">Thu 11:00 booked</div>
                </div>
              </div>
              <button class="rounded-lg bg-talent-navy text-white px-3 py-1.5 text-xs font-semibold">View</button>
            </div>
          </div>

          <%# Floating notification badges %>
          <div class="hidden sm:flex absolute -top-2 right-6 items-center gap-2 rounded-full bg-talent-orange text-white px-3 py-1.5 text-xs font-semibold shadow-[var(--shadow-glow-orange)] animate-[float_6s_ease-in-out_infinite]">
            <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="currentColor"><polygon points="13 2 4 14 11 14 9 22 20 10 13 10 13 2"/></svg>
            New defect logged
          </div>
          <div class="hidden sm:flex absolute bottom-2 -left-4 items-center gap-2 rounded-full bg-white text-talent-navy px-3 py-1.5 text-xs font-semibold shadow-card animate-[float_6s_ease-in-out_infinite] [animation-delay:1.4s]">
            <span class="relative flex h-2 w-2">
              <span class="absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75 animate-ping"></span>
              <span class="relative inline-flex h-2 w-2 rounded-full bg-emerald-500"></span>
            </span>
            Resident signed off — Plot 06
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<%# ============== SECTIONED FEATURES ============== %>
<% sections = [
     {
       eyebrow: "Intake", id: "intake",
       title: "Log a defect in under two minutes",
       body: "From phone, tablet or laptop. Site managers on the ground, customer care behind a desk — same form, same fields, same speed.",
       points: [
         "Site → Plot → Trade → Priority — all pre-populated drop-downs",
         "Active Storage direct upload for camera-first photos",
         "Hyde / client reference numbers as a first-class field",
         "Default SLA target dates per trade, overridable per case"
       ],
       visual: :intake
     },
     {
       eyebrow: "Assignment", id: "assignment",
       title: "One-tap routing to the right trade",
       body: "Assign the defect to a contractor company. They get an email with a tokenised link — no login, no IT ticket.",
       points: [
         "Per-trade contractor mappings",
         "Rules-based default contractor by site + trade",
         "Auto-nudge after 24 hours of silence",
         "Acceptance / rejection with reason captured"
       ],
       visual: :assignment
     },
     {
       eyebrow: "Appointments", id: "appointments",
       title: "Appointments that don't slip through cracks",
       body: "Proposed, confirmed, attended, missed, cancelled — every state on a calendar view and the defect timeline.",
       points: [
         "Trade proposes a time slot from mobile",
         "Customer care confirms or counter-proposes",
         "Reminder notifications 24h and 2h before",
         "Calendar export for the office team"
       ],
       visual: :appointments
     },
     {
       eyebrow: "Completion + sign-off", id: "signoff",
       title: "Resident sign-off, digital and locked in",
       body: "Tokenised magic link. Drawn signature. Photos as evidence. Defect closes itself. No paperwork to chase.",
       points: [
         "Expiring sign-off links (no account required)",
         "Drawn signature stored against the defect",
         "Completion photos surfaced for resident review",
         "Customer care can re-open if signature is disputed"
       ],
       visual: :signoff
     },
     {
       eyebrow: "Audit + evidence", id: "audit",
       title: "An immutable timeline you can show a director",
       body: "Every status change, comment, upload, assignment and signature timestamped, attributed and unchangeable.",
       points: [
         "Internal vs. external visibility on comments",
         "Photos stored privately, served via signed URLs",
         "Activity events as flexible JSONB for export",
         "Built-in role-based access control"
       ],
       visual: :audit
     },
     {
       eyebrow: "Dashboard + reporting", id: "radar",
       title: "Operational visibility without running a report",
       body: "Open, overdue, approaching breach, awaiting acceptance, awaiting sign-off — at a glance. Filters, KPIs, CSV exports.",
       points: [
         "Traffic-light SLA by site / trade / contractor",
         "Average time to acceptance and completion",
         "Recurring defect detection (phase 3)",
         "CSV export for management reporting"
       ],
       visual: :radar
     }
   ] %>

<% sections.each_with_index do |s, i| %>
  <% bg = i.even? ? "bg-white" : "bg-talent-mist" %>
  <section id="<%= s[:id] %>" class="section <%= bg %>">
    <div class="mx-auto max-w-7xl px-5 sm:px-8" data-controller="reveal">
      <div class="grid lg:grid-cols-12 gap-12 items-center">
        <div class="<%= 'lg:col-span-5' %> <%= 'lg:order-2' if i.odd? %> reveal">
          <span class="eyebrow"><%= s[:eyebrow] %></span>
          <h2 class="mt-4 font-display text-3xl sm:text-4xl lg:text-5xl font-bold tracking-tight leading-[1.05]"><%= s[:title] %></h2>
          <p class="mt-5 text-lg text-talent-slate leading-relaxed"><%= s[:body] %></p>
          <ul class="mt-6 space-y-3">
            <% s[:points].each do |p| %>
              <li class="flex gap-3 text-talent-slate">
                <span class="flex-shrink-0 mt-1 h-5 w-5 rounded-full bg-talent-orange/15 grid place-items-center">
                  <svg class="h-3 w-3 text-talent-orange" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                </span>
                <span><%= p %></span>
              </li>
            <% end %>
          </ul>
        </div>

        <div class="lg:col-span-7 reveal" style="transition-delay: .15s">
          <%= render "pages/feature_visual_#{s[:visual]}" %>
        </div>
      </div>
    </div>
  </section>
<% end %>

<%# ============== CTA ============== %>
<section class="relative overflow-hidden">
  <div class="mx-auto max-w-7xl px-5 sm:px-8 py-20">
    <div class="card-accent-orange relative overflow-hidden p-10 sm:p-14">
      <div class="absolute inset-0 bp-grid opacity-25 pointer-events-none"></div>
      <div class="relative grid lg:grid-cols-12 gap-8 items-center">
        <div class="lg:col-span-8">
          <h2 class="font-display text-4xl sm:text-5xl font-bold tracking-tighter leading-[1.05]">See it on your sites.</h2>
          <p class="mt-4 text-lg text-white/90">Book a demo and we'll log a real defect from one of your projects, live.</p>
        </div>
        <div class="lg:col-span-4 flex">
          <%= link_to "Book a demo", contact_path, class: "btn-pill-dark w-full justify-center text-base py-4" %>
        </div>
      </div>
    </div>
  </div>
</section>
