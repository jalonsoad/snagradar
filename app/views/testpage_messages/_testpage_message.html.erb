<%# Single broadcast item. dom_id ensures broadcast_remove_to finds the right element. %>
<% tone = {
     "info"    => { bg: "bg-blue-50",    fg: "text-talent-blue",   border: "border-blue-200",    icon_color: "text-talent-blue"   },
     "success" => { bg: "bg-emerald-50", fg: "text-emerald-700",   border: "border-emerald-200", icon_color: "text-emerald-600"   },
     "warning" => { bg: "bg-amber-50",   fg: "text-amber-700",     border: "border-amber-200",   icon_color: "text-amber-600"     },
     "danger"  => { bg: "bg-rose-50",    fg: "text-rose-700",      border: "border-rose-200",    icon_color: "text-rose-600"      }
   }[testpage_message.kind] || { bg: "bg-gray-50", fg: "text-gray-700", border: "border-gray-200", icon_color: "text-gray-500" } %>

<div id="<%= dom_id(testpage_message) %>"
     class="flex items-start gap-3 rounded-lg border <%= tone[:border] %> <%= tone[:bg] %> p-3 text-sm">
  <span class="inline-flex items-center justify-center flex-shrink-0 h-8 w-8 rounded-lg bg-white <%= tone[:icon_color] %>">
    <% case testpage_message.kind
       when "success" %>
      <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
    <% when "warning" %>
      <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
    <% when "danger" %>
      <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
    <% else %>
      <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
    <% end %>
  </span>

  <div class="flex-1 min-w-0">
    <div class="flex items-center gap-2">
      <span class="inline-flex items-center text-[10px] font-semibold uppercase tracking-wide px-1.5 py-0.5 rounded <%= tone[:fg] %> bg-white border <%= tone[:border] %>">
        <%= testpage_message.kind %>
      </span>
      <span class="text-[11px] font-mono text-gray-400"><%= testpage_message.created_at.strftime("%H:%M:%S") %></span>
    </div>
    <p class="mt-1 text-talent-navy break-words"><%= testpage_message.body %></p>
  </div>

  <%= button_to testpage_message_path(testpage_message), method: :delete,
        class: "flex-shrink-0 h-7 w-7 grid place-items-center rounded text-gray-400 hover:text-rose-600 hover:bg-white cursor-pointer transition",
        form: { data: { turbo_confirm: nil }, class: "inline" } do %>
    <svg class="h-3 w-3" viewBox="0 0 14 14" fill="none"><path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 1 6 6m0 0 6 6M7 7l6-6M7 7l-6 6"/></svg>
  <% end %>
</div>
