<% input_classes = "mt-2 w-full rounded-xl border border-talent-navy/10 px-4 py-3 text-sm focus:outline-none focus:border-talent-orange focus:ring-2 focus:ring-talent-orange/20" %>
<% label_classes = "block text-xs font-semibold uppercase tracking-wide text-talent-muted" %>

<%= form_with model: trade, url: (trade.persisted? ? trade_path(trade) : trades_path), class: "space-y-5" do |f| %>
  <div>
    <%= f.label :name, class: label_classes %>
    <%= f.text_field :name, class: input_classes, required: true, autofocus: true %>
  </div>
  <div>
    <%= f.label :default_sla_days, "Default SLA (days)", class: label_classes %>
    <%= f.number_field :default_sla_days, class: input_classes, min: 1, max: 90, required: true %>
  </div>
  <div class="flex gap-3">
    <%= f.submit (trade.persisted? ? "Save" : "Add trade"), class: "btn-primary cursor-pointer" %>
    <%= link_to "Cancel", trades_path, class: "inline-flex items-center justify-center rounded-full bg-white text-talent-navy border border-talent-navy/10 px-7 py-3 text-sm font-semibold hover:bg-talent-mist transition" %>
  </div>
<% end %>
