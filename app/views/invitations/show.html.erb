<% content_for :title, "Accept invitation — SnagRadar" %>

<div>
  <h1 class="font-display text-3xl font-extrabold tracking-tight text-talent-navy">
    Join <%= @invitation.organization.name %>
  </h1>
  <p class="mt-2 text-talent-slate">
    <strong class="text-talent-navy"><%= @invitation.invited_by.display_name %></strong> invited you to join as
    <strong class="text-talent-navy"><%= @invitation.role.titleize %></strong>. Pick a password to get started.
  </p>

  <% if flash.now[:alert].present? %>
    <div class="mt-6 rounded-2xl bg-rose-50 ring-1 ring-rose-200 p-4 text-sm font-medium text-rose-800"><%= flash.now[:alert] %></div>
  <% end %>

  <%= form_with model: @user, url: accept_invitation_path(token: params[:token]), method: :patch, class: "mt-8 space-y-5" do |f| %>
    <div>
      <label class="block text-xs font-semibold uppercase tracking-wide text-talent-muted">Email address</label>
      <input type="email" disabled value="<%= @invitation.email_address %>"
             class="mt-2 w-full rounded-xl border border-talent-navy/10 bg-talent-mist/60 px-4 py-3 text-sm text-talent-muted">
    </div>

    <div>
      <%= f.label :name, "Your name", class: "block text-xs font-semibold uppercase tracking-wide text-talent-muted" %>
      <%= f.text_field :name, autofocus: true, autocomplete: "name", placeholder: "Sara Jenkins",
            class: "mt-2 w-full rounded-xl border border-talent-navy/10 px-4 py-3 text-sm focus:outline-none focus:border-talent-orange focus:ring-2 focus:ring-talent-orange/20" %>
    </div>

    <%= render "shared/password_field", form: f, field: :password, label: "Pick a password", autocomplete: "new-password", placeholder: "At least 8 characters" %>
    <%= render "shared/password_field", form: f, field: :password_confirmation, label: "Confirm password", autocomplete: "new-password", placeholder: "Re-type your password" %>

    <%= f.submit "Accept &amp; sign in", class: "btn-primary w-full justify-center cursor-pointer" %>
  <% end %>
</div>
