<% content_for :title, "Invite teammate — SnagRadar" %>

<div class="max-w-xl mx-auto">
  <nav class="flex items-center gap-2 text-sm text-gray-500" aria-label="Breadcrumb">
    <%= link_to "Team", invitations_path, class: "hover:text-talent-navy transition" %>
    <svg class="h-3 w-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
    <span class="font-medium text-talent-navy">Invite teammate</span>
  </nav>

  <h1 class="mt-2 text-2xl sm:text-3xl font-semibold tracking-tight text-talent-navy">Invite a teammate</h1>
  <p class="mt-1 text-sm text-gray-500">They'll get an email with a magic link to set their password (link expires in 14 days).</p>

  <div class="mt-6 rounded-lg bg-white border border-gray-200 p-6 sm:p-8">
    <%= render "form", invitation: @invitation %>

    <div class="mt-6 pt-6 border-t border-gray-100 flex gap-2">
      <button type="submit" form="<%= dom_id(@invitation) %>"
              class="inline-flex items-center gap-2 rounded-lg bg-talent-orange px-4 py-2 text-sm font-medium text-white hover:bg-talent-orange-600 cursor-pointer transition">
        Send invitation
      </button>
      <%= link_to "Cancel", invitations_path,
            class: "inline-flex items-center gap-2 rounded-lg border border-gray-200 bg-white px-4 py-2 text-sm font-medium text-talent-navy hover:bg-gray-50 transition" %>
    </div>
  </div>
</div>
