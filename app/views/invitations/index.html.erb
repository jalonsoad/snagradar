<% content_for :title, "Team — SnagRadar" %>

<div class="space-y-6">

  <%# ── Page header ──────────────────────────────────────────── %>
  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
    <div>
      <h1 class="text-2xl sm:text-3xl font-semibold tracking-tight text-talent-navy">Team</h1>
      <p class="mt-1 text-sm text-gray-500">Invite teammates to your workspace. Open invitations expire after 14 days.</p>
    </div>
    <button type="button" data-modal-target="invite-modal" data-modal-toggle="invite-modal"
            class="inline-flex items-center gap-2 rounded-lg bg-talent-orange px-4 py-2 text-sm font-medium text-white hover:bg-talent-orange-600 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-talent-orange focus-visible:ring-offset-2 cursor-pointer transition">
      <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
      Invite teammate
    </button>
  </div>

  <%# ── Pending invitations ─────────────────────────────────── %>
  <div class="bg-white border border-gray-200 rounded-lg overflow-hidden">
    <div class="px-5 py-4 border-b border-gray-200 flex items-center justify-between">
      <h3 class="text-lg font-semibold text-talent-navy">Pending invitations</h3>
      <span class="inline-flex items-center justify-center rounded-full bg-gray-100 text-gray-600 px-2 py-0.5 text-xs font-medium"><%= @pending.size %></span>
    </div>
    <% if @pending.any? %>
      <ul class="divide-y divide-gray-100">
        <% @pending.each do |inv| %>
          <li class="px-5 py-3 flex items-center gap-4">
            <span class="h-10 w-10 rounded-full bg-talent-orange-50 grid place-items-center text-talent-orange-700 font-semibold text-sm">
              <%= inv.email_address[0].upcase %>
            </span>
            <div class="flex-1 min-w-0">
              <div class="font-medium text-talent-navy truncate"><%= inv.email_address %></div>
              <div class="text-xs text-gray-500"><%= inv.role.titleize %> · invited <%= time_ago_in_words inv.created_at %> ago · expires in <%= time_ago_in_words inv.expires_at %></div>
            </div>
            <%= button_to invitation_path(inv), method: :delete,
                  data: { turbo_confirm: "Revoke invitation for #{inv.email_address}?" },
                  class: "inline-flex items-center gap-1 rounded-md bg-rose-50 text-rose-700 px-2.5 py-1 text-xs font-medium hover:bg-rose-100 cursor-pointer transition" do %>
              <svg class="h-3 w-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M3 6h18M19 6l-2 14a2 2 0 0 1-2 2H9a2 2 0 0 1-2-2L5 6"/></svg>
              Revoke
            <% end %>
          </li>
        <% end %>
      </ul>
    <% else %>
      <div class="p-10 text-center">
        <div class="mx-auto h-10 w-10 rounded-full bg-gray-100 text-gray-400 grid place-items-center">
          <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
        </div>
        <p class="mt-3 text-sm font-medium text-talent-navy">No pending invitations</p>
        <p class="mt-1 text-xs text-gray-500">Click "Invite teammate" above to send one.</p>
      </div>
    <% end %>
  </div>

  <%# ── Team members ────────────────────────────────────────── %>
  <div class="bg-white border border-gray-200 rounded-lg overflow-hidden">
    <div class="px-5 py-4 border-b border-gray-200 flex items-center justify-between">
      <h3 class="text-lg font-semibold text-talent-navy">Team members</h3>
      <span class="inline-flex items-center justify-center rounded-full bg-gray-100 text-gray-600 px-2 py-0.5 text-xs font-medium"><%= Current.organization.users.size %></span>
    </div>
    <ul class="divide-y divide-gray-100">
      <% Current.organization.users.order(:name).each do |u| %>
        <li class="px-5 py-3 flex items-center gap-4">
          <span class="h-10 w-10 rounded-full bg-talent-orange grid place-items-center text-white font-bold text-sm"><%= u.initials %></span>
          <div class="flex-1 min-w-0">
            <div class="font-medium text-talent-navy">
              <%= u.display_name %>
              <% if u == Current.user %><span class="ml-1 text-xs text-gray-500 font-normal">(you)</span><% end %>
            </div>
            <div class="text-xs text-gray-500"><%= u.email_address %></div>
          </div>
          <span class="inline-flex items-center text-xs font-medium px-2.5 py-0.5 rounded-full bg-gray-100 text-talent-navy capitalize">
            <%= u.role.tr("_", " ") %>
          </span>
        </li>
      <% end %>
    </ul>
  </div>
</div>

<%# ── Invite teammate modal (Flowbite) ─────────────────────── %>
<div id="invite-modal" tabindex="-1" aria-hidden="true"
     class="hidden overflow-y-auto overflow-x-hidden fixed top-0 right-0 left-0 z-50 justify-center items-center w-full md:inset-0 h-[calc(100%-1rem)] max-h-full">
  <div class="relative p-4 w-full max-w-md max-h-full">
    <div class="relative bg-white rounded-lg shadow-lg border border-gray-200">

      <div class="flex items-start justify-between p-5 border-b border-gray-200">
        <div>
          <h3 class="text-lg font-semibold text-talent-navy">Invite a teammate</h3>
          <p class="text-xs text-gray-500 mt-0.5">They'll get an email with a magic link to set their password (expires in 14 days).</p>
        </div>
        <button type="button" data-modal-hide="invite-modal"
                class="text-gray-400 bg-transparent hover:bg-gray-100 hover:text-talent-navy rounded-lg text-sm w-8 h-8 inline-flex justify-center items-center cursor-pointer transition" aria-label="Close">
          <svg class="w-3 h-3" viewBox="0 0 14 14" fill="none"><path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 1 6 6m0 0 6 6M7 7l6-6M7 7l-6 6"/></svg>
        </button>
      </div>

      <div class="p-5">
        <%# When the form re-renders with errors, the modal needs to stay open
            on page load. The classes below open it via Flowbite's data-modal-show. %>
        <% invitation = @invitation || Current.organization.invitations.build(role: :care_coord) %>
        <%= render "form", invitation: invitation %>
      </div>

      <div class="flex items-center justify-end gap-2 p-4 border-t border-gray-200">
        <button type="button" data-modal-hide="invite-modal"
                class="rounded-lg border border-gray-200 bg-white px-4 py-2 text-sm font-medium text-talent-navy hover:bg-gray-50 cursor-pointer transition">Cancel</button>
        <%# Click triggers the form's submit. %>
        <button type="submit" form="<%= dom_id(invitation || Current.organization.invitations.new) %>"
                class="rounded-lg bg-talent-orange px-4 py-2 text-sm font-medium text-white hover:bg-talent-orange-600 cursor-pointer transition">
          Send invitation
        </button>
      </div>
    </div>
  </div>
</div>

<% if @invitation&.errors&.any? %>
  <%# Validation failed on submit — re-open the modal on next paint.
      Flowbite's Modal instance exposes show() once initFlowbite has bound it. %>
  <script>
    document.addEventListener("turbo:load", () => {
      const trigger = document.querySelector('[data-modal-toggle="invite-modal"]');
      trigger?.click();
    }, { once: true });
  </script>
<% end %>
