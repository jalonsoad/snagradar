<% content_for :title, "Set new password — SnagRadar" %>
<% content_for :auth_top_link do %>
  <%= link_to "Sign in", new_session_path, class: "ml-1 font-semibold text-talent-orange hover:text-talent-orange-700 transition" %>
<% end %>

<div>
  <h1 class="font-display text-3xl font-extrabold tracking-tight text-talent-navy">Set a new password</h1>
  <p class="mt-2 text-talent-slate">Choose something you'll remember — at least 8 characters.</p>

  <% if alert = flash[:alert] %>
    <div class="mt-6 rounded-2xl bg-rose-50 ring-1 ring-rose-200 p-4 text-sm font-medium text-rose-800" role="alert"><%= alert %></div>
  <% end %>

  <%= form_with url: password_path(params[:token]), method: :put, class: "mt-8 space-y-5" do |form| %>
    <%= render "shared/password_field",
        form: form,
        field: :password,
        label: "New password",
        autocomplete: "new-password",
        autofocus: true,
        placeholder: "At least 8 characters" %>

    <%= render "shared/password_field",
        form: form,
        field: :password_confirmation,
        label: "Confirm new password",
        autocomplete: "new-password",
        placeholder: "Re-type your password" %>

    <%= form.submit "Save new password", class: "btn-primary w-full justify-center cursor-pointer" %>
  <% end %>
</div>
